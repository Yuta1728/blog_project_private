# Python関連
__pycache__/
*.py[cod]
*$py.class

# 仮想環境（venvを使用している場合）
venv/
.venv/
env/

# 環境変数・シークレット情報
# config.pyでOS環境変数を読み込む運用が基本ですが、
# もし .env ファイルを作成して管理している場合は必須です
.env
.env.*

# データベース関連
# SQLiteを使用している場合は、そのファイルを除外（PostgreSQLなら不要）
*.db
*.sqlite3

# OS生成ファイル
.DS_Store
Thumbs.db

# ログファイル
*.log

# アップロードされた画像（static/img/ 以下を丸ごと除外したい場合）
# もし初期設定画像以外をgit管理したくない場合は以下を追加
# static/img/uploads/