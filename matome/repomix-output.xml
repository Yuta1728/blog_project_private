        {% endif %}
    </div>

    <h3 class="section-title-posts">📝 投稿一覧</h3>

    {% for post in posts %}
        <article class="post-card">
            <div class="post-thumbnail">
                {# サムネイル表示の優先順位:
                   1. thumbnail_img（アップロードされた専用サムネイル）
                   2. default_thumb（プリセットから選択したデフォルトサムネイル）
                   3. system-default.jpg（システム共通のデフォルト） #}
                {% if post.thumbnail_img %}
                    <img src="{{ url_for('static', filename='img/posts/' + post.thumbnail_img) }}" alt="{{ post.title }}" class="thumb-img">
                {% elif post.default_thumb %}
                    <img src="{{ url_for('static', filename='img/thbnails/' + post.default_thumb) }}" alt="選択されたデフォルトサムネイル" class="thumb-img">
                {% else %}
                    <img src="{{ url_for('static', filename='img/thbnails/system-default.jpg') }}" alt="システム共通デフォルトサムネイル" class="thumb-img">
                {% endif %}
            </div>

            <div class="post-content">
                <div class="post-header-meta">
                    <span class="badge-genre">📂 {{ post.genre if post.genre else '未分類' }}</span>
                    {% if not post.is_published %}
                        <span class="badge-private">🔒 非公開</span>
                    {% endif %}
                </div>

                <h2 class="post-title">
                    <a href="{{ url_for('blog.detail', id=post.id) }}">{{ post.title }}</a>
                </h2>

                {# ===== ハッシュタグバッジ ===== #}
                {% if post.hashtags %}
                    <div class="post-hashtags">
                        {% for tag in post.hashtags %}
                            <a href="{{ url_for('blog.index', genre=post.genre, hashtag=tag.name) }}" class="hashtag-badge">
                                #{{ tag.name }}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
                {# ============================= #}

                <p class="post-date">
                    🕒 投稿: {{ post.created_at.strftime('%Y年%m月%d日') }}
                    {% if post.updated_at %}
                        <span class="updated-date">（更新: {{ post.updated_at.strftime('%Y年%m月%d日') }}）</span>
                    {% endif %}
                </p>

                <div class="post-actions">
                    <a href="{{ url_for('admin.update', id=post.id) }}" role="button" class="btn-edit">編集</a>
                    <form action="{{ url_for('admin.delete', id=post.id) }}" method="POST" onsubmit="return confirm('本当にこの投稿を削除しますか？');">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                        <button type="submit" class="btn-delete">削除</button>
                    </form>
                </div>
            </div>
        </article>
    {% else %}
        <p class="empty-message">まだ投稿がありません。<br><a href="{{ url_for('admin.create') }}">最初の記事を書いてみましょう</a></p>
    {% endfor %}

    {# ===== 「もっと見る」「表示を減らす」ボタン ===== #}
    <div class="load-more-wrap" id="mypage-load-more-wrap">
        <button class="load-less-btn" id="mypage-load-less-btn" type="button"
                onclick="mypageLoadLess()">
            ▲ 表示を減らす
        </button>
        <button class="load-more-btn" id="mypage-load-more-btn" type="button"
                onclick="mypageLoadMore()">
            もっと見る
            <span class="load-more-count" id="mypage-load-more-count"></span>
        </button>
    </div>
    {# ================================================ #}

</div>

<script>
(function () {
    var INITIAL = 4;
    var STEP    = 4;

    var cards   = Array.from(document.querySelectorAll('.mypage-container > article.post-card'));
    var total   = cards.length;
    var shown   = 0;

    var wrap    = document.getElementById('mypage-load-more-wrap');
    var countEl = document.getElementById('mypage-load-more-count');
    var lessBtn = document.getElementById('mypage-load-less-btn');
    var moreBtn = document.getElementById('mypage-load-more-btn');

    cards.forEach(function (c) { c.style.display = 'none'; });

    function showCards(n) {
        var end = Math.min(shown + n, total);
        for (var i = shown; i < end; i++) {
            cards[i].style.display = '';
        }
        shown = end;
        updateBtn();
    }

    function hideCards(n) {
        var end = Math.max(shown - n, INITIAL);
        for (var i = end; i < shown; i++) {
            cards[i].style.display = 'none';
        }
        shown = end;
        updateBtn();
    }

    function updateBtn() {
        var remaining = total - shown;

        /* ラッパー：初期1件のみ表示中は非表示、それ以外は常に表示 */
        wrap.style.display = (shown <= INITIAL && remaining <= 0) ? 'none' : 'flex';

        /* もっと見るボタン：残件数0なら非表示 */
        moreBtn.style.display = remaining > 0 ? 'inline-flex' : 'none';
        countEl.textContent   = 'あと ' + remaining + ' 件';

        /* 表示を減らすボタン：INITIAL件より多く表示中なら表示 */
        lessBtn.style.display = shown > INITIAL ? 'inline-flex' : 'none';
    }

    window.mypageLoadMore = function () { showCards(STEP); };
    window.mypageLoadLess = function () { hideCards(STEP); };

    showCards(INITIAL);
})();
</script>

{% endblock %}
</file>

<file path="templates/search_area.html">
{# templates/search_area.html
   index ページ専用の検索エリア（部分テンプレート）
   使い方: {% include 'search_area.html' %}

   依存する変数（index ビューから渡される）:
     selected_genre   : 現在選択中のジャンル名（str | None）
     search_word      : 現在のキーワード（str | None）
     genre_list_all   : 選択肢として表示するジャンル名リスト（list[str]）

   将来拡張:
     - selected_hashtag を追加してタグ絞り込みも並べられる構造
     - sort_order（新着順 / 人気順）をここに追加可能
#}

<section class="index-search-area" aria-label="記事検索">
    <p class="index-search-title">📖 記事を探す</p>

    <form action="{{ url_for('blog.index') }}" method="GET" class="index-search-form" id="indexSearchForm">

        {# ジャンル選択 #}
        <div class="index-search-field index-search-genre">
            <label for="indexGenreSelect" class="index-search-label">ジャンル</label>
            <div class="index-search-select-wrap">
                <select name="genre"
                        id="indexGenreSelect"
                        class="index-search-select"
                        aria-label="ジャンルを選択">
                    <option value="">すべてのジャンル</option>
                    {% for g in genre_list_all %}
                        <option value="{{ g }}" {% if selected_genre == g %}selected{% endif %}>
                            {{ g }}
                        </option>
                    {% endfor %}
                </select>
                {# カスタム矢印アイコン #}
                <svg class="index-search-select-arrow" viewBox="0 0 16 16" fill="none"
                     xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.8"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>

        {# キーワード入力 #}
        <div class="index-search-field index-search-keyword">
            <label for="indexSearchInput" class="index-search-label">キーワード</label>
            <div class="index-search-input-wrap">
                <svg class="index-search-input-icon" viewBox="0 0 24 24" fill="none"
                     xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5
                             16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16
                             c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5z"
                          fill="currentColor"/>
                </svg>
                <input type="text"
                       name="search"
                       id="indexSearchInput"
                       class="index-search-input"
                       value="{{ search_word if search_word else '' }}"
                       placeholder="タイトル・タグで検索…"
                       autocomplete="off"
                       aria-label="キーワードを入力">
                {# 入力クリアボタン（JS で表示切替） #}
                <button type="button"
                        class="index-search-clear"
                        id="indexSearchClear"
                        aria-label="キーワードをクリア">✕</button>
            </div>
        </div>

        {# 検索ボタン #}
        <div class="index-search-field index-search-action">
            {# label のスペースを合わせて縦位置を揃える（PCのみ） #}
            <span class="index-search-label index-search-label-spacer" aria-hidden="true"></span>
            <button type="submit" class="index-search-btn">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
                     width="17" height="17" aria-hidden="true">
                    <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5
                             16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16
                             c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5z"
                          fill="currentColor"/>
                </svg>
                検索する
            </button>
            {% if search_word or selected_genre %}
                <a href="{{ url_for('blog.index') }}" class="index-search-reset">
                    絞り込みを解除
                </a>
            {% endif %}
        </div>

    </form>
</section>

<script>
/* ============================================================
   index 検索エリア：クリアボタンの表示制御
   ============================================================ */
(function () {
    var input   = document.getElementById('indexSearchInput');
    var clearBtn = document.getElementById('indexSearchClear');
    if (!input || !clearBtn) return;

    function updateClear() {
        clearBtn.style.display = input.value.length > 0 ? 'flex' : 'none';
    }

    input.addEventListener('input', updateClear);
    clearBtn.addEventListener('click', function () {
        input.value = '';
        input.focus();
        updateClear();
    });

    /* ページロード時に既存値があればボタンを表示 */
    updateClear();
})();
</script>
</file>

