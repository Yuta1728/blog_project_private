/* ------------------------------------------------------------
   【mypage.html】「もっと見る」ボタン内の残り件数バッジ（「あと◯件」）
   ------------------------------------------------------------ */
.load-more-count {
    display: inline-block;
    background: #dbeafe;
    color: #0369a1;
