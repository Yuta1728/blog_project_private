    font-weight: 500;
    padding: 8px 16px;
    border-radius: 20px;
    background-color: transparent;
    border: 1.5px solid #8cc8e8;
    transition: all 0.18s ease;
    display: inline-block;
    white-space: nowrap;
}

.header-nav ul li a:hover {
    color: #0d3a52;
    border-color: #5aaedc;
    background-color: #dff0fb;
    text-decoration: none;
}

/* 「新規投稿」アクセントカラー */
.header-nav ul li:first-child a {
    background-color: #1a7aad;
    color: #fff;
    border-color: #1a7aad;
}

.header-nav ul li:first-child a:hover {
    background-color: #155f8a;
    border-color: #155f8a;
    color: #fff;
}

/* ===========================
   ハンバーガーボタン（スマホ）
   =========================== */
.hamburger-btn {
    display: none;
    background: none;
    border: 1.5px solid #c5dff0;
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
}

.hamburger-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #1a6a96;
    border-radius: 2px;
    transition: all 0.25s ease;
}

/* ===========================
   ドロワーナビ（スマホ）
   =========================== */
.mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(13, 58, 82, 0.45);
    z-index: 999;
}

.mobile-nav-overlay.open {
    display: block;
}

.mobile-nav-drawer {
    position: fixed;
    top: 0;
    right: -290px;
    width: 270px;
    height: 100dvh;
    background: #ffffff;
    box-shadow: -4px 0 20px rgba(26, 122, 173, 0.15);
    z-index: 1000;
    transition: right 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
}

.mobile-nav-drawer.open {
    right: 0;
}

.mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 1px solid #dff0fb;
}

.mobile-nav-header-logo {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a7aad;
}

.mobile-nav-close {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #5a8ba8;
    padding: 4px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    transition: background 0.15s;
}

.mobile-nav-close:hover,
.mobile-nav-close:active {
    background: #eef6fb;
}

.mobile-nav-drawer ul {
    list-style: none;
    margin: 12px 0 0;
    padding: 0 12px;
}

.mobile-nav-drawer ul li {
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 6px;
}

.mobile-nav-drawer ul li a {
    display: block;
    padding: 14px 16px;
    color: #1a5f85;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    transition: background 0.15s;
    border-radius: 8px;
    min-height: 48px;
}

.mobile-nav-drawer ul li a:hover,
.mobile-nav-drawer ul li a:active {
    background: #dff0fb;
}

.mobile-nav-drawer ul li:first-child a {
    background-color: #1a7aad;
    color: #fff;
    margin-bottom: 12px;
    text-align: center;
}

.mobile-nav-drawer ul li:first-child a:hover,
.mobile-nav-drawer ul li:first-child a:active {
    background-color: #155f8a;
}

.clear { clear: both; }

/* ==========================================================================
   レスポンシブ（スマホ）
   ========================================================================== */
@media (max-width: 767px) {
    .header-container {
        padding: 0 15px;
        height: 63px;
        gap: 12px;
    }

    .header-logo a {
        font-size: 24px;
    }

    .header-nav {
        display: none;
    }

    .hamburger-btn {
        display: flex;
    }

    .flash-messages {
        margin: 12px 16px;
    }

    .flash-messages li {
        font-size: 13px;
    }

    h2 {
        font-size: 20px;
