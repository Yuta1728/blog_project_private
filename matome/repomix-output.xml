<file path="templates/mypage.html">
{% extends "base.html" %}
{% from '_macros.html' import post_card with context %}
{% block content %}

{# ============================================================
   マイページ

   【今回の変更: JS「もっと見る」→ サーバーサイドページネーション】
   従来はビュー側で自分の全投稿を渡し、ここで全カードを描画してから
   JavaScript で先頭 4 件以外を display:none で隠す「もっと見る」方式だった。
   ビュー（views/admin.py の mypage）を index と同じ paginate() に統一した
   ため、テンプレートも index.html と同じページ番号ナビに置き換える。

   これにより
     ・受け取る posts は「現在ページ分（最大 POSTS_PER_PAGE 件）」だけ
     ・全カードを隠すための JS と load_more.css が不要
   になった。総投稿数は total_count（全件数）で表示する。
   ============================================================ #}

<link rel="stylesheet" href="{{ url_for('static', filename='css/index.css') }}">
<link rel="stylesheet" href="{{ url_for('static', filename='css/mypage.css') }}">
{# load_more.css はもっと見る方式の撤去に伴い読み込み不要になったため削除 #}


<div class="mypage-container">

    <div class="profile-header">
        <h2 class="profile-title">
            👤 {% if current_user.nickname %}{{ current_user.nickname }}{% endif %} さんのマイページ
        </h2>

        {# 総投稿数はページ分ではなく全件数（total_count）を表示する #}
        <p class="profile-post-count">
            これまでの総投稿数: <strong>{{ total_count }}</strong> 件
        </p>

        <div class="nickname-form-wrapper">
            <form method="POST" action="{{ url_for('admin.mypage') }}" class="nickname-form">
                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">

                <label for="nickname">ニックネーム変更:</label>
                <input type="text" name="nickname" id="nickname"
                    class="nickname-input"
                    placeholder="新しいニックネーム"
                    maxlength="50">
                <button type="submit" class="nickname-submit-btn">変更する</button>
            </form>
        </div>
    </div>

    <h3 class="section-title-genre">📂 あなたの作成・使用したジャンル</h3>
    <div class="user-genre-list">
        {% if user_genres %}
            <ul class="genre-tags">
                {% for genre_item in user_genres %}
                <li class="genre-tag-item">
                    <a href="{{ url_for('blog.index', genre=genre_item) }}" class="genre-tag-link">{{ genre_item }}</a>
                </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="genre-empty-note">登録されたジャンルはありません。</p>
        {% endif %}
    </div>

    <h3 class="section-title-posts">📝 投稿一覧</h3>

    {# ===== ページ送りのリンク先がここへ来るようにするための目印 =====
       固定ヘッダーに隠れないよう scroll-margin-top を mypage.css で確保。
       ページ番号リンクの #mypage-articles-anchor フラグメントで
       投稿一覧の先頭へジャンプする（index.html と同じ仕組み）。 #}
    <div id="mypage-articles-anchor"></div>
    {# ========================================================= #}

    {# 記事カードは _macros.html の post_card マクロで描画（index.html と共通）。
       マイページは自分の記事のみ一覧するため、マクロ内の
       「ログイン中 かつ 自分の記事」条件は常に真となり、
       従来どおり全カードに編集・削除ボタンが表示される。 #}
    {% for post in posts %}
        {{ post_card(post) }}
    {% else %}
        <p class="empty-message">まだ投稿がありません。<br><a href="{{ url_for('admin.create') }}">最初の記事を書いてみましょう</a></p>
    {% endfor %}

    {# ============================================================
       ページ番号によるページ送り（サーバーサイドページネーション）
       ------------------------------------------------------------
       index.html と同じデザイン（index.css の .index-pagination /
       .page-btn 系）を流用する（mypage.html は index.css を読み込み済み）。
       リンク先は admin.mypage。#mypage-articles-anchor フラグメントで
       ページ遷移後に投稿一覧の先頭へスクロールする。
       ============================================================ #}
    {% if pagination.pages > 1 %}
        <nav class="index-pagination" aria-label="投稿一覧のページ送り">

            {# --- 前へ --- #}
            {% if pagination.has_prev %}
                <a href="{{ url_for('admin.mypage', page=pagination.prev_num, _anchor='mypage-articles-anchor') }}"
                   class="page-btn page-btn-arrow" aria-label="前のページ" rel="prev">‹</a>
            {% else %}
                <span class="page-btn page-btn-arrow page-btn-disabled" aria-hidden="true">‹</span>
            {% endif %}

            {# --- ページ番号（前後2ページ + 端を表示、間は … で省略） --- #}
            {% for p in pagination.iter_pages(left_edge=1, left_current=2, right_current=2, right_edge=1) %}
                {% if p %}
                    {% if p == pagination.page %}
                        <span class="page-btn active" aria-current="page">{{ p }}</span>
                    {% else %}
                        <a href="{{ url_for('admin.mypage', page=p, _anchor='mypage-articles-anchor') }}"
                           class="page-btn">{{ p }}</a>
                    {% endif %}
                {% else %}
                    <span class="page-ellipsis" aria-hidden="true">…</span>
                {% endif %}
            {% endfor %}

            {# --- 次へ --- #}
            {% if pagination.has_next %}
                <a href="{{ url_for('admin.mypage', page=pagination.next_num, _anchor='mypage-articles-anchor') }}"
                   class="page-btn page-btn-arrow" aria-label="次のページ" rel="next">›</a>
            {% else %}
                <span class="page-btn page-btn-arrow page-btn-disabled" aria-hidden="true">›</span>
            {% endif %}

        </nav>
    {% endif %}
    {# ================================================ #}

</div>

{% endblock %}
</file>

<file path="templates/search_area.html">
{# templates/search_area.html
   index ページ専用の検索エリア（部分テンプレート）
   使い方: {% include 'search_area.html' %}

   依存する変数（index ビューから渡される）:
     selected_genre   : 現在選択中のジャンル名（str | None）
     search_word      : 現在のキーワード（str | None）
     genre_list_all   : 選択肢として表示するジャンル名リスト（list[str]）

   将来拡張:
     - selected_hashtag を追加してタグ絞り込みも並べられる構造
     - sort_order（新着順 / 人気順）をここに追加可能
#}

<section class="index-search-area" aria-label="記事検索">
    <p class="index-search-title">📖 記事を探す</p>

    <form action="{{ url_for('blog.index') }}" method="GET" class="index-search-form" id="indexSearchForm">

        {# ジャンル選択 #}
        <div class="index-search-field index-search-genre">
            <label for="indexGenreSelect" class="index-search-label">ジャンル</label>
            <div class="index-search-select-wrap">
                <select name="genre"
                        id="indexGenreSelect"
                        class="index-search-select"
                        aria-label="ジャンルを選択">
                    <option value="">すべてのジャンル</option>
                    {% for g in genre_list_all %}
                        <option value="{{ g }}" {% if selected_genre == g %}selected{% endif %}>
                            {{ g }}
                        </option>
                    {% endfor %}
                </select>
                {# カスタム矢印アイコン #}
                <svg class="index-search-select-arrow" viewBox="0 0 16 16" fill="none"
                     xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.8"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>

        {# キーワード入力 #}
        <div class="index-search-field index-search-keyword">
            <label for="indexSearchInput" class="index-search-label">キーワード</label>
            <div class="index-search-input-wrap">
                <svg class="index-search-input-icon" viewBox="0 0 24 24" fill="none"
                     xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5
                             16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16
                             c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5z"
                          fill="currentColor"/>
                </svg>
                <input type="text"
                       name="search"
                       id="indexSearchInput"
                       class="index-search-input"
                       value="{{ search_word if search_word else '' }}"
                       placeholder="タイトル・タグで検索…"
                       autocomplete="off"
                       aria-label="キーワードを入力">
                {# 入力クリアボタン（JS で表示切替） #}
                <button type="button"
                        class="index-search-clear"
                        id="indexSearchClear"
                        aria-label="キーワードをクリア">✕</button>
            </div>
        </div>

        {# 検索ボタン #}
        <div class="index-search-field index-search-action">
            {# label のスペースを合わせて縦位置を揃える（PCのみ） #}
            <span class="index-search-label index-search-label-spacer" aria-hidden="true"></span>
            <button type="submit" class="index-search-btn">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
                     width="17" height="17" aria-hidden="true">
                    <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5
                             16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16
                             c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5z"
                          fill="currentColor"/>
                </svg>
                検索する
            </button>
            {% if search_word or selected_genre %}
                <a href="{{ url_for('blog.index') }}" class="index-search-reset">
                    絞り込みを解除
                </a>
            {% endif %}
        </div>

    </form>
</section>

<script>
/* ============================================================
   index 検索エリア：クリアボタンの表示制御
   ============================================================ */
(function () {
    var input   = document.getElementById('indexSearchInput');
    var clearBtn = document.getElementById('indexSearchClear');
    if (!input || !clearBtn) return;

    function updateClear() {
        clearBtn.style.display = input.value.length > 0 ? 'flex' : 'none';
    }

    input.addEventListener('input', updateClear);
    clearBtn.addEventListener('click', function () {
        input.value = '';
        input.focus();
        updateClear();
    });

    /* ページロード時に既存値があればボタンを表示 */
    updateClear();
})();
</script>
</file>

