    font-weight: 700;
}

.mobile-nav-drawer ul li:first-child a:hover,
.mobile-nav-drawer ul li:first-child a:active {
    background-color: #0369a1;
}

/* 【共通】floatクリア用ユーティリティ */
.clear { clear: both; }


/* ==========================================================================
   【共通ヘッダー】レスポンシブ（スマホ）
   ========================================================================== */

@media (max-width: 767px) {

    /* ========================================================================
       【スマホのフォントが細く見える問題への対応】
       ------------------------------------------------------------------------
       body に指定している -webkit-font-smoothing: antialiased は、
       WebKit 系ブラウザ（iPhone の Safari / Chrome など）で文字の線を
       グレースケール・アンチエイリアスで「細く」描画する。
       一方 Windows の Chrome / Edge はこの指定を無視し、ClearType で
       しっかりした太さで描画するため、
       「Windows では普通なのにスマホだけ痩せて見える」差が生まれていた。

       文字の太さ（font-weight）は Windows もスマホも同じ値なので、
       スマホ側でこの痩せる描画（antialiased）を解除するだけで、
       Windows とほぼ同じ見た目の太さになる。

       - -webkit-font-smoothing: auto  … WebKit 系の痩せ描画を解除
       - -moz-osx-font-smoothing: auto … macOS 版 Firefox 用の同等指定
       ※ これらのプロパティは継承されるため html, body に指定すれば
         ページ内すべての文字（他CSSファイルで装飾された要素も含む）に効く。
       ======================================================================== */
    html,
    body {
        -webkit-font-smoothing: auto;
        -moz-osx-font-smoothing: auto;
    }

    .header-container {
        padding: 0 15px;
        height: 63px;
        gap: 12px;
    }

    /* 固定ヘッダーの高さがスマホでは63pxになるため、
       本文の押し下げ量もそれに合わせて上書きする。 */
    body {
        padding-top: 63px;
    }

    .header-logo a {
        font-size: 26px;
    }

    .header-nav {
        display: none;
    }

    /* スマホではナビが消える分、右側の間隔を詰める */
    .header-right {
        gap: 10px;
    }

    /* スマホでもテーマ切り替えボタンは常時表示（少しだけ小さく） */
    .theme-toggle-btn {
        width: 38px;
        height: 38px;
        font-size: 17px;
    }

    .hamburger-btn {
        display: flex;
    }

    .flash-messages {
        margin: 12px 16px;
    }

    .flash-messages li {
        font-size: 13px;
    }

    h2 {
        font-size: 20px;
        margin: 16px 0;
    }
}
</file>

<file path="static/css/create_update.css">
/* ============================================================
   static/css/create_update.css - Coastal Dawn v2
   【対象ページ】 create.html（新規投稿）／ update.html（記事編集）
   ============================================================
   このファイルは投稿作成・編集フォーム専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【create.html / update.html】ページ見出し（「新規投稿作成」「編集」）
   ------------------------------------------------------------ */
h1 {
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    margin: 36px 0 24px;
    color: #0c1f35;
    letter-spacing: -0.01em;
}

/* ------------------------------------------------------------
   【create.html / update.html】フォームカード全体
   ------------------------------------------------------------ */
.post-form {
    max-width: 720px;
    margin: 0 auto 60px;
    background: #fff;
    padding: 40px 44px;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    box-sizing: border-box;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.post-form label {
    display: block;
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 8px;
    color: #0c1f35;
    letter-spacing: 0.02em;
}

/* ------------------------------------------------------------
   【create.html / update.html】タイトル入力欄・ジャンル選択セレクト
   ------------------------------------------------------------ */
.post-form input[type="text"],
.post-form select {
    width: 100% !important;
    padding: 10px 14px;
    font-size: 15px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    box-sizing: border-box;
    margin-bottom: 22px;
    outline: none;
    background-color: #f0f9ff;
    color: #0c1f35;
    transition: border-color 0.18s, background 0.18s, box-shadow 0.18s;
    font-family: inherit;
}

.post-form input[type="text"]:focus,
.post-form select:focus {
    border-color: #0ea5e9;
    background-color: #fff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* ------------------------------------------------------------
   【create.html / update.html】「+ 新しいジャンルを作成する」入力欄
   ------------------------------------------------------------
   初期状態は非表示。セレクトで「__NEW__」が選ばれたときに
   JS（toggleNewGenreInput）が style.display を書き換えて表示する。
   ------------------------------------------------------------ */
#new_genre_wrapper {
    display: none;
}

/* ------------------------------------------------------------
   【create.html / update.html】本文（Markdown）入力用テキストエリア
   ------------------------------------------------------------ */
.post-form textarea {
    width: 100% !important;
    padding: 18px !important;
    font-size: 20px !important;
    line-height: 1.9 !important;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace !important;
    letter-spacing: normal !important;
    border: 1px solid #7dd3fa !important;
    border-radius: 8px !important;
    box-sizing: border-box !important;
    margin-bottom: 22px !important;
    outline: none !important;
    background-color: #f0f9ff !important;
    color: #0c1f35 !important;
    min-height: 520px !important;
    resize: vertical !important;
    transition: border-color 0.18s, background 0.18s !important;
}

.post-form textarea:focus {
    border-color: #0ea5e9 !important;
    background-color: #fff !important;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12) !important;
}

/* フォーム内の補足説明テキスト（各項目のヘルプ文） */
.post-form p { font-size: 15px; color: #2a4a5e; margin: 0 0 8px; line-height: 1.5; font-weight: 500; }

/* 画像アップロード用のネイティブ input[type=file] */
.post-form input[type="file"] { display: block; margin-bottom: 24px; font-size: 13px; color: #0c1f35; width: 100%; }

/* ------------------------------------------------------------
   【create.html / update.html】画像選択用の隠し input[type=file]
   ------------------------------------------------------------
   「📂 複数まとめて選択」「＋ 1枚追加」ボタンから JS の .click() で
   間接的に起動するため、input 自体は常に非表示にする。
   ------------------------------------------------------------ */
.post-form input[type="file"].img-input-hidden {
    display: none;
}

/* ------------------------------------------------------------
   【create.html / update.html】「複数まとめて選択」「＋1枚追加」ボタンの行
   ------------------------------------------------------------ */
.img-upload-btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
}

/* ------------------------------------------------------------
   【create.html / update.html】画像アップロードボタン
   ------------------------------------------------------------ */
.img-upload-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: all 0.18s;
    font-family: inherit;
    line-height: 1;
    min-height: 38px;
}

/* 「📂 複数まとめて選択」ボタン */
.img-upload-btn--bulk {
    background: #f5f9fd;
    color: #1a5f85;
    border-color: #c5dff0;
}

.img-upload-btn--bulk:hover {
    background: #dff0fb;
    border-color: #5aaedc;
}

/* 「＋ 1枚追加」ボタン */
.img-upload-btn--one {
    background: #e7f7ff;
    color: #1a5f85;
    border-color: #8cc8e8;
}

.img-upload-btn--one:hover {
    background: #c5dff0;
    border-color: #1a7aad;
}

/* ------------------------------------------------------------
   【create.html / update.html】画像プレビューエリア
   ------------------------------------------------------------
   #preview-area は初期非表示。画像が選択されたときに
   JS（renderPreviews）が style.display を書き換えて表示する。
   ------------------------------------------------------------ */
#preview-area {
    display: none;
}

/* 【update.html】既存画像エリアとの間隔調整用モディファイア */
.preview-area--spaced {
    margin-top: 14px;
}

/* プレビューエリアの見出し（「📸 アップロード画像プレビュー」等） */
.preview-area-title {
    font-weight: bold;
    font-size: 14px;
    color: #444;
    margin-bottom: 10px;
}

/* プレビューカードを並べるリスト
   （#preview-list: 新規画像 / #existing-img-list: 【update.html】既存画像） */
#preview-list,
#existing-img-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 20px;
}

/* ------------------------------------------------------------
   【create.html / update.html】画像アップロードのプレビューカード
   （[imgN]ラベル・ファイル名・削除ボタンを含むカード）
   ------------------------------------------------------------ */
.preview-item {
    position: relative;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    overflow: hidden;
    background: #f0f9ff;
    width: 150px;
    margin-bottom: 8px;
}

.preview-item img { width: 150px; height: 112px; object-fit: cover; display: block; }

/* 【update.html】既存画像カード（新規プレビューよりひと回り大きい 200px 幅）
   ※ （旧インライン style="width: 200px;" と同じ優先度関係を維持） */
.preview-item.existing-img-item {
    width: 200px;
}

/* デフォルトサムネイルのプレビューカード（幅の上限のみ設定） */
.preview-item--thumb {
    max-width: 200px;
}

.preview-label {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    color: #0369a1;
    padding: 5px 0 3px;
    background: #dbeafe;
    border-top: 1px solid #7dd3fa;
    letter-spacing: 0.03em;
}

.preview-filename {
    text-align: center;
    font-size: 10px;
    color: #4a7a96;
    padding: 2px 6px 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* ------------------------------------------------------------
   【create.html / update.html】プレビューカード内の削除ボタン
   ------------------------------------------------------------ */
.preview-delete-btn {
    display: block;
    width: 100%;
    padding: 5px 0;
    font-size: 12px;
    font-weight: 700;
    text-align: center;
    background: #fff0ee;
    color: #c0392b;
    border: none;
    border-top: 1px solid #f5b7b1;
    cursor: pointer;
    transition: background 0.15s;
    font-family: inherit;
}

.preview-delete-btn:hover {
    background: #fddcda;
}

/* ------------------------------------------------------------
   【update.html】既存画像・画像変更エリアの注意書きテキスト
   ------------------------------------------------------------ */
/* 「現在の画像・キャプション」直下の注意書き */
.img-edit-note {
    font-size: 13px;
    color: #555;
    margin: -8px 0 12px;
}

/* 「画像を変更する」直下の注意書き */
.img-change-note {
    font-size: 13px;
    color: #555;
    margin: 4px 0 10px;
}

/* ------------------------------------------------------------
   【create.html / update.html】デフォルトサムネイルのプレビュー枠
   ------------------------------------------------------------
   初期非表示。セレクトで画像が選ばれたときに
   JS（previewDefaultThumb）が style.display を書き換えて表示する。
   【update.html】保存済みのサムネイルがある場合は
   Jinja 側で .is-visible を付与して初期表示にする。
   ------------------------------------------------------------ */
#default-thumb-preview-area {
    display: none;
    margin-bottom: 20px;
}

#default-thumb-preview-area.is-visible {
    display: block;
}

/* プレビュー画像本体（旧: style="width:100%; border-radius:6px;" から移設） */
#default-thumb-preview-img {
    width: 100%;
    border-radius: 6px;
}

/* ------------------------------------------------------------
   【create.html / update.html】公開設定トグルボタン（🔒非公開／🔓全体公開）
   ------------------------------------------------------------ */
.toggle-status-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 700;
    border-radius: 20px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.2s ease;
    font-family: inherit;
    margin-bottom: 22px;
    outline: none;
}

.toggle-status-btn.private {
    background-color: #f0f9ff;
    color: #0369a1;
    border-color: #7dd3fa;
}

.toggle-status-btn.private:hover { background-color: #dbeafe; border-color: #38bdf8; }

.toggle-status-btn.published {
    background-color: #dbeafe;
    color: #0369a1;
    border-color: #38bdf8;
}

.toggle-status-btn.published:hover { background-color: #bae6fd; border-color: #0ea5e9; }

/* ------------------------------------------------------------
   【create.html / update.html】「投稿する」「更新」送信ボタン
   ------------------------------------------------------------ */
.post-form input[type="submit"] {
    display: block;
    width: 100%;
    padding: 14px;
    background-color: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.18s;
    font-family: inherit;
    letter-spacing: 0.02em;
}

.post-form input[type="submit"]:hover { background-color: #0369a1; }

/* ============================================================
   【create.html / update.html】Markdown編集ツールバー
   （H2/H3見出し・太字・目次・リスト・地図・YouTubeの各挿入ボタン）
   ============================================================ */
.md-toolbar-wrapper { position: relative; }

/* ツールバー本体：本文欄の上に張り付くスティッキーバー */
.md-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 12px;
    background: #e0f2fe;
    border: 1px solid #7dd3fa;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    margin-bottom: 0 !important;
    position: sticky;
    top: 85px;
    z-index: 50;
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.12);
    transition: box-shadow 0.2s ease;
}

/* スクロールでツールバーが本文上部に貼り付いた際の強調影 */
.md-toolbar.is-sticky { box-shadow: 0 6px 20px rgba(14, 165, 233, 0.18); border-color: #38bdf8; }

/* ツールバー内の各ボタン共通スタイル（H2見出し・太字・[toc]目次など） */
.md-btn {
    padding: 7px 13px;
    font-size: 13px;
    font-weight: 600;
    color: #0c1f35;
    background: #fff;
    border: 1px solid #7dd3fa;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    line-height: 1;
    min-width: 44px;
    min-height: 36px;
    text-align: center;
}

.md-btn:hover, .md-btn:active { background: #dbeafe; border-color: #38bdf8; color: #0c1f35; }

/* ツールバー内のボタン間の区切り線 */
.md-btn-separator {
    display: inline-block;
    width: 1px;
    height: 24px;
    background: #7dd3fa;
    margin: 0 4px;
    vertical-align: middle;
    flex-shrink: 0;
}

/* [imgN] 画像挿入ボタン（アップロード枚数に応じて動的に生成） */
.md-btn-img { color: #0369a1; background: #dbeafe; border-color: #38bdf8; }
.md-btn-img:hover, .md-btn-img:active { background: #bae6fd; border-color: #0ea5e9; color: #0c1f35; }

/* 🗺️ 地図挿入ボタン */
.md-btn-map { color: #166534; background: #dcfce7; border-color: #86efac; }
.md-btn-map:hover, .md-btn-map:active { background: #bbf7d0; border-color: #4ade80; color: #14532d; }

/* ▶ YouTube挿入ボタン */
.md-btn-youtube { color: #fff; background: rgba(220,38,38,0.75); border-color: rgba(185,28,28,0.6); font-weight: 700; }
.md-btn-youtube:hover, .md-btn-youtube:active { background: rgba(185,28,28,0.85); color: #fff; }

/* 箇条書きリスト挿入ボタン（SVGアイコン付き） */
.md-btn-list { display: inline-flex; align-items: center; gap: 5px; color: #0c1f35; }
.md-btn-list:hover, .md-btn-list:active { background: #dbeafe; border-color: #38bdf8; }

/* ツールバー直下に接続する本文テキストエリアの角丸調整 */
#bodyTextarea {
    border-radius: 0 0 8px 8px !important;
    border-top: none !important;
    scroll-margin-top: calc(85px + 48px + 8px);
}

/* ============================================================
   【create.html / update.html】🗺️ 地図挿入モーダル
   （md-btn-map クリックで開くポップアップ）
   ============================================================
   同じ .map-modal 系クラスは、下部の ▶ YouTube挿入モーダル
   （youtube-modal-overlay / youtube-modal）でも共用している。
   ============================================================ */
.map-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(12,31,53,0.45); z-index: 1100; }
.map-modal-overlay.open { display: block; }

.map-modal {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -48%);
    width: min(560px, calc(100vw - 32px));
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(14,165,233,0.18);
    z-index: 1200;
    overflow: hidden;
    flex-direction: column;
}

.map-modal.open { display: flex; }

.map-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e0f2fe;
    background: #f0f9ff;
}


.map-modal-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: #4a7a96;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    padding: 0;
}

.map-modal-close:hover { background: #dbeafe; color: #0c1f35; }
.map-modal-body { padding: 20px 20px 8px; }
.map-modal-label { display: block; font-size: 13px; font-weight: 700; color: #0369a1; margin-bottom: 8px; }

/* モーダル内の場所・URL入力欄（地図／YouTube共通デザイン） */
.map-modal-input {
    width: 100%;
    padding: 10px 14px;
    font-size: 15px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    box-sizing: border-box;
    outline: none;
    background: #f0f9ff;
    color: #0c1f35;
    font-family: inherit;
    transition: border-color 0.18s, background 0.18s;
    margin-bottom: 14px;
}

.map-modal-input:focus { border-color: #0ea5e9; background: #fff; box-shadow: 0 0 0 3px rgba(14,165,233,0.12); }

/* モーダル内プレビュー領域（地図iframe／YouTubeサムネイル共通の枠） */
.map-preview-area {
    width: 100%;
    height: 260px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    overflow: hidden;
    background: #f0f9ff;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* YouTube挿入モーダルのプレビュー枠（サムネイル映えする黒背景）
   （旧: style="background:#111;" から移設） */
.map-preview-area--dark {
    background: #111;
}

.map-preview-placeholder { color: #4a7a96; font-size: 14px; text-align: center; margin: 0; padding: 0 20px; }
.map-preview-iframe { width: 100%; height: 100%; border: none; display: block; }

/* モーダル下部のキャンセル／挿入ボタン行 */
.map-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 14px 20px 18px;
    border-top: 1px solid #e0f2fe;
}

.map-modal-cancel {
    padding: 9px 20px;
    font-size: 14px;
    font-weight: 600;
    background: #fff;
    color: #4a7a96;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
}

.map-modal-cancel:hover { background: #f0f9ff; }

.map-modal-insert {
    padding: 9px 22px;
    font-size: 14px;
    font-weight: 700;
    background: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.18s;
}

.map-modal-insert:hover:not(:disabled) { background: #0369a1; }
.map-modal-insert:disabled { background: #bae6fd; cursor: not-allowed; }

/* ------------------------------------------------------------
   【create.html / update.html】画像プレビューのキャプション入力欄
   ------------------------------------------------------------ */
.preview-caption-wrapper { padding: 8px 8px 2px; background: #dbeafe; border-top: 1px solid #7dd3fa; }

.preview-caption-input {
    width: 100%;
    padding: 5px 10px;
    font-size: 12px;
    border: 1px solid #38bdf8;
    border-radius: 6px;
    box-sizing: border-box;
    outline: none;
    background: #fff;
    color: #0c1f35;
    font-family: inherit;
    transition: border-color 0.18s;
}

.preview-caption-input:focus { border-color: #0ea5e9; }
.preview-caption-input::placeholder { color: #7dd3fa; font-size: 11px; }

/* ------------------------------------------------------------
   【create.html / update.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    h1 { font-size: 17px; margin: 20px 0 16px; }
    .post-form { padding: 24px 16px; border-radius: 0 10px 10px 0; border-left: none; border-right: none; margin-bottom: 0; width: 100% !important; box-sizing: border-box; }
    .post-form p { font-size: 13px; margin: 0 0 6px; line-height: 1.5; }
    .post-form label { font-size: 13px; }
    .post-form input[type="text"], .post-form select { font-size: 16px !important; padding: 12px !important; border-radius: 6px; margin-bottom: 16px; }
    .post-form textarea { font-size: 16px !important; line-height: 1.75 !important; padding: 14px !important; min-height: 320px !important; border-radius: 6px !important; margin-bottom: 16px !important; }
    .post-form input[type="submit"] { padding: 14px; font-size: 15px; border-radius: 8px; min-height: 48px; }
    /* プレビューリスト・アップロードボタン行の間隔調整
       （旧: .post-form div[style*="display: flex"] で「style 属性を持つ div」を
         対象にしていたが、インラインスタイル廃止に伴い
         移設後のID・クラスを直接指定する形に変更） */
    #preview-list, #existing-img-list, .img-upload-btn-row { gap: 12px !important; justify-content: flex-start; }
    .preview-item { width: calc(50% - 6px); box-sizing: border-box; margin-bottom: 12px; }
    .preview-item img { width: 100%; height: 110px; }
    .toggle-status-btn { padding: 12px 20px; font-size: 14px; margin-bottom: 16px; width: 100%; box-sizing: border-box; }
    .md-btn { padding: 10px 12px; font-size: 14px; min-width: 48px; min-height: 44px; }
    .md-btn-list { padding: 10px 12px; font-size: 14px; min-width: 48px; min-height: 44px; gap: 4px; }
    .md-toolbar { top: 63px; padding: 8px 10px; gap: 5px; overflow-x: hidden; }
    #bodyTextarea { scroll-margin-top: calc(63px + 56px + 8px); }
    .map-modal { top: auto; bottom: 0; left: 0; right: 0; transform: none; width: 100%; border-radius: 16px 16px 0 0; max-height: 90dvh; overflow-y: auto; }
    .map-preview-area { height: 200px; }
    .preview-caption-input { font-size: 14px; }
}
