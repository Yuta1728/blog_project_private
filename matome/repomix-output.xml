    <h3 class="section-title-genre">📂 あなたの作成・使用したジャンル</h3>
    <div class="user-genre-list">
        {% if user_genres %}
            <ul class="genre-tags">
                {% for genre_item in user_genres %}
                <li class="genre-tag-item">
                    <a href="{{ url_for('blog.index', genre=genre_item) }}" class="genre-tag-link">{{ genre_item }}</a>
