<file path="static/css/genre.css">
/* ============================================================
   static/css/genre.css - Coastal Dawn v2
   【対象ページ】 genre.html（ジャンル一覧ページ）
   ============================================================
   このファイルはジャンル一覧ページ専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【genre.html】ページ見出し「ジャンル一覧」
   ------------------------------------------------------------ */
h1 {
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    margin: 36px 0 20px;
    color: #0c1f35;
    letter-spacing: -0.01em;
}

/* ------------------------------------------------------------
   【genre.html】カード全体（ジャンル一覧を囲む枠）
   ------------------------------------------------------------ */
.genre-container {
    max-width: 480px;
    margin: 0 auto 60px;
    background: #fff;
    border: 1.5px solid #7dd3fa;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.genre-list, .sub-genre-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

/* ------------------------------------------------------------
   【genre.html】「📁 全て表示」リンク（一覧最上部）
   ------------------------------------------------------------ */
.genre-item-all a {
    display: block;
    padding: 16px 24px;
    font-size: 15px !important;
    font-weight: 700;
    color: #0369a1;
    text-decoration: none;
    border-bottom: 1px solid #e0f2fe;
    transition: background 0.15s;
}

.genre-item-all a:hover {
    background: #dbeafe;
    color: #0c1f35;
    text-decoration: none;
}

/* ============================================================
   【genre.html】アコーディオン形式のカテゴリグループ
   （ライフスタイル／社会経済／技術学習／スポーツ／娯楽／仕事）
   ============================================================ */

/* グループ全体の外枠（<details>要素） */
.genre-group {
    border-bottom: 1px solid #e0f2fe;
}

.genre-group:last-child {
    border-bottom: none;
}

/* グループの見出し行（<summary>要素、クリックで開閉） */
.group-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 24px;
    font-size: 15px;
    font-weight: 600;
    color: #0c1f35;
    cursor: pointer;
    user-select: none;
    outline: none;
    list-style: none;
    transition: background 0.15s;
    min-height: 52px;
    box-sizing: border-box;
}

.group-title:hover {
    background: #f0f9ff;
}

.group-title::-webkit-details-marker {
    display: none;
}

/* 開閉状態を示す矢印アイコン（▶ → 開いたら90度回転） */
.group-title .arrow {
    font-size: 10px;
    color: #38bdf8;
    display: inline-block;
    transition: transform 0.22s ease, color 0.22s;
    flex-shrink: 0;
}

details[open] .group-title .arrow {
    transform: rotate(90deg);
    color: #0ea5e9;
}

details[open] .group-title {
    color: #0c1f35;
    background: #f0f9ff;
    border-bottom: 1px solid #e0f2fe;
}

/* ------------------------------------------------------------
   【genre.html】展開時に表示されるサブジャンルのリンク一覧
   ------------------------------------------------------------ */
.sub-genre-list {
    background: #f8fdff;
    padding: 4px 0;
}

.sub-genre-list li a {
    font-weight: 500;
    display: flex;
    align-items: center;
    padding: 12px 24px 12px 36px;
    font-size: 14px !important;
    color: #0369a1;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    min-height: 44px;
    box-sizing: border-box;
}

.sub-genre-list li a::before {
    content: "–";
    margin-right: 8px;
    color: #38bdf8;
    flex-shrink: 0;
}

.sub-genre-list li a:hover {
    background: #dbeafe;
    color: #0c1f35;
    text-decoration: none;
}

/* ------------------------------------------------------------
   【genre.html】ジャンルが1件もないときの空メッセージ
   ------------------------------------------------------------ */
.genre-empty-message {
    padding: 24px;
    color: #aaa;
    text-align: center;
}

/* ------------------------------------------------------------
   【genre.html】カード下部の「一覧画面に戻る」フッターリンク
   ------------------------------------------------------------ */
.genre-footer {
    text-align: center;
    margin: 20px 0 48px;
}

.genre-footer a {
    font-size: 14px;
    color: #0369a1;
    text-decoration: none;
    padding: 10px 22px;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    display: inline-block;
    transition: all 0.18s;
    background: #ffffff;
}

.genre-footer a:hover {
    border-color: #0ea5e9;
    color: #0c1f35;
    background: #dbeafe;
}

/* ------------------------------------------------------------
   【genre.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    h1 { font-size: 18px; margin: 24px 0 16px; }
    .genre-container { margin: 0 16px 48px; border-radius: 10px; }
    .genre-item-all a { padding: 16px 18px; font-size: 14px !important; }
    .group-title { padding: 14px 18px; font-size: 14px; min-height: 50px; }
    .sub-genre-list li a {
    font-weight: 500; padding: 12px 18px 12px 30px; font-size: 14px !important; min-height: 48px; }
}
</file>

<file path="static/css/hashtag.css">
/* ============================================================
   static/css/hashtag.css - Coastal Dawn v2
   【対象ページ】 全ページ共通（base.htmlで読み込み）
   ハッシュタグ関連の表示・入力・絞り込みUIをまとめたファイル。
   ============================================================
   使用ページの内訳:
   - index.html / mypage.html   : 記事カードのハッシュタグバッジ、絞り込みバー
   - detail.html                : 記事詳細のハッシュタグバッジ
   - create.html / update.html  : ハッシュタグ入力欄・プレビュー
   ============================================================ */

/* ------------------------------------------------------------
   【共通】ハッシュタグバッジ本体（記事カード・記事詳細で表示するタグ）
   ------------------------------------------------------------ */
.hashtag-badge {
    display: inline-block;
    padding: 2px 9px;
    font-size: 12px;
    font-weight: 600;
    color: #0369a1;
    background-color: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 7px;
    text-decoration: none;
    transition: background-color 0.15s, border-color 0.15s;
    white-space: nowrap;
}

.hashtag-badge:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}

/* 【index.html / mypage.html】記事カード内のタグ一覧の並び方 */
.post-hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 4px 0 8px;
}

/* 【detail.html】記事詳細メタ情報内のタグ一覧の並び方 */
.detail-hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
}

/* ============================================================
   【index.html】ハッシュタグ絞り込みバー（ジャンル選択中のみ表示）
   ============================================================ */
.hashtag-filter-bar {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 10px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 4px solid #0ea5e9;
    border-radius: 0 10px 10px 0;
    padding: 14px 18px;
    margin-bottom: 35px;
    box-shadow: 0 2px 10px rgba(14, 165, 233, 0.08);
}

.hashtag-filter-label {
    font-size: 13px;
    font-weight: 700;
    color: #0369a1;
    white-space: nowrap;
    padding-top: 2px;
    flex-shrink: 0;
}

.hashtag-filter-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
}

/* 絞り込みバー内の各タグボタン */
.hashtag-filter-badge {
    display: inline-block;
    padding: 4px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #0369a1;
    background-color: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
}

.hashtag-filter-badge:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}

/* 現在選択中のタグ（塗りつぶし強調） */
.hashtag-filter-badge.active {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
    color: #fff;
}

.hashtag-filter-badge.active:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #fff;
}

/* 「✕ タグ解除」ボタン */
.hashtag-filter-clear {
    display: inline-block;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 700;
    color: #c0392b;
    background-color: #fff;
    border: 1px solid #f5b7b1;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
}

.hashtag-filter-clear:hover {
    background-color: #fff0ee;
    border-color: #e74c3c;
    color: #a93226;
    text-decoration: none;
}

/* ============================================================
   【create.html / update.html】ハッシュタグ入力エリア
   ============================================================ */
.hashtag-input-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    padding: 8px 14px;
    background: #f0f9ff;
    margin-bottom: 10px;
    transition: border-color 0.18s, background 0.18s;
    box-sizing: border-box;
    width: 100%;
}

.hashtag-input-wrapper:focus-within {
    border-color: #0ea5e9;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* 入力欄先頭に固定表示される「#」記号 */
.hashtag-prefix {
    font-size: 16px;
    font-weight: 700;
    color: #0ea5e9;
    margin-right: 6px;
    user-select: none;
    flex-shrink: 0;
}

.hashtag-text-input {
    flex: 1;
    border: none !important;
    outline: none !important;
    background: transparent !important;
    font-size: 15px;
    color: #0c1f35;
    padding: 0 !important;
    margin: 0 !important;
    box-shadow: none !important;
    min-width: 0;
    font-family: inherit;
}

/* 入力内容からリアルタイム生成されるタグプレビューの並び */
.hashtag-preview-area {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-height: 28px;
    margin-bottom: 22px;
}

/* プレビュー用タグバッジ（ポップアニメーション付き） */
.hashtag-badge-preview {
    display: inline-block;
    padding: 3px 12px;
    font-size: 12px;
    font-weight: 600;
    color: #0369a1;
    background-color: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 20px;
    animation: badgePop 0.15s ease;
}

@keyframes badgePop {
    from { transform: scale(0.85); opacity: 0.6; }
    to   { transform: scale(1);    opacity: 1; }
}

/* ------------------------------------------------------------
   【共通】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .hashtag-filter-bar {
        flex-direction: column;
        gap: 8px;
        padding: 12px 14px;
        margin-bottom: 18px;
    }
    .hashtag-filter-list { gap: 6px; }
    .hashtag-filter-badge, .hashtag-filter-clear { font-size: 12px; padding: 5px 12px; }
    .post-hashtags, .detail-hashtags { gap: 5px; }
    .hashtag-badge { font-size: 11px; padding: 2px 8px; }
    .hashtag-input-wrapper { padding: 10px 12px; }
    .hashtag-text-input { font-size: 16px !important; }
}
</file>

<file path="static/css/index.css">
/* ============================================================
   static/css/index.css - Coastal Dawn v2（白ヘッダー・視認性改善版）
   【対象ページ】 index.html（トップページ・記事一覧）
   ============================================================
   このファイルはトップページの記事一覧・記事カード・
   ページ番号ページ送りのスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */


/* ------------------------------------------------------------
   【index.html】メインレイアウト（記事一覧全体を囲む余白）
   ------------------------------------------------------------ */
.page-wrapper {
    max-width: 940px;
    margin: 0 auto;
    padding: 32px 28px 60px;
    margin-top: 15px;
}

/* ------------------------------------------------------------
   【index.html】ページ送り後に記事一覧の先頭へ戻すための目印（非表示要素）
   ------------------------------------------------------------
   ページ番号リンクの #index-articles-anchor フラグメントで
   ここへスクロールする。固定ヘッダー（position: fixed）の下に
   隠れないよう scroll-margin-top をヘッダーの高さ分だけ確保しておく。
   ------------------------------------------------------------ */
#index-articles-anchor {
    scroll-margin-top: 100px;
}

@media (max-width: 767px) {
    #index-articles-anchor {
        scroll-margin-top: 80px;
    }
}


/* ------------------------------------------------------------
   【index.html / mypage.html 共通】記事カードの「編集」リンクボタン
   ------------------------------------------------------------ */
.btn-edit {
    display: inline-block;
    padding: 3px 14px;
    font-size: 14px;
    font-weight: 500;
    color: #0369a1;
    border: 1.2px solid #7dd3fa;
    border-radius: 4px;
    margin-right: 7px;
    background: transparent;
    text-decoration: none;
}

a[role="button"]:hover {
    color: #0c1f35;
    border-color: #0ea5e9;
    background: #e0f2fe;
    text-decoration: none;
}


/* ------------------------------------------------------------
   【index.html】検索・絞り込み結果ラベル（「🔍「◯◯」の検索結果」）
   ------------------------------------------------------------ */
.filter-label {
    font-size: 19px;
    color: #0c1f35;
    font-weight: 600;
    margin-bottom: 10px;
    display: inline-block;
}


/* ------------------------------------------------------------
   【index.html】「📋 最新の記事」セクション見出し
   ------------------------------------------------------------ */
.posts-section-title {
    font-size: 1.3rem !important;
    font-weight: 700;
    color: #0c1f35;
    line-height: 1.4;
    letter-spacing: 0.01em;
}


/* ------------------------------------------------------------
   【index.html】自己紹介（hero）セクションの見出し
   （実際の詳細レイアウトは top_sections.css で定義）
   ------------------------------------------------------------ */
.hero-section-title {
    font-size: 1.3rem !important;
    font-weight: 700;
    color: #0c1f35;
    line-height: 1.4;
    letter-spacing: 0.01em;
}


/* ------------------------------------------------------------
   【index.html / mypage.html 共通】記事カードのジャンル・非公開バッジ
   ------------------------------------------------------------ */
.badge-genre {
    font-size: 12px;
    font-weight: 600;
    color: #0369a1;
    background: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 7px;
    padding: 2px 10px;
    white-space: nowrap;
}

.badge-private {
    font-size: 12px;
    font-weight: 700;
    color: #c0392b;
    background: #fff0ee;
    border: 1.2px solid #f5b7b1;
    border-radius: 12px;
    padding: 2px 10px;
    white-space: nowrap;
}


/* ============================================================
   【index.html / mypage.html 共通】記事カード本体
   ============================================================ */
.post-card {
    display: flex;
    gap: 36px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 16px 24px;
    margin-bottom: 20px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
    transition: transform 0.22s ease, box-shadow 0.22s ease,
                border-left-color 0.22s ease, border-color 0.22s ease,
                background-color 0.22s ease;
    position: relative;
    cursor: pointer;
}

.post-card:hover {
    transform: translateY(-3px);
    background: #fffbeb;
    border: 1.5px solid #fbbf24;
    border-left: 5px solid #f59e0b;
    box-shadow: 0 8px 28px rgba(245, 158, 11, 0.20),
                0 2px 8px rgba(14, 165, 233, 0.08);
}

/* カード左側のサムネイル画像枠 */
.post-thumbnail {
    flex: 0 0 260px;
    height: 158px;
    border-radius: 8px;
    overflow: hidden;
    background-color: #e0f2fe;
    border: 1.5px solid #7dd3fa;
    transition: border-color 0.22s ease;
}

.post-card:hover .post-thumbnail {
    border-color: #fbbf24;
    background-color: #fef3c7;
}

.thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
}

/* カード右側のコンテンツ（ジャンル・タイトル・日付・操作ボタン）レイアウト */
.post-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.post-header-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
    font-size: 0.95rem;
    flex-wrap: wrap;
}

/* ------------------------------------------------------------
   【index.html / mypage.html 共通】記事タイトルリンク
   ------------------------------------------------------------ */
.post-title {
    margin: 8px 0 8px 0;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.5;
    text-align: left !important;
}

.post-title a {
    color: #0c1f35;
    text-decoration: none;
    display: inline-block;
    transition: color 0.22s ease;
}

/* カード全域をタップ可能にする透明レイヤー */
.post-title a::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
}

.post-card:hover .post-title a {
    color: #0369a1;
    font-weight: 700;
}

/* ------------------------------------------------------------
   【index.html / mypage.html 共通】「編集」「削除」ボタン行(投稿者本人のみ表示)
   ------------------------------------------------------------ */
.post-actions {
    position: relative;
    z-index: 2;
    margin-top: 8px;
}

/* 【index.html / mypage.html 共通】編集・削除ボタンを横並びにするため
   削除フォームをインライン表示にする（.post-actions 内のフォーム）*/
.post-actions form {
    display: inline;
}

.btn-delete {
    background: transparent;
    border: 1.2px solid #f5b7b1;
    color: #c0392b;
    padding: 3px 14px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.18s;
}

.btn-delete:hover {
    background-color: #fff0ee;
    border-color: #e74c3c;
    color: #a93226;
}

/* ------------------------------------------------------------
   【index.html / mypage.html 共通】投稿日・更新日の表示
   ------------------------------------------------------------ */
.post-date {
    margin: 1px 0 0 0;
    font-size: 0.80rem;
    color: #0369a1;
    font-weight: 500;
    transition: color 0.22s ease;
}

.post-card:hover .post-date {
    color: #b45309;
}


/* ------------------------------------------------------------
   【index.html】検索・絞り込みで該当記事がないときの空メッセージ
   ------------------------------------------------------------ */
.index-empty-message {
    text-align: center;
    color: #aaa;
    margin-top: 60px;
}


/* ============================================================
   【index.html】ページ番号によるページ送り（サーバー側・1ページ4件表示）
   ============================================================
   【変更点】
   以前はクライアント JS がカードを分割表示し、totalPages > 1 の
   ときだけこのナビを JS で flex 表示していた。サーバー側
   ページネーションに一本化したため、Jinja 側でページ数が
   2 以上のときだけ <nav> 自体を出力する方式に変更。
   このため、初期状態を display: none にする必要がなくなり、
   常に flex 表示にしている。
   ============================================================ */

/* ページ送りナビ全体 */
.index-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 8px 0 40px;
    flex-wrap: wrap;
}

/* ページ番号・前へ／次へ の共通ボタンデザイン
   （リンク <a> と現在ページ・無効状態の <span> で共用する） */
.page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    color: #0369a1;
    background-color: #ffffff;
    border: 1px solid #7dd3fa;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.08);
    transition: background-color 0.2s ease, border-color 0.2s ease,
                color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
}

.page-btn:hover {
    background-color: #dbeafe;
    border-color: #38bdf8;
    color: #0c1f35;
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.16);
    transform: translateY(-1px);
    text-decoration: none;
}

.page-btn:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #bae6fd;
}

/* 現在表示中のページ番号（塗りつぶし強調、<span> で出力） */
.page-btn.active {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
    cursor: default;
}

/* 現在ページはリンクではないのでホバーで浮かせない */
.page-btn.active:hover {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
    color: #ffffff;
    transform: none;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
}

/* 「‹」「›」前へ／次へ ボタン */
.page-btn-arrow {
    font-size: 16px;
    font-weight: 700;
}

/* 先頭・末尾ページで無効化された前へ／次へ（<span> で出力）
   ------------------------------------------------------------
   <a> と違い <span> は :disabled を持てないため、専用クラスで
   見た目を無効化する。pointer-events: none によりホバー効果も
   無効になる。 */
.page-btn-disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
    transform: none;
    pointer-events: none;
}

/* ページ番号の省略記号（…） */
.page-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 40px;
    color: #7dd3fa;
    font-size: 14px;
    font-weight: 700;
    user-select: none;
}


/* ==========================================================================
   【index.html / mypage.html 共通】レスポンシブ（スマホ）
   ========================================================================== */

@media (max-width: 600px) {
    .page-wrapper {
        padding: 16px 14px 48px;
    }

    .post-card {
        flex-direction: column;
        gap: 12px;
        padding: 15px;
        margin-top: 5px;
        border-radius: 0 10px 10px 0;
    }

    .post-thumbnail {
        flex: none;
        width: 100%;
        height: 240px;
    }

    .post-content {
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    .post-header-meta {
        font-size: 0.85rem;
        margin-bottom: 4px;
    }

    .post-title {
        font-size: 1.1rem;
        line-height: 1.45;
        margin-bottom: 10px;
    }

    .post-date {
        order: 0;
        font-size: 0.75rem;
        margin-top: 3px;
        margin-bottom: 3px;
    }

    .post-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
        margin-bottom: 3px;
        width: 100%;
    }

    .btn-edit,
    .btn-delete {
        padding: 4px 17px;
        font-size: 13px;
        min-height: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .post-actions {
        order: 1;
    }

    .post-title a::after {
        inset: 0;
        z-index: 1;
    }

    .index-pagination {
        gap: 6px;
        margin: 8px 0 32px;
    }

    .page-btn {
        min-width: 36px;
        height: 36px;
        padding: 0 10px;
        font-size: 13px;
    }

    .page-ellipsis {
        height: 36px;
        min-width: 20px;
    }
}
</file>

<file path="static/css/load_more.css">
/* ============================================================
   static/css/load_more.css - Coastal Dawn v2
   【対象ページ】 mypage.html（マイページの投稿一覧）
   ============================================================
   以前は index.html でも使用していたが、index.html は
   ページ番号方式のページ送り（index.css の .index-pagination）に
   置き換えたため、現在この CSS を読み込んでいるのは
   mypage.html のみ。学習用サンプルとしてこのファイル自体は
   そのまま残してある。
   ============================================================ */

/* ------------------------------------------------------------
   【mypage.html】「もっと見る／表示を減らす」ボタンのラッパー
   ------------------------------------------------------------ */
.load-more-wrap {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 8px 0 40px;
    flex-wrap: wrap;
}

/* ------------------------------------------------------------
   【mypage.html】「もっと見る」「▲ 表示を減らす」ボタン共通デザイン
   ------------------------------------------------------------ */
.load-more-btn,
.load-less-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 40px;
    border-radius: 24px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    transition: background-color 0.2s ease, border-color 0.2s ease,
                color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
}

/* 「もっと見る」ボタン（白背景） */
.load-more-btn {
    background-color: #ffffff;
    color: #0369a1;
    border: 1px solid #7dd3fa;
    box-shadow: 0 2px 10px rgba(14, 165, 233, 0.10);
}

.load-more-btn:hover {
    background-color: #dbeafe;
    border-color: #38bdf8;
    color: #0c1f35;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.18);
    transform: translateY(-1px);
}

.load-more-btn:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #bae6fd;
}

/* 「▲ 表示を減らす」ボタン（控えめなグレー系） */
.load-less-btn {
    background-color: #ffffff;
    color: #4a7a96;
    border: 1px solid #bae6fd;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.06);
