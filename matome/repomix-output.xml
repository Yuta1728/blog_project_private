/* ============================================================
   static/css/auth.css - Coastal Dawn v2
   【対象ページ】 login.html（管理者ログインページ）
   ============================================================
   このファイルはログインページ専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */


/* ------------------------------------------------------------
   【login.html】カード全体（フォームを囲む枠）
   ------------------------------------------------------------ */
.auth-container {
    max-width: 400px;
    margin: 72px auto 60px;
    padding: 40px 40px 36px;
    background-color: #ffffff;
    border-radius: 0 12px 12px 0;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
    box-sizing: border-box;
    font-family: inherit;
}

/* ------------------------------------------------------------
   【login.html】見出し「管理者画面」
   ------------------------------------------------------------ */
h2 {
    text-align: center;
    color: #0c1f35;
    margin: 0 0 20px;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
}

/* ------------------------------------------------------------
   【login.html】フォームグループ（ユーザー名／パスワード欄の間隔）
   ------------------------------------------------------------ */
.form-group {
    margin-bottom: 20px;
}

/* ------------------------------------------------------------
   【login.html】各入力欄のラベル（「ユーザー名」「パスワード」）
   ------------------------------------------------------------ */
label {
    display: block;
    margin-bottom: 8px;
    font-weight: 700;
    font-size: 13px;
    color: #0369a1;
    letter-spacing: 0.03em;
}

/* ------------------------------------------------------------
   【login.html】ユーザー名・パスワードの入力欄
   ------------------------------------------------------------ */
input[type="text"],
input[type="password"] {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 16px;
    outline: none;
    background: #f0f9ff;
    color: #0c1f35;
    transition: border-color 0.18s, background 0.18s;
    font-family: inherit;
}

input[type="text"]:focus,
input[type="password"]:focus {
    border-color: #0ea5e9;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* ------------------------------------------------------------
   【login.html】「ログイン」送信ボタン
   ------------------------------------------------------------ */
.submit-btn {
    width: 100%;
    padding: 12px;
    background-color: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    margin-top: 15px;
    transition: background-color 0.18s;
    font-family: inherit;
}

.submit-btn:hover {
    background-color: #0369a1;
}

/* ------------------------------------------------------------
   【login.html】カード下部の補足リンク（現状未使用の予備クラス）
   ------------------------------------------------------------ */
.footer-link {
    text-align: center;
    margin-top: 18px;
    font-size: 13px;
    color: #0369a1;
}

/* ------------------------------------------------------------
   【login.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .auth-container {
        margin: 24px 16px;
        padding: 28px 22px;
        border-radius: 0 10px 10px 0;
    }
    h2 { font-size: 18px; margin-bottom: 20px; }
    .form-group { margin-bottom: 16px; }
    .submit-btn { padding: 14px; font-size: 15px; }
}
