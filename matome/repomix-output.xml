        display: flex;
        justify-content: center;
    }

    .header-search-box form {
        width: 100%;
        max-width: 160px;
        padding: 2px 8px;
        border-radius: 15px;
        background-color: #eef6fb;
    }

    .header-search-box input[type="text"] {
        font-size: 12px;
        padding: 3px 2px;
    }

    .search-submit-btn svg {
        width: 14px;
        height: 14px;
    }

    .search-clear-btn {
        margin-left: 4px;
        font-size: 11px;
    }
}

@media (max-width: 480px) {
    .header-search-box form {
        max-width: 145px;
    }

    .header-search-box input[type="text"]::placeholder {
        font-size: 12px;
    }
}
