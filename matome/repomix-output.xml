<file path="templates/update.html">
{% extends "base.html" %}
{% block content %}

<link rel="stylesheet" href="{{ url_for('static', filename='css/create_update.css') }}">

<h1>編集</h1>

<div>
    <form action="{{ url_for('admin.update', id=post.id) }}" method="post" enctype="multipart/form-data" class="post-form">
        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">

        <label for="title">タイトル</label>
        <input type="text" name="title" value="{{post.title}}">

        <p>
            <label for="genre_select">ジャンル</label>
            <select name="genre_select" id="genre_select" onchange="toggleNewGenreInput()">
                <option value="未分類" {% if post.genre == '未分類' or not post.genre %}selected{% endif %}>-- ジャンルを選択（選択なしは未分類） --</option>
                {% for genre in genres %}
                    <option value="{{ genre }}" {% if post.genre == genre %}selected{% endif %}>{{ genre }}</option>
                {% endfor %}
                <option value="__NEW__">+ 新しいジャンルを作成する</option>
            </select>
        </p>

        {# 初期非表示（create_update.css の #new_genre_wrapper）。JSが表示を切り替える #}
        <p id="new_genre_wrapper">
            <label for="genre_new">新しいジャンル名</label>
            <input type="text" name="genre_new" id="genre_new" placeholder="新しいジャンル名を入力">
        </p>

        <p>
            <label>公開設定</label>
            <input type="hidden" name="is_published" id="is_published" value="{{ 'true' if post.is_published else 'false' }}">
            <button type="button" id="toggle_status_btn"
                    class="toggle-status-btn {{ 'published' if post.is_published else 'private' }}"
                    onclick="handleStatusToggle()">
                <span class="status-icon">{{ '🔓' if post.is_published else '🔒' }}</span>
                <span class="status-text">{{ '全体公開' if post.is_published else '非公開' }}</span>
            </button>
        </p>

        <label for="bodyTextarea">内容</label>

        <div class="md-toolbar-wrapper">

        <!-- ===== マークダウンツールバー ===== -->
        <div class="md-toolbar" id="md-toolbar">
            <button type="button" class="md-btn" onclick="mdInsertHeading2()">H2 見出し</button>
            <button type="button" class="md-btn" onclick="mdInsertHeading3()">H3 見出し</button>
            <button type="button" class="md-btn" onclick="mdWrapBold()"><b>太字</b></button>
            <button type="button" class="md-btn" onclick="mdInsertToc()">[toc] 目次</button>
            <button type="button" class="md-btn md-btn-list" onclick="mdInsertList('bullet')" title="箇条書きリストを挿入">
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="1.5" cy="3.5"  r="1.5" fill="currentColor"/>
                    <rect   x="5"   y="2.5" width="10" height="2" rx="1" fill="currentColor"/>
                    <circle cx="1.5" cy="7.5"  r="1.5" fill="currentColor"/>
                    <rect   x="5"   y="6.5" width="10" height="2" rx="1" fill="currentColor"/>
                    <circle cx="1.5" cy="11.5" r="1.5" fill="currentColor"/>
                    <rect   x="5"   y="10.5" width="10" height="2" rx="1" fill="currentColor"/>
                </svg>
                リスト
            </button>
            <span class="md-btn-separator"></span>
            <button type="button" class="md-btn md-btn-map" onclick="openMapModal()">🗺️ 地図</button>
            <button type="button" class="md-btn md-btn-youtube" onclick="openYoutubeModal()">▶ YouTube</button>
            <span class="md-btn-separator"></span>
            <span id="img-btn-group">
                {% if post.img_name %}
                    {% for img in post.img_name.split(',') %}
                        <button type="button" class="md-btn md-btn-img"
                                data-img-index="{{ loop.index }}">[img{{ loop.index }}]</button>
                    {% endfor %}
                {% endif %}
            </span>
        </div>

        {# 地図・YouTube 挿入モーダル（create/update 共通部分テンプレート） #}
        {% include '_map_modal.html' %}
        {% include '_youtube_modal.html' %}

        <textarea name="body" id="bodyTextarea" rows="17">{{post.body}}</textarea>

        </div>

        <!-- ===== ハッシュタグ入力 ===== -->
        <p>
            <label for="hashtag_input">ハッシュタグ</label>
            ※スペース・カンマ区切りで複数入力できます。「#」は省略しても OK<br>
            　例：<code>#Flask Python ブログ開発</code>
        </p>
        <div class="hashtag-input-wrapper">
            <span class="hashtag-prefix">#</span>
            <input type="text"
                   name="hashtag_input"
                   id="hashtag_input"
                   class="hashtag-text-input"
                   value="{{ existing_hashtag_str }}"
                   placeholder="Flask Python ブログ開発 …"
                   autocomplete="off"
                   oninput="renderHashtagPreview(this.value)">
        </div>
        <div id="hashtag-preview" class="hashtag-preview-area">
            {% for tag in post.hashtags %}
                <span class="hashtag-badge-preview">#{{ tag.name }}</span>
            {% endfor %}
        </div>


        <!-- ===== 現在の画像（既存）キャプション編集・削除エリア ===== -->
        {% if post.img_name %}
            <label>現在の画像・キャプション</label>
            <p class="img-edit-note">
                ※画像の説明（キャプション）を編集できます。空欄のままにすると非表示になります。<br>
                ※<strong>「更新」ボタンを押すまで確定しません</strong>。<br>
                ※画像を削除すると残りの画像の番号（[imgN]）が繰り上がります。
            </p>
            <div id="existing-img-list">
                {% for img in post.img_name.split(',') %}
                    <div class="preview-item existing-img-item">
                        {# 削除フラグ: '1'=残す（デフォルト） / '0'=削除予定。
                        サーバー側（update() のパターンB）はこの値で残す画像を判定する #}
                        <input type="hidden" name="keep_img_{{ loop.index }}" value="1" class="keep-img-flag">

                        <img src="{{ url_for('static', filename='img/posts/' + img) }}" alt="{{ img }}">
                        <div class="preview-label">[img{{ loop.index }}]（現在）</div>
                        <div class="preview-filename" title="{{ img }}">{{ img }}</div>
                        <div class="preview-caption-wrapper">
                            <input type="text"
                                name="img_caption_{{ loop.index }}"
                                class="preview-caption-input"
                                placeholder="画像の説明（省略可）"
                                maxlength="100"
                                value="{{ existing_captions[loop.index0] if loop.index0 < existing_captions|length else '' }}">
                        </div>
                        <button type="button"
                                class="preview-delete-btn existing-delete-btn"
                                onclick="toggleExistingDelete(this)">✕ この画像を削除</button>
                    </div>
                {% endfor %}
            </div>
        {% endif %}


        <!-- ===== 新しい画像の追加エリア ===== -->
        <div>
            <label>画像を変更する（本文中に載せる画像）</label>
            <p class="img-change-note">
                ※新しい画像を選択した場合、現在の画像はすべて置き換えられます。<br>
                　「複数まとめて選択」で一括追加、「1枚追加」で1枚ずつ追加できます。
            </p>

            <!-- 既存：複数一括選択 input（img-input-hidden で非表示にして JS から参照） -->
            <input type="file" name="img[]" id="imgUpload" multiple accept="image/*"
                   onchange="onBulkSelect(this)" class="img-input-hidden">

            <!-- 追加：1枚ずつ選択用 input（img-input-hidden で非表示） -->
            <input type="file" name="" id="imgUploadOne" accept="image/*"
                   onchange="onOneSelect(this)" class="img-input-hidden">

            <!-- ボタン群 -->
            <div class="img-upload-btn-row">
                <button type="button" class="img-upload-btn img-upload-btn--bulk"
                        onclick="document.getElementById('imgUpload').click()">
                    📂 複数まとめて選択
                </button>
                <button type="button" class="img-upload-btn img-upload-btn--one"
                        onclick="document.getElementById('imgUploadOne').click()">
                    ＋ 1枚追加
                </button>
            </div>

            <!-- 新規選択画像プレビュー
                 初期非表示（create_update.css の #preview-area）。JSが表示を切り替える -->
            <div id="preview-area" class="preview-area--spaced">
                <p class="preview-area-title">
                    📸 新しい画像のプレビュー（更新後はこちらに差し替えられます）
                </p>
                <div id="preview-list"></div>
            </div>

            {# ============================================================
               サムネイル専用画像のアップロード・変更・削除
               ・現在のサムネイルがある場合は表示し、個別削除できる
               ・新しいサムネイルを選ぶと、更新後に差し替えられる
               ・どちらもなければ下のデフォルトサムネイルが使われる
               ============================================================ #}
            <p>
                <label>サムネイル画像（任意）</label>
                ※記事一覧などで表示されるサムネイルを個別にアップロードできます。<br>
                　新しく選択すると現在のサムネイルは置き換えられます。<br>
                　サムネイルがない場合は、下で選択したデフォルトサムネイルが使用されます。
            </p>

            {# 現在のサムネイル（既存）— 存在するときのみ表示 #}
            {% if post.thumbnail_img %}
                {# keep_thumbnail: '1'=残す（デフォルト） / '0'=削除予定。
                   サーバー側 update() の STEP 5.5 がこの値を見て削除判定する #}
                <input type="hidden" name="keep_thumbnail" id="keep_thumbnail" value="1">
                <div id="current-thumbnail-area">
                    <div class="preview-item preview-item--thumb" id="current-thumbnail-item">
                        <img src="{{ url_for('static', filename='img/posts/' + post.thumbnail_img) }}"
                             alt="現在のサムネイル">
                        <div class="preview-label">現在のサムネイル</div>
                        <button type="button"
                                class="preview-delete-btn"
                                id="thumbnail-delete-btn"
                                onclick="toggleThumbnailDelete()">✕ このサムネイルを削除</button>
                    </div>
                </div>
            {% endif %}

            <!-- サムネイル選択用の隠し input（ボタンから .click() で起動） -->
            <input type="file" name="thumbnail_img" id="thumbnailUpload" accept="image/*"
                   onchange="onThumbnailSelect(this)" class="img-input-hidden">

            <div class="img-upload-btn-row">
                <button type="button" class="img-upload-btn img-upload-btn--one"
                        onclick="document.getElementById('thumbnailUpload').click()">
                    🖼️ サムネイル画像を選択
                </button>
            </div>

            <!-- 新規サムネイルのプレビュー（初期非表示。JS が style.display を切り替える） -->
            <div id="thumbnail-preview-area" style="display: none; margin-bottom: 20px;">
                <div class="preview-item preview-item--thumb">
                    <img id="thumbnail-preview-img" src="" alt="サムネイルプレビュー">
                    <div class="preview-label">新しいサムネイル（更新後に差し替え）</div>
                    <button type="button" class="preview-delete-btn" onclick="clearThumbnail()">✕ 選択を解除</button>
                </div>
            </div>

            <p>
                <label for="default_thumb_select">デフォルトサムネイル画像を選択（サムネイル画像がない場合）</label>
                <select name="default_thumb_select" id="default_thumb_select" onchange="previewDefaultThumb(this)">
                    <option value="none" {% if not post.default_thumb %}selected{% endif %}>-- 選択なし（システム共通のデフォルトになります） --</option>
                    <option value="thumb_option1.jpg"  {% if post.default_thumb == 'thumb_option1.jpg'  %}selected{% endif %}>選択肢1：趣味</option>
                    <option value="thumb_option2.jpg"  {% if post.default_thumb == 'thumb_option2.jpg'  %}selected{% endif %}>選択肢2：旅行</option>
                    <option value="thumb_option3.jpg"  {% if post.default_thumb == 'thumb_option3.jpg'  %}selected{% endif %}>選択肢3：スポーツ</option>
                    <option value="thumb_option4.jpg"  {% if post.default_thumb == 'thumb_option4.jpg'  %}selected{% endif %}>選択肢4：アニメ</option>
                    <option value="thumb_option5.jpg"  {% if post.default_thumb == 'thumb_option5.jpg'  %}selected{% endif %}>選択肢5：本</option>
                    <option value="thumb_option6.jpg"  {% if post.default_thumb == 'thumb_option6.jpg'  %}selected{% endif %}>選択肢6：ゲーム</option>
                    <option value="thumb_option7.jpg"  {% if post.default_thumb == 'thumb_option7.jpg'  %}selected{% endif %}>選択肢7：音楽</option>
                    <option value="thumb_option8.jpg"  {% if post.default_thumb == 'thumb_option8.jpg'  %}selected{% endif %}>選択肢8：映画</option>
                    <option value="thumb_option9.jpg"  {% if post.default_thumb == 'thumb_option9.jpg'  %}selected{% endif %}>選択肢9：ドラマ</option>
                    <option value="thumb_option10.jpg" {% if post.default_thumb == 'thumb_option10.jpg' %}selected{% endif %}>選択肢10：開発</option>
                    <option value="thumb_option11.jpg" {% if post.default_thumb == 'thumb_option11.jpg' %}selected{% endif %}>選択肢11：勉強</option>
                </select>
            </p>

            {# 保存済みのデフォルトサムネイルがある場合のみ .is-visible を付与して初期表示。
               未設定時は create_update.css の #default-thumb-preview-area により初期非表示 #}
            <div id="default-thumb-preview-area" {% if post.default_thumb %}class="is-visible"{% endif %}>
                <div class="preview-item preview-item--thumb">
                    <img id="default-thumb-preview-img"
                         src="{{ url_for('static', filename='img/thbnails/' + post.default_thumb) if post.default_thumb else '' }}"
                         alt="デフォルトサムネイルプレビュー">
                    <div class="preview-label">選択中のサムネイル</div>
                </div>
            </div>

            <input type="submit" value="更新">
        </div>

    </form>
</div>

{# ============================================================
   共通エディタスクリプト（create/update 共有）
   編集時の新規画像キャプションは、既存画像のキャプション欄
   （img_caption_N）と衝突しないよう input name 接頭辞を
   'new_img_caption_' にする（サーバー側 update() も対応済み）。
   ============================================================ #}
<script>
    window.EDITOR_CONFIG = { newImageCaptionPrefix: 'new_img_caption_' };
</script>
<script src="{{ url_for('static', filename='js/editor.js') }}"></script>

{% endblock %}
</file>

<file path="views/admin.py">
# ======================================================================
# views/admin.py — 管理者専用ページ（ログイン必須）
# ======================================================================
#
# 【役割】
#   管理者専用ページのルートとロジックを担うビューファイル。
#
#   担当機能:
#     /create          → 新規記事投稿
