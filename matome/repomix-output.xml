        flex-direction: column;
        align-items: stretch;
        gap: 8px;
    }

    .nickname-input {
        font-size: 16px;
        width: 100% !important;
        box-sizing: border-box;
    }

    .nickname-submit-btn {
        text-align: center;
        margin-top: 4px;
        padding: 10px;
        font-size: 14px;
