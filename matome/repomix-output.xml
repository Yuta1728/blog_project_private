}

.info-page-title {
    font-size: 22px;
    font-weight: 800;
    color: #0d3a52;
    margin: 0;
    text-align: left;
    letter-spacing: -0.01em;
}

.info-page-body {
    background: #ffffff;
    border: 1px solid #c5dff0;
    border-radius: 12px;
    padding: 32px 36px;
    box-shadow: 0 4px 16px rgba(26, 122, 173, 0.07);
    margin-bottom: 28px;
}

.info-section {
    margin-bottom: 32px;
}

.info-section:last-child {
    margin-bottom: 0;
}

.info-section-title {
    font-size: 17px;
    font-weight: 700;
    color: #0d3a52;
    border-left: 4px solid #1a7aad;
    padding-left: 12px;
    margin: 0 0 12px;
    text-align: left;
}

.info-section p {
    font-size: 15px;
