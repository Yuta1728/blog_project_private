<file path="templates/index.html">
{% extends "base.html" %}
{% block content %}

<link rel="stylesheet" href="{{ url_for('static', filename='css/index.css') }}">
<link rel="stylesheet" href="{{ url_for('static', filename='css/top_sections.css') }}">


<div class="page-wrapper">

    {# ===== フィルターなし（トップ表示）のときだけ stats を表示 ===== #}
    {% if not selected_genre and not search_word and not selected_hashtag %}
        {% include 'stats.html' %}
    {% endif %}
    {# ======================================================================= #}

    {# ===== インページ検索エリア（常に表示） ===== #}
    {% include 'search_area.html' %}
    {# ============================================ #}

    {% if selected_genre or search_word or selected_hashtag %}
        <p class="filter-label">
            🔍 
            {% if search_word %}「{{ search_word }}」{% endif %}
            {% if selected_genre %}ジャンル「{{ selected_genre }}」{% endif %}
            {% if selected_hashtag %}ハッシュタグ「#{{ selected_hashtag }}」{% endif %}
            の検索結果
        </p>
    {% endif %}

    {# ===== ハッシュタグ絞り込みバー（ジャンル選択中のみ表示） ===== #}
    {% if selected_genre and hashtags_in_genre %}
        <div class="hashtag-filter-bar">
            <span class="hashtag-filter-label">🏷️ タグで絞り込む：</span>
            <div class="hashtag-filter-list">
                {% for tag in hashtags_in_genre %}
                    <a href="{{ url_for('blog.index', genre=selected_genre, hashtag=tag.name) }}"
                       class="hashtag-filter-badge {% if selected_hashtag == tag.name %}active{% endif %}">
                        #{{ tag.name }}
                    </a>
                {% endfor %}
                {% if selected_hashtag %}
                    <a href="{{ url_for('blog.index', genre=selected_genre) }}"
                       class="hashtag-filter-clear">✕ タグ解除</a>
                {% endif %}
            </div>
        </div>
    {% endif %}
    {# ========================================================= #}

    {# ===== ページ送り時にここへスクロールを戻すための目印 ===== #}
    <div id="index-articles-anchor"></div>
    {# ========================================================= #}

    {# ===== 記事一覧の見出し ===== #}
    {% if not selected_genre and not search_word and not selected_hashtag %}
        <h3 class="posts-section-title">📋 最新の記事</h3>
    {% endif %}
    {# =========================== #}

    {% for post in posts %}
        <article class="post-card">
            <div class="post-thumbnail">
                {% if post.img_name %}
                    {% set first_img = post.img_name.split(',')[0] %}
                    <img src="{{ url_for('static', filename='img/posts/' + first_img) }}" alt="{{ post.title }}" class="thumb-img">
                {% elif post.default_thumb %}
                    <img src="{{ url_for('static', filename='img/thbnails/' + post.default_thumb) }}" alt="選択されたデフォルトサムネイル" class="thumb-img">
                {% else %}
                    <img src="{{ url_for('static', filename='img/thbnails/system-default.jpg') }}" alt="システム共通デフォルトサムネイル" class="thumb-img">
                {% endif %}
            </div>

            <div class="post-content">
                <div class="post-header-meta">
                    <span class="badge-genre">📂 {{ post.genre if post.genre else '未分類' }}</span>

                    {% if not post.is_published %}
                        <span class="badge-private">🔒 非公開</span>
                    {% endif %}
                </div>

                <h2 class="post-title">
                    <a href="{{ url_for('blog.detail', id=post.id) }}">{{ post.title }}</a>
                </h2>

                {# ===== ハッシュタグバッジ ===== #}
                {% if post.hashtags %}
                    <div class="post-hashtags">
                        {% for tag in post.hashtags %}
                            <a href="{{ url_for('blog.index', genre=post.genre, hashtag=tag.name) }}" class="hashtag-badge">
                                #{{ tag.name }}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
                {# ============================= #}

                <p class="post-date">
                    🕒 投稿: {{ post.created_at.strftime('%Y年%m月%d日') }}
                    {% if post.updated_at %}
                        <span class="updated-date">（更新: {{ post.updated_at.strftime('%Y年%m月%d日') }}）</span>
                    {% endif %}
                </p>

                {% if current_user.is_authenticated and post.user_id == current_user.id %}
                    <div class="post-actions">
                        <a href="{{ url_for('admin.update', id=post.id) }}" role="button" class="btn-edit">編集</a>
                        <form action="{{ url_for('admin.delete', id=post.id) }}" method="POST" onsubmit="return confirm('本当にこの投稿を削除しますか？');" style="display:inline;">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                            <button type="submit" class="btn-delete">削除</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </article>
    {% else %}
        <p style="text-align:center; color:#aaa; margin-top:60px;">
            該当する記事が見つかりませんでした。
        </p>
    {% endfor %}

    {# ===== ページ番号によるページ送り ===== #}
    <nav class="index-pagination" id="index-pagination" aria-label="記事一覧のページ送り"></nav>
    {# ================================================ #}


    {# ===== フィルターなし（トップ表示）のときだけ hero・howtoを表示 ===== #}
    {% if not selected_genre and not search_word and not selected_hashtag %}
        {% include 'hero.html' %}
    {% endif %}
    {# ======================================================================= #}

</div>

<script>
/* ============================================================
   記事一覧のページ送り（ページ番号方式）
   ------------------------------------------------------------
   従来の「もっと見る／表示を減らす」による追加表示方式は、
   ページが縦に伸び続けてスクロール量が増えてしまい、
   どこからが新しく表示された記事なのか分かりにくいという
   課題があったため、1ページあたり PAGE_SIZE 件ずつを表示し、
   下部のページ番号ボタンで表示を「切り替える」方式に変更した。

   記事自体はこれまでと同様にサーバー側で全件レンダリングされており、
   JS側では表示するカードを display: none / '' で切り替えているだけ
   （サーバーへの再リクエストは発生しない）。

   ページを切り替えた際は、ユーザーが毎回一覧の先頭まで
   手動でスクロールし直す必要がないよう、
   #index-articles-anchor へ自動でスムーズスクロールする。
   ============================================================ */
(function () {
    var PAGE_SIZE = 4;   // 1ページあたりの表示件数

    var cards = Array.from(document.querySelectorAll('.page-wrapper > article.post-card'));
    var total = cards.length;
    var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    var currentPage = 1;

    var nav    = document.getElementById('index-pagination');
    var anchor = document.getElementById('index-articles-anchor');

    function showPage(page, opts) {
        opts = opts || {};
        currentPage = Math.min(Math.max(page, 1), totalPages);

        var start = (currentPage - 1) * PAGE_SIZE;
        var end   = start + PAGE_SIZE;

        cards.forEach(function (card, i) {
            card.style.display = (i >= start && i < end) ? '' : 'none';
        });

        renderPagination();

        if (opts.scroll && anchor) {
            anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    function makeButton(label, extraClass) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'page-btn' + (extraClass ? ' ' + extraClass : '');
        btn.textContent = label;
        return btn;
    }

    function renderPagination() {
        if (!nav) return;
        nav.innerHTML = '';

        /* 1ページに収まる件数しかない場合はページ送り自体を表示しない */
        if (totalPages <= 1) {
            nav.style.display = 'none';
            return;
        }
        nav.style.display = 'flex';

        /* 前へ */
        var prevBtn = makeButton('‹', 'page-btn-arrow');
        prevBtn.setAttribute('aria-label', '前のページ');
        prevBtn.disabled = currentPage === 1;
        prevBtn.addEventListener('click', function () {
            showPage(currentPage - 1, { scroll: true });
        });
        nav.appendChild(prevBtn);

        /* ページ番号 1, 2, 3 ... */
        for (var p = 1; p <= totalPages; p++) {
            (function (pageNum) {
                var btn = makeButton(String(pageNum), pageNum === currentPage ? 'active' : '');
                btn.setAttribute('aria-current', pageNum === currentPage ? 'page' : 'false');
                btn.addEventListener('click', function () {
                    showPage(pageNum, { scroll: true });
                });
                nav.appendChild(btn);
            })(p);
        }

        /* 次へ */
        var nextBtn = makeButton('›', 'page-btn-arrow');
        nextBtn.setAttribute('aria-label', '次のページ');
        nextBtn.disabled = currentPage === totalPages;
        nextBtn.addEventListener('click', function () {
            showPage(currentPage + 1, { scroll: true });
        });
        nav.appendChild(nextBtn);
    }

    showPage(1);
})();
</script>

{% endblock %}
</file>

