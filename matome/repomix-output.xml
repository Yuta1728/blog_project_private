# constants.py
#
# 【役割】
# アプリ全体で共有する「定数」を一元管理するファイル。
#
# 【なぜ定数ファイルを分けるのか】
# もし admin.py と blog.py にそれぞれ同じリストを書くと、
# ジャンルを追加・削除したいときに 2 か所を修正しなければならず
# 片方だけ更新するバグが起きやすい。
# ここに一か所まとめることで「変更は 1 か所だけ」になる（DRY 原則）。
#
# 使用箇所:
#   views/admin.py  → _get_genre_list() で新規ジャンル選択肢の母集合として使用
#   views/blog.py   → genre_list() でジャンル一覧ページの表示に使用

# -------------------------------------------------------------------
# DEFAULT_GENRES: アプリがデフォルトで用意するジャンルの一覧
#
# - 順番がそのままジャンル選択 UI の表示順になる
# - ユーザーが記事に使ったジャンルはこのリストに追加されることはなく、
#   あくまで「選択肢のひな形」として機能する
# - ユーザーが「+ 新しいジャンルを作成する」を選んで独自のジャンルを
#   追加することも可能（その場合 DB の Post.genre に直接保存される）
# -------------------------------------------------------------------
DEFAULT_GENRES = [
    # ライフスタイル系
    '日常', '健康', '旅行', '趣味', 'イラスト',
    # 社会・経済系
    'ニュース', '経済', '投資',
    # 技術・勉強系
    'プログラミング学習', '開発記録', '資格勉強', '勉強',
    # スポーツ系
    'サッカー', '野球', '競馬',
