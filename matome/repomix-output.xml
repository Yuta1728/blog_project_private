# ======================================================================
# PythonAnywhere の WSGI 設定ファイルに貼り付ける内容のサンプル
# ======================================================================
#
# 【使い方】
#   PythonAnywhere の Web タブにある WSGI 設定ファイルのリンク
#     /var/www/<ユーザー名>_pythonanywhere_com_wsgi.py
#   を開き、中身をすべて削除してから以下の内容に置き換える。
#   その際、<ユーザー名> と project_home を自分の環境に合わせて変更すること。
#
#   ※ このファイルはあくまで「貼り付け用サンプル」なので、
#      GitHub に置いておいても、PythonAnywhere 上で直接実行されるわけではない。
# ======================================================================

import sys

# ----------------------------------------------------------------------
# 1) プロジェクトのパスを Python の検索パスに追加する
# ----------------------------------------------------------------------
# git clone した先のディレクトリを指定する。
# 例: /home/<ユーザー名>/mysite
project_home = '/home/<ユーザー名>/mysite'   # ← 自分の clone 先に合わせて変更
if project_home not in sys.path:
    sys.path.insert(0, project_home)

# ----------------------------------------------------------------------
# 2) （任意）環境変数をここで直接設定することもできる
# ----------------------------------------------------------------------
# プロジェクト直下に .env を置く場合、config.py が自動で読み込むため
# 以下のブロックは不要（コメントアウトのままでよい）。
# .env を使いたくない場合は、以下のコメントを外して値を設定する。
#
# import os
# os.environ['FLASK_ENV']        = 'production'
# os.environ['USE_SQLITE']       = '1'
# os.environ['SECRET_KEY']       = '<ランダムな長い文字列>'
# os.environ['ADMIN_USERNAME']   = 'admin'
# os.environ['ADMIN_PASSWORD']   = '<パスワード（平文またはハッシュ）>'
# os.environ['ADMIN_LOGIN_PATH'] = 'secret-login-xxxxxxxx'
# os.environ['ADMIN_GATE_KEY']   = '<ランダムな長い文字列>'

# ----------------------------------------------------------------------
# 3) アプリを生成して application として公開する（WSGI の規約）
# ----------------------------------------------------------------------
# PythonAnywhere は「application」という名前の変数を探して実行する。
from app import create_app
application = create_app()
