<body>

    <header class="main-header" id="mainHeader">
        <div class="header-container">
            <div class="header-logo">
                <a href="{{ url_for('blog.index') }}">MIT Blog</a>
            </div>

            <div class="header-search-box">
                <form action="{{ url_for('blog.index') }}" method="GET" class="search-form">
                    {% if selected_genre %}
                        <input type="hidden" name="genre" value="{{ selected_genre }}">
                    {% endif %}
                    
                    <input type="text" name="search" value="{{ search_word if search_word else '' }}" placeholder="キーワードで検索...">
                    
                    <button type="submit" class="search-submit-btn" aria-label="検索">
                        <svg class="search-icon" viewBox="0 0 24 24" width="18" height="18">
                            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
                        </svg>
                    </button>
                    
                    {% if search_word or selected_genre %}
                        <a href="{{ url_for('blog.index') }}" class="search-clear-btn" aria-label="検索を解除してトップへ戻る">
