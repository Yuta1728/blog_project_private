        <div id="hashtag-preview" class="hashtag-preview-area"></div>

        <!-- ===== 画像アップロード ===== -->
        <p>
            <label>画像</label>
            ※「複数まとめて選択」で一括追加、「1枚追加」で1枚ずつ追加できます。
        </p>

        <!-- 既存：複数一括選択 input（hidden にして JS から参照） -->
        <input type="file" name="img[]" id="imgUpload" multiple accept="image/*"
               onchange="onBulkSelect(this)" style="display:none;">

        <!-- 追加：1枚ずつ選択用 input（hidden） -->
        <input type="file" name="" id="imgUploadOne" accept="image/*"
               onchange="onOneSelect(this)" style="display:none;">

        <!-- ボタン群 -->
        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:16px;">
            <button type="button" class="img-upload-btn img-upload-btn--bulk"
                    onclick="document.getElementById('imgUpload').click()">
                📂 複数まとめて選択
            </button>
