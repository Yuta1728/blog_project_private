    white-space: nowrap;
}

.header-nav ul li a:hover {
    color: #1a1a1a;
    border-color: #999;
    background-color: #f8f8f8;
    text-decoration: none;
}

/* 「新規投稿」だけアクセントカラー */
.header-nav ul li:first-child a {
    background-color: #1a1a1a;
    color: #fff;
    border-color: #1a1a1a;
}

.header-nav ul li:first-child a:hover {
    background-color: #333;
    border-color: #333;
    color: #fff;
}

/* ===========================
   ハンバーガーボタン（スマホ）
   =========================== */
.hamburger-btn {
    display: none;
    background: none;
    border: 1.5px solid #ddd;
    border-radius: 8px;
    padding: 8px 10px;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
}

.hamburger-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #333;
    border-radius: 2px;
    transition: all 0.25s ease;
}

/* ===========================
   ドロワーナビ（スマホ）
   =========================== */
.mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 999;
}

.mobile-nav-overlay.open {
    display: block;
}

.mobile-nav-drawer {
    position: fixed;
    top: 0;
    right: -290px;
    width: 270px;
    height: 100%;
    background: #fff;
    box-shadow: -4px 0 20px rgba(0,0,0,0.12);
    z-index: 1000;
    transition: right 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0;
    overflow-y: auto;
}

.mobile-nav-drawer.open {
    right: 0;
}

.mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 20px 16px;
    border-bottom: 1px solid #f0f0f0;
}

.mobile-nav-header-logo {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1a1a;
}

.mobile-nav-close {
    background: none;
    border: none;
    font-size: 22px;
    cursor: pointer;
    color: #888;
    padding: 4px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    transition: background 0.15s;
}

.mobile-nav-close:hover {
    background: #f5f5f5;
}

.mobile-nav-drawer ul {
    list-style: none;
    margin: 8px 0 0;
    padding: 0 12px;
}

.mobile-nav-drawer ul li {
    border-radius: 8px;
    overflow: hidden;
}

.mobile-nav-drawer ul li + li {
    margin-top: 2px;
}

.mobile-nav-drawer ul li a {
    display: block;
    padding: 14px 16px;
    color: #333;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: background 0.15s;
    border-radius: 8px;
}

.mobile-nav-drawer ul li a:hover {
    background: #f5f5f5;
}

/* 新規投稿ボタン（スマホドロワー内） */
.mobile-nav-drawer ul li:first-child a {
    background-color: #1a1a1a;
    color: #fff;
    margin-bottom: 8px;
    text-align: center;
}

.mobile-nav-drawer ul li:first-child a:hover {
    background-color: #333;
}

.clear { clear: both; }

/* ===========================
   スマホ（〜767px）
   =========================== */
@media (max-width: 767px) {

    .header-container {
        padding: 0 16px;
        height: 56px;
        gap: 12px;
    }

    .header-logo a {
        font-size: 22px;
    }

    .header-nav {
        display: none;
    }

    .hamburger-btn {
        display: flex;
    }

    .flash-messages {
        margin: 12px 16px;
    }

    .flash-messages li {
        font-size: 13px;
    }

    h2 {
        font-size: 20px;
        margin: 16px 0;
    }
}

/* ==========================================================================
   ヘッダー三分割・中央検索バーのレイアウトスタイル
   ========================================================================== */

/* 全体のコンテナ設定 */
.header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1200px; /* 必要に応じてブログの最大幅に合わせてください */
    margin: 0 auto;
    padding: 0 20px;
}

/* 1. ロゴエリア（左側をキープ） */
.header-logo {
    flex: 0 0 auto; /* 幅を自動にして縮ませない */
}

/* 2. 検索バーエリア（★ここが中央配置の肝になります） */
.header-search-box {
    flex: 1;               /* 利用可能なスペースをすべて広げる */
    display: flex;
    justify-content: center; /* 中身のフォームを完全に中央に寄せる */
    padding: 0 20px;
}

/* 検索フォーム自体のデザイン */
.header-search-box form {
    display: flex;
    align-items: center;
    background-color: #f1f3f5;
    border-radius: 20px;
    padding: 4px 14px;
    border: 1px solid #dee2e6;
    transition: all 0.3s ease;
    width: 100%;
    max-width: 350px; /* 検索バーが広がりすぎないように最大幅を制限 */
}

/* フォーカス時の演出 */
.header-search-box form:focus-within {
    background-color: #fff;
    border-color: #339af0;
    box-shadow: 0 0 0 3px rgba(51, 154, 240, 0.15);
}

.header-search-box input[type="text"] {
    border: none;
    background: transparent;
    outline: none;
    padding: 6px 4px;
    font-size: 14px;
    color: #495057;
    width: 100%; /* フォームの幅いっぱいに広げる */
}

/* ボタンとクリアボタンの調整 */
.search-submit-btn {
    border: none;
    background: transparent;
    cursor: pointer;
    color: #868e96;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    border-radius: 50%;
    transition: color 0.2s, background-color 0.2s;
}

.search-submit-btn:hover {
    color: #212529;
    background-color: #e9ecef;
}

.search-clear-btn {
    color: #adb5bd;
    text-decoration: none;
    margin-left: 8px;
    font-size: 14px;
    font-weight: bold;
}

.search-clear-btn:hover {
    color: #fa5252;
}

/* 3. ナビゲーションエリア（右側をキープ） */
.header-nav {
    flex: 0 0 auto;
}


/* ==========================================================================
   レスポンシブ対応（スマホ画面で検索バーをコンパクトに収める）
   ========================================================================== */
@media (max-width: 768px) {
    /* タブレット・スマホ全般での検索バー全体の配置設定 */
    .header-search-box {
        padding: 0 5px;   /* 左右のロゴやボタンとの間隔を最小限に */
        flex: 1;          /* 中央配置のためのベースは維持 */
        display: flex;
        justify-content: center; /* 常に中央に寄せる */
    }
    
    /* 検索バー本体を小さく絞り込む */
    .header-search-box form {
        width: 100%;
        max-width: 160px; /* 👈 【重要】スマホ版での検索バーの最大横幅をかなり小さく制限 */
        padding: 2px 8px; /* 上下の厚みを薄くしてスリムに */
        border-radius: 15px; /* スリム化に合わせて角丸の具合を調整 */
        background-color: #f1f3f5;
    }
    
    /* 入力エリアの文字と高さを小さく */
    .header-search-box input[type="text"] {
        font-size: 12px;     /* 文字を小さく */
        padding: 3px 2px;    /* 入力欄を縦に補足 */
    }
    
    /* 虫眼鏡アイコンを小さく */
    .search-submit-btn svg {
        width: 14px;         /* アイコンを一回り小さく */
        height: 14px;
    }
    
    /* ✕（クリア）ボタンも小さく */
    .search-clear-btn {
        margin-left: 4px;
        font-size: 11px;
    }
}

@media (max-width: 480px) {
    /* さらに画面幅が狭いスマホ（iPhone SEなど）での最終調整 */
    .header-search-box form {
        max-width: 120px; /* 👈 超小型スマホではさらに横幅を「120px」まで小さくして絶対に溢れさせない */
    }
    
    /* プレースホルダーの文字（キーワードで検索...）がはみ出るのを防ぐため、文字をさらに小さく */
    .header-search-box input[type="text"]::placeholder {
        font-size: 11px;
    }
}
</file>

<file path="static/css/create_update.css">
/* static/css/create_update.css - note風レスポンシブ対応版 */

/* ===========================
   ページレイアウト
   =========================== */
h1 {
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    margin: 36px 0 24px;
    color: #1a1a1a;
    letter-spacing: -0.01em;
}

/* ===========================
   フォームコンテナ
   =========================== */
.post-form {
    max-width: 720px;
    margin: 0 auto 60px;
    background: #fff;
    padding: 40px 44px;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    box-sizing: border-box;
}

/* ===========================
   ラベル
   =========================== */
.post-form label {
    display: block;
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 8px;
    color: #555;
    letter-spacing: 0.02em;
}

/* ===========================
   入力フィールド
   =========================== */
.post-form input[type="text"],
.post-form select {
    width: 100% !important;
    padding: 10px 14px;
    font-size: 15px;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    box-sizing: border-box;
    margin-bottom: 22px;
    outline: none;
    background-color: #fafafa;
    color: #1a1a1a;
    transition: border-color 0.18s, background 0.18s;
    font-family: inherit;
}

.post-form input[type="text"]:focus,
.post-form select:focus {
    border-color: #888;
    background-color: #fff;
}

/* ===========================
   テキストエリア（本文）
   =========================== */
.post-form textarea {
    width: 100% !important;
    padding: 18px !important;
    font-size: 17px !important;
    line-height: 1.9 !important;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", "Noto Sans JP", "MS Gothic", monospace !important;
    letter-spacing: normal !important;
    border: 1.5px solid #e0e0e0 !important;
    border-radius: 8px !important;
    box-sizing: border-box !important;
    margin-bottom: 22px !important;
    outline: none !important;
    background-color: #fafafa !important;
    color: #1a1a1a !important;
    min-height: 520px !important;
    resize: vertical !important;
    transition: border-color 0.18s, background 0.18s !important;
}

.post-form textarea:focus {
    border-color: #888 !important;
    background-color: #fff !important;
}

/* ===========================
   説明テキスト
   =========================== */
.post-form p {
    font-size: 13px;
    color: #999;
    margin: 0 0 6px;
    line-height: 1.6;
}

/* ===========================
   ファイル入力
   =========================== */
.post-form input[type="file"] {
    display: block;
    margin-bottom: 24px;
    font-size: 13px;
    color: #666;
    width: 100%;
}

/* ===========================
   送信・更新ボタン
   =========================== */
.post-form input[type="submit"] {
    display: block;
    width: 100%;
    padding: 14px;
    background-color: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.18s;
    font-family: inherit;
    letter-spacing: 0.02em;
}

.post-form input[type="submit"]:hover {
    background-color: #333;
}

/* ===========================
   画像プレビュー
   =========================== */
.preview-item {
    position: relative;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    overflow: hidden;
    background: #fafafa;
    width: 150px;
}

.preview-item img {
    width: 150px;
    height: 112px;
    object-fit: cover;
    display: block;
}

.preview-label {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    color: #777;
    padding: 5px 0 3px;
    background: #f5f5f5;
    border-top: 1px solid #eee;
    letter-spacing: 0.03em;
}

.preview-filename {
    text-align: center;
    font-size: 10px;
    color: #aaa;
    padding: 2px 6px 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* ===========================
   スマホ（〜767px）
   =========================== */
@media (max-width: 767px) {

    h1 {
        font-size: 17px;
        margin: 20px 0 16px;
    }

    .post-form {
        padding: 20px 16px;
        border-radius: 0;
        border-left: none;
        border-right: none;
        margin-bottom: 0;
    }

    .post-form label {
        font-size: 13px;
    }

    .post-form input[type="text"],
    .post-form select {
        font-size: 16px !important;
        padding: 10px 12px !important;
        border-radius: 6px;
        margin-bottom: 16px;
    }

    .post-form textarea {
        font-size: 16px !important;
        line-height: 1.75 !important;
        padding: 14px !important;
        min-height: 280px !important;
        border-radius: 6px !important;
        margin-bottom: 16px !important;
    }

    .post-form input[type="submit"] {
        padding: 14px;
        font-size: 15px;
        border-radius: 8px;
    }

    .preview-item {
        width: 100px;
    }

    .preview-item img {
        width: 100px;
        height: 75px;
    }
}


/* ===========================
   公開設定トグルボタン（追加分）
   =========================== */
.toggle-status-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 700;
    border-radius: 20px; /* 丸みのある扱いやすいデザイン */
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: all 0.2s ease;
    font-family: inherit;
    margin-bottom: 22px;
    outline: none;
}

/* 非公開時のスタイル（控えめなグレー） */
.toggle-status-btn.private {
    background-color: #f0f0f0;
    color: #555;
    border-color: #e0e0e0;
}

.toggle-status-btn.private:hover {
    background-color: #e5e5e5;
}

/* 全体公開時のスタイル（注意を引く緑系、またはブランドカラー） */
.toggle-status-btn.published {
    background-color: #e6f4ea;
    color: #137333;
    border-color: #ceead6;
}

.toggle-status-btn.published:hover {
    background-color: #d2e9d6;
}

/* スマホ対応の微調整 */
@media (max-width: 767px) {
    .toggle-status-btn {
        padding: 10px 16px;
        font-size: 13px;
        margin-bottom: 16px;
    }
}


/* ===========================
   マークダウンツールバー
   =========================== */
.md-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 12px;
    background: #f5f5f5;
    border: 1.5px solid #e0e0e0;
    border-bottom: none;          /* textareaと繋げる */
    border-radius: 8px 8px 0 0;
    margin-bottom: 0 !important;
}

.md-btn {
    padding: 7px 13px;
    font-size: 13px;
    font-weight: 600;
    color: #444;
    background: #fff;
    border: 1.5px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    line-height: 1;
    min-width: 44px;              /* スマホでのタップ領域を確保 */
    min-height: 36px;
    text-align: center;
}

.md-btn:hover,
.md-btn:active {
    background: #e8e8e8;
    border-color: #aaa;
    color: #111;
}

/* ツールバーと接続するためtextareaの上角を角丸なしに */
#bodyTextarea {
    border-radius: 0 0 8px 8px !important;
    border-top: none !important;
}

/* スマホ（〜767px） */
@media (max-width: 767px) {
    .md-btn {
        padding: 9px 11px;
        font-size: 13px;
        min-width: 48px;          /* タップしやすいサイズに */
        min-height: 42px;
    }
}
</file>

<file path="static/css/detail.css">
/* static/css/detail.css - note風レスポンシブ対応版（埋め込み目次同期・文字サイズ微拡大版） */

/* ===========================
   ページレイアウト
   =========================== */
.detail-container {
    max-width: 720px !important;
    margin: 0 auto;
    padding: 36px 24px 60px;
    box-sizing: border-box;
}

/* ===========================
   記事本体
   =========================== */
article {
    background: #fff;
    padding: 48px 52px;
    border: 1px solid #dedede;
    border-radius: 12px;
    margin-bottom: 32px;
    box-sizing: border-box;
}

h1 {
    font-size: 25px;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 20px;
    text-align: left;
    line-height: 1.4;
    letter-spacing: -0.02em;
}

/* ジャンルバッジ */
.genre-badge {
    background-color: #f0f0f0;
    color: #474747;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 8px;
    font-weight: 500;
}

/* メタ情報エリア */
.post-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
    color: #aaa;
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid #f0f0f0;
    width: 100%;
}

.post-user-info {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #555;
    font-weight: 600;
    font-size: 13px;
}

.post-user-info img {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #e9ecef;
    border: 1px solid #e0e0e0;
    margin: 0 !important;
}

.post-time {
    color: #8d8d8d;
    font-size: 12px;
}

/* ===========================
   目次（TOC）：上部固定・本文内埋め込み共通デザイン
   =========================== */
.post-toc,
.detail-article-body .toc {
    background-color: #f6f6f6 !important;
    border: 1px solid #dbdbdb !important;
    border-radius: 8px;
    padding: 20px 24px;
    margin: 36px 0;
    box-sizing: border-box;
}

/* 1. 【文字を強制表示するグループ】（HTML側にタイトルがない埋め込み目次用） */
.detail-article-body .toc::before {
    content: "目次" !important; /* CSS側で文字を出力します */
    display: block !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    margin: 0 0 14px !important;
    color: #3c3c3c !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

/* 2. 【HTML内のタイトルを装飾するグループ】（今回の <p class="toc-title"> 用） */
/* 💡 HTML側にすでに書かれている「目次」という文字に、デザインだけを適用します（2重化を防止） */
.post-toc .toc-title,
.toc-fixed .toc-title,
.toc-sticky .toc-title {
    display: block !important;
    font-weight: 700 !important;
    font-size: 17px !important;   /* 埋め込み式と同じサイズ */
    margin: 0 0 14px !important;  /* 下の見出しリストとの隙間 */
    color: #3c3c3c !important;    /* 落ち着いた黒（note風） */
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}


/* 埋め込み目次の「目次」タイトル設定（上部固定の.toc-titleとデザインを完全同期） */
.detail-article-body .toc::before {
    content: "目次" !important;
    display: block !important;
    font-weight: 700 !important;
    font-size: 15px !important; /* タイトルもわずかに大きく調整 (14px -> 15px) */
    margin: 0 0 14px !important;
    color: #3c3c3c !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

/* 一番外側のul（大見出しのリスト） */
.post-toc > ul,
.post-toc .toc > ul,
.detail-article-body .toc > ul {
    list-style-type: none !important;
    padding-left: 0 !important;
    margin: 0 !important;
    text-align: left !important;
    display: block !important;
}

/* 大見出し（h2）に該当するli */
.post-toc > ul > li,
.post-toc .toc > ul > li,
.detail-article-body .toc > ul > li {
    text-align: left !important;
    margin-bottom: 0 !important; 
    padding: 11px 0 !important; /* 🌟 文字拡大に合わせて上下の余白を微調整 (10px -> 11px) */
    font-size: 15px !important; /* 🌟 【PC版大見出し】わずかに拡大 (14px -> 15px) */
    font-weight: bold !important;
    display: block !important;
    background: none !important;
    border: none !important;
    border-bottom: 1px solid #dbdbdb !important;
}

/* 中見出しを包む内側のul（字下げ設定） */
.post-toc ul ul,
.post-toc .toc ul ul,
.detail-article-body .toc ul ul {
    list-style-type: none !important;
    padding-left: 20px !important; /* 🌟 視認性向上のため字下げ幅をわずかに調整 (18px -> 20px) */
    margin: 6px 0 0 !important;   /* 🌟 大見出しとの隙間をわずかに拡張 (4px -> 6px) */
    display: block !important;
}

/* 中見出し（h3）に該当するli */
.post-toc ul ul li,
.post-toc .toc ul ul li,
.detail-article-body .toc ul ul li {
    font-size: 14px !important; /* 🌟 【PC版中見出し】わずかに拡大 (13px -> 14px) */
    font-weight: normal !important;
    padding: 4px 0 !important; /* 🌟 行間が詰まりすぎないよう微調整 (3px -> 4px) */
    border-bottom: none !important;
    position: relative !important;
    display: block !important;
}

/* 中見出しの先頭に「•」アイコンを添える */
.post-toc ul ul li::before,
.post-toc .toc ul ul li::before,
.detail-article-body .toc ul ul li::before {
    content: "•" !important;
    color: #8d8d8d !important;
    margin-right: 6px !important;
    font-size: 13px !important; /* 🌟 アイコンのサイズも微調整 (12px -> 13px) */
}

/* 一番最後の項目だけは下線を消してスッキリさせる */
.post-toc > ul > li:last-child,
.post-toc .toc > ul > li:last-child,
.detail-article-body .toc > ul > li:last-child {
    margin-bottom: 0 !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

/* 最初の項目の上側の余白を少し詰める調整 */
.post-toc > ul > li:first-child,
.post-toc .toc > ul > li:first-child,
.detail-article-body .toc > ul > li:first-child {
    padding-top: 4px !important;
}

/* 目次内のリンク共通スタイル */
.post-toc a,
.detail-article-body .toc a {
    color: #515151 !important;
    text-decoration: none !important;
    transition: color 0.15s !important;
    display: inline-block !important;
}

.post-toc a:hover,
.detail-article-body .toc a:hover {
    color: #000 !important;
    text-decoration: none !important;
}

/* ===========================
   本文
   =========================== */
.detail-article-body {
    font-size: 18px;
    line-height: 1.5;
    word-break: break-word;
    text-align: left;
    white-space: normal;
    color: #2a2a2a;
}

.detail-article-body strong {
    font-weight: 700 !important;
    color: #1a1a1a;
}

.detail-article-body p {
    margin-top: 9px !important;
    margin-bottom: 1.4em;
    font-size: 20px;
}

.detail-article-body h2 {
    font-size: 23px;
    font-weight: 700;
    border-bottom: 2px solid #e8e8e8;
    padding-bottom: 6px;
    margin: 40px 0 16px;
    text-align: left;
    color: #1a1a1a;
}

.detail-article-body h3 {
    font-size: 20px;
    font-weight: 700;
    margin: 28px 0 0;
    text-align: left;
    color: #1a1a1a;
}

article img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 25px auto;
    border-radius: 5px;
    margin-bottom: 0%;
}

/* ===========================
   フッター
   =========================== */
hr {
    border: 0;
    border-top: 1px solid #eee;
    margin: 0 0 24px;
}

.detail-ul {
    display: flex;
    justify-content: center;
    gap: 16px;
    padding: 0;
    margin: 0;
    list-style: none;
    flex-wrap: wrap;
}

.detail-ul-li {
    background: none;
    border: none;
    padding: 0;
}

.detail-ul-li-a {
    font-size: 14px;
    color: #4e4e4e;
    text-decoration: none;
    padding: 10px 22px;
    border: 1.5px solid #c9c9c9;
    border-radius: 20px;
    display: inline-block;
    transition: all 0.18s;
}

.detail-ul-li-a:hover {
    border-color: #999;
    color: #1a1a1a;
    background: #f8f8f8;
    text-decoration: none;
}

/* ===========================
   スマホ（〜767px）
   =========================== */
@media (max-width: 767px) {

    .detail-container {
        padding: 16px 0 48px !important;
    }

    article {
        padding: 24px 18px;
        border-radius: 0;
        border-left: none;
        border-right: none;
        margin-bottom: 16px;
    }

    h1 {
        font-size: 20px;
        letter-spacing: -0.01em;
        line-height: 1.45;
    }

    .post-meta {
        font-size: 12px;
        gap: 6px;
        margin-bottom: 24px;
        padding-bottom: 16px;
    }

    .post-user-info {
        font-size: 13px;
    }

    .detail-article-body {
        font-size: 16px !important;
        line-height: 1.65 !important;
    }

    .detail-article-body p {
        margin-top: 9px !important;
        margin-bottom: 1.4em;
        font-size: 16px;
    }

    .detail-article-body h2 {
        font-size: 19px;
        margin: 32px 0 12px;
    }

    .detail-article-body h3 {
        font-size: 17px;
        margin: 24px 0 0;
    }

    /* スマホ用の目次（上部・埋め込み共通） */
    .post-toc,
    .detail-article-body .toc {
        padding: 16px !important;
        border-radius: 6px !important;
        margin-bottom: 24px !important;
    }

    /* 大見出し（h2）に該当するスマホ用の目次スタイル */
    .post-toc > ul > li,
    .post-toc .toc > ul > li,
    .detail-article-body .toc > ul > li {
        font-size: 14px !important; /* 🌟 【スマホ版大見出し】わずかに拡大 (13px -> 14px) */
        padding: 9px 0 !important;  /* スマホの余白も微調整 (8px -> 9px) */
    }

    /* 中見出し（h3）を包むスマホ用の内側リスト */
    .post-toc ul ul,
    .post-toc .toc ul ul,
    .detail-article-body .toc ul ul {
        padding-left: 16px !important; /* スマホ側の字下げもわずかに調整 (14px -> 16px) */
        margin: 4px 0 0 !important;   /* スマホ側の大見出しとの隙間調整 (2px -> 4px) */
    }

    /* 中見出し（h3）に該当するスマホ用の目次スタイル */
    .post-toc ul ul li,
    .post-toc .toc ul ul li,
    .detail-article-body .toc ul ul li {
        font-size: 13px !important; /* 🌟 【スマホ版中見出し】わずかに拡大 (12px -> 13px) */
        padding: 3px 0 !important;  /* スマホ側の行間調整 (2px -> 3px) */
    }

    /* 中見出しの「•」アイコンのスマホ用サイズ */
    .post-toc ul ul li::before,
    .post-toc .toc ul ul li::before,
    .detail-article-body .toc ul ul li::before {
        font-size: 12px !important; /* アイコンサイズ微調整 (11px -> 12px) */
        margin-right: 5px !important;
    }

    hr {
        margin: 0 16px 20px;
    }

    .detail-ul {
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 0 16px 12px;
    }

    .detail-ul-li-a {
        font-size: 14px;
        padding: 11px 24px;
        display: block;
        text-align: center;
        width: 100%;
        box-sizing: border-box;
    }
}
