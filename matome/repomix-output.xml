    border-color: #1a7aad;
    color: #0d3a52;
    text-decoration: none;
}

/* ===========================
   スマホ対応（about / howto）
   =========================== */
@media (max-width: 600px) {
    .hero-links {
        flex-direction: column;
        gap: 17px;
    }

    .hero-link-btn {
        text-align: center;
    }

    .info-page-container {
