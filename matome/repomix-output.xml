<file path="static/css/top_sections.css">
/* static/css/top_sections.css
   hero・howto・stats セクション共通スタイル
   ================================================= */

/* ===========================
   共通：セクション間余白
   =========================== */
.hero-section,
.howto-section,
.stats-section {
    margin-bottom: 28px;
}

/* ===========================
   hero セクション
   =========================== */
.hero-section {
    display: flex;
    align-items: center;
    gap: 24px;
    background: #ffffff;
    border: 1px solid #7cb9e1;
    border-radius: 12px;
    padding: 28px 32px;
    box-shadow: 0 4px 16px rgba(26, 122, 173, 0.07);
}

.hero-avatar img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid #c5dff0;
    background: #edf8ff;
    flex-shrink: 0;
    display: block;
}

.hero-body {
    flex: 1;
}

.hero-name {
    font-size: 20px;
    font-weight: 800;
    color: #0d3a52;
    margin: 0 0 10px;
    text-align: left;
    letter-spacing: -0.01em;
}

.hero-bio {
    font-size: 15px;
    color: #2a4a5e;
    line-height: 1.75;
    margin: 0;
}

/* ===========================
   howto セクション
   =========================== */
.howto-section {
    background: #f4fbff;
    border: 1px solid #c5dff0;
    border-left: 4px solid #1a7aad;
    border-radius: 12px;
    padding: 24px 28px;
}

.howto-title {
    font-size: 16px;
    font-weight: 700;
    color: #0d3a52;
    margin: 0 0 16px;
    text-align: left;
}

.howto-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.howto-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 14px;
    color: #2a4a5e;
    line-height: 1.65;
}

.howto-icon {
    font-size: 20px;
    flex-shrink: 0;
    line-height: 1.4;
}

.howto-item strong {
    color: #0d3a52;
    font-weight: 700;
}

/* ===========================
   stats セクション
   =========================== */
.stats-section {
    display: flex;
    gap: 27px;
    height: 70%;
}

.stats-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: #ffffff;
    border: 1px solid #7cb9e1;
    border-radius: 12px;
    padding: 12px 10px;
    box-shadow: 0 3px 10px rgba(26, 122, 173, 0.06);
    text-align: center;
}

.stats-icon {
    font-size: 20px;
    line-height: 1;
}

.stats-number {
    font-size: 24px;
    font-weight: 800;
    color: #1a7aad;
    line-height: 1.2;
    letter-spacing: -0.02em;
}

.stats-label {
    font-size: 12px;
    color: #5a8ba8;
    font-weight: 600;
    letter-spacing: 0.03em;
}

/* ===========================
   記事一覧 見出し
   =========================== */
.posts-section-title {
    font-size: 16px;
    font-weight: 700;
    color: #0d3a52;
    border-bottom: 2px solid #1a7aad;
    padding-bottom: 10px;
    margin: 0 0 20px;
    text-align: left;
    letter-spacing: 0.02em;
}

/* ===========================
   スマホ（〜600px）
   =========================== */
@media (max-width: 600px) {
    .hero-section {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        padding: 20px 16px;
    }

    .hero-avatar img {
        width: 64px;
        height: 64px;
    }

    .hero-name {
        font-size: 17px;
    }

    .hero-bio {
        font-size: 14px;
    }

    .howto-section {
        padding: 18px 16px;
    }

    .howto-title {
        font-size: 15px;
    }

    .howto-item {
        font-size: 13px;
        gap: 10px;
    }

    .howto-icon {
        font-size: 18px;
    }

    .stats-section {
        gap: 10px;
    }

    .stats-card {
        padding: 16px 8px;
    }

    .stats-icon {
        font-size: 18px;
    }

    .stats-number {
        font-size: 20px;
    }

    .stats-label {
        font-size: 11px;
    }
}

/* ===========================
   hero セクション内リンクボタン
   =========================== */
.hero-links {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    flex-wrap: wrap;
}

.hero-link-btn {
    display: inline-block;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
    color: #1a5f85;
    background: #edf8ff;
    border: 1.5px solid #8cc8e8;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.18s;
    white-space: nowrap;
}

.hero-link-btn:hover {
    background: #dff0fb;
    border-color: #1a7aad;
    color: #0d3a52;
    text-decoration: none;
}

/* ===========================
   about / howto ページ共通
   =========================== */
.info-page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 36px 24px 60px;
    box-sizing: border-box;
}

.info-page-header {
    display: flex;
    align-items: center;
