<file path="static/css/hashtag.css">
/* static/css/hashtag.css - 水色×白 爽やかテーマ版 v2（差し色・視認性改善） */

/* ===========================================================
   1. 投稿カード・詳細ページ共通：ハッシュタグバッジ
   =========================================================== */
.hashtag-badge {
    display: inline-block;
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 600;
    color: #0086cf;            /* 濃くして背景(#dff0fb)との差を確保 */
    background-color: #eeeeee;
    border-radius: 7px;
    text-decoration: none;
    transition: background-color 0.15s, border-color 0.15s;
    white-space: nowrap;
}

.hashtag-badge:hover {
    background-color: #c5dff0;
    border-color: #5aaedc;
    color: #0d3a52;
    text-decoration: none;
}

.post-hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 4px 0 10px;
}

.detail-hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
}

/* ===========================================================
   2. ハッシュタグ絞り込みバー
   =========================================================== */
.hashtag-filter-bar {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 10px;
    background: #fcffff;
    border: 1px solid #72c9ff;
    border-radius: 10px;
    padding: 14px 18px;
    margin-bottom: 24px;
}

.hashtag-filter-label {
    font-size: 13px;
    font-weight: 700;
    color: #1a5f85;            /* 濃くして読みやすく */
    white-space: nowrap;
    padding-top: 2px;
    flex-shrink: 0;
}

.hashtag-filter-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
}

.hashtag-filter-badge {
    display: inline-block;
    padding: 4px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #0e5e8a;
    background-color: #f5ffff;
    border: 1.5px solid #74cdfd;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
}

.hashtag-filter-badge:hover {
    background-color: #dff0fb;
    border-color: #5aaedc;
    color: #0d3a52;
    text-decoration: none;
}

/* 選択中バッジ */
.hashtag-filter-badge.active {
    background-color: #1a7aad;
    border-color: #1a7aad;
    color: #fff;
}

.hashtag-filter-badge.active:hover {
    background-color: #155f8a;
    border-color: #155f8a;
    color: #fff;
}

/* タグ解除（×）ボタン：赤系で削除の意味を明示 */
.hashtag-filter-clear {
    display: inline-block;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 700;
    color: #c0392b;            /* 警告赤 */
    background-color: #fff;
    border: 1.5px solid #f5b7b1;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
}

.hashtag-filter-clear:hover {
    background-color: #fff0ee;
    border-color: #e74c3c;
    color: #a93226;
    text-decoration: none;
}

/* ===========================================================
   3. 投稿フォーム：ハッシュタグ入力エリア
   =========================================================== */
.hashtag-input-wrapper {
    display: flex;
    align-items: center;
    border: 1.5px solid #c5dff0;
    border-radius: 8px;
    padding: 8px 14px;
    background: #f5f9fd;
    margin-bottom: 10px;
    transition: border-color 0.18s, background 0.18s;
    box-sizing: border-box;
    width: 100%;
}

.hashtag-input-wrapper:focus-within {
    border-color: #1a7aad;
    background: #fff;
}

.hashtag-prefix {
    font-size: 16px;
    font-weight: 700;
    color: #1a7aad;
    margin-right: 6px;
    user-select: none;
    flex-shrink: 0;
}

.hashtag-text-input {
    flex: 1;
    border: none !important;
    outline: none !important;
    background: transparent !important;
    font-size: 15px;
    color: #0d3a52;
    padding: 0 !important;
    margin: 0 !important;
    box-shadow: none !important;
    min-width: 0;
    font-family: inherit;
}

.hashtag-preview-area {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-height: 28px;
    margin-bottom: 22px;
}

.hashtag-badge-preview {
    display: inline-block;
    padding: 3px 12px;
    font-size: 12px;
    font-weight: 600;
    color: #1a5f85;
    background-color: #dff0fb;
    border: 1px solid #8cc8e8;
    border-radius: 20px;
    animation: badgePop 0.15s ease;
}

@keyframes badgePop {
    from { transform: scale(0.85); opacity: 0.6; }
    to   { transform: scale(1);    opacity: 1;   }
}

/* ===========================================================
   4. レスポンシブ（〜767px）
   =========================================================== */
@media (max-width: 767px) {
    .hashtag-filter-bar {
        flex-direction: column;
        gap: 8px;
        padding: 12px 14px;
        margin-bottom: 16px;
    }

    .hashtag-filter-list {
        gap: 6px;
    }

    .hashtag-filter-badge,
    .hashtag-filter-clear {
        font-size: 12px;
        padding: 5px 12px;
    }

    .post-hashtags,
    .detail-hashtags {
        gap: 5px;
    }

    .hashtag-badge {
        font-size: 12px;
        padding: 2px 8px;
    }

    .hashtag-input-wrapper {
        padding: 10px 12px;
    }

    .hashtag-text-input {
        font-size: 16px !important;
    }
}
</file>

<file path="static/css/index.css">
/* static/css/index.css - 水色×白 爽やかテーマ版 v2（差し色・視認性改善） */

/* ===========================
   メインレイアウト
   =========================== */
.page-wrapper {
    max-width: 845px;
    margin: 0 auto;
    padding: 32px 24px 60px;
    margin-top: 15px;
}

/* 編集ボタン */
.btn-edit {
    display: inline-block;
    padding: 2px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #1a6a96;          /* 濃くして視認性UP */
    border: 1.2px solid #7ab8d8;
    border-radius: 4px;
    margin-right: 7px;
    background: transparent;
    text-decoration: none;
}

a[role="button"]:hover {
    color: #0d5580;
    border-color: #5aaedc;
    background: #dff0fb;
    text-decoration: none;
}

/* ===========================
   フィルター表示テキスト（視認性改善）
   =========================== */
.filter-label {
    font-size: 15px;
    color: #094260;          /* #2a6f94より濃く、背景(#dff0fb)との差を確保 */
    font-weight: 600;
    margin-bottom: 20px;
    display: inline-block;
}

/* ===========================
   ジャンルバッジ（視認性改善）
   =========================== */
.badge-genre {
    font-size: 13px;
    font-weight: 600;
    color: #1a5f85;          /* 薄い水色背景の上でも読める濃さ */
    background: #f0faff;
    border: 1px solid #45a3d8;
    border-radius: 12px;
    padding: 2px 10px;
    white-space: nowrap;
}

/* ===========================
   非公開バッジ（差し色：暖色警告）
   =========================== */
.badge-private {
    font-size: 12px;
    font-weight: 700;
    color: #c0392b;          /* 警告赤 */
    background: #fff0ee;
    border: 1.2px solid #f5b7b1;
    border-radius: 12px;
    padding: 2px 10px;
    white-space: nowrap;
}

/* ===========================
   記事カード全体
   =========================== */
.post-card {
    display: flex;
    gap: 32px;
    background: #ffffff;
    border: 1px solid #80bfe9;
    border-radius: 10px;
    padding: 28px;
    margin-bottom: 20px;
    box-shadow: 0 3px 8px rgba(26, 122, 173, 0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
    cursor: pointer;
}

.post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(26, 122, 173, 0.12);
}

/* サムネイル */
.post-thumbnail {
    flex: 0 0 280px;
    height: 170px;
    border-radius: 6px;
    overflow: hidden;
    background-color: #dff0fb;
    border: 1.4px solid #38a1e2;
}

.thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
}

/* コンテンツエリア */
.post-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

/* メタ情報 */
.post-header-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
    font-size: 0.95rem;
    flex-wrap: wrap;
}

/* 記事タイトル */
.post-title {
    margin: 8px 0 8px 0;
    font-size: 1.25rem;
    line-height: 1.4;
    text-align: left !important;
}

.post-title a {
    color: #050505;
    text-decoration: none;
    display: inline-block;
}

/* 全域タップ化 */
.post-title a::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
}

.post-card:hover .post-title a {
    color: #006cd0;
}

/* ボタン保護 */
.post-actions {
    position: relative;
    z-index: 2;
}

/* ===========================
   削除ボタン（差し色：珊瑚系警告）
   =========================== */
.btn-delete {
    background: transparent;
    border: 1.2px solid #f5b7b1;  /* パステル赤ボーダー */
    color: #c0392b;                /* 警告赤の文字 */
    padding: 2px 12px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.18s;
}

.btn-delete:hover {
    background-color: #fff0ee;     /* パステル赤背景 */
    border-color: #e74c3c;
    color: #a93226;
}

/* ===========================
   投稿日時（視認性改善）
   =========================== */
.post-date {
    margin: 8px 0 0 0;
    font-size: 0.80rem;
    color: #3a82ac;              /* #7aaec8より濃く、爽やかさ維持 */
}

/* ===========================
   📱 スマホ対応
   =========================== */
@media (max-width: 600px) {
    .page-wrapper {
        padding: 16px 14px 48px;
    }

    .post-card {
        flex-direction: column;
        gap: 12px;
        padding: 12px;
        margin-top: 5px;
    }

    .post-thumbnail {
        flex: none;
        width: 100%;
        height: 220px;
    }

    .post-content {
        width: 100%;
    }

    .post-header-meta {
        font-size: 0.85rem;
        margin-bottom: 4px;
    }

    .post-title {
        font-size: 1.25rem;
        line-height: 1.4;
        margin-bottom: 10px;
    }

    .post-actions {
        margin-top: 4px;
        margin-bottom: 8px;
        display: flex;
        gap: 10px;
    }

    .btn-edit, .btn-delete {
        padding: 6px 16px;
        font-size: 13px;
        min-height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .post-date {
        font-size: 0.75rem;
        margin-top: 6px;
    }

    .post-title a::after {
        inset: 0;
        z-index: 1;
    }
}
</file>

<file path="static/css/load_more.css">
/* static/css/load_more.css
   「もっと見る」「表示を減らす」ボタン共通スタイル
   index.html / mypage.html の両方から読み込む
   ================================================= */

/* ===========================
   ボタンラッパー
   =========================== */
.load-more-wrap {
    display: none;          /* JS で flex に切り替える */
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 8px 0 40px;
    flex-wrap: wrap;
}

/* ===========================
   ボタン共通
   =========================== */
.load-more-btn,
.load-less-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 40px;
    border-radius: 24px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    transition: background-color 0.2s ease,
                border-color     0.2s ease,
                color            0.2s ease,
                box-shadow       0.2s ease,
                transform        0.15s ease;
}

/* ===========================
   「もっと見る」ボタン
   =========================== */
.load-more-btn {
    background-color: #ffffff;
    color: #1a5f85;
    border: 1.5px solid #8cc8e8;
    box-shadow: 0 2px 8px rgba(26, 122, 173, 0.08);
}

.load-more-btn:hover {
    background-color: #dff0fb;
    border-color: #5aaedc;
    color: #0d3a52;
    box-shadow: 0 4px 14px rgba(26, 122, 173, 0.14);
    transform: translateY(-1px);
}

.load-more-btn:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #c5dff0;
}

/* ===========================
   「表示を減らす」ボタン
   =========================== */
.load-less-btn {
    background-color: #ffffff;
    color: #5a8ba8;
    border: 1.5px solid #c5dff0;
    box-shadow: 0 2px 8px rgba(26, 122, 173, 0.05);
}

.load-less-btn:hover {
    background-color: #f4fbff;
    border-color: #8cc8e8;
    color: #0d3a52;
    box-shadow: 0 4px 14px rgba(26, 122, 173, 0.10);
    transform: translateY(-1px);
}

.load-less-btn:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #e4f3fb;
}

/* ===========================
   残件数バッジ
   =========================== */
.load-more-count {
    display: inline-block;
    background: #e4f3fb;
    color: #1a7aad;
    font-size: 12px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 10px;
    min-width: 28px;
    text-align: center;
    line-height: 1.6;
    transition: background-color 0.2s;
}

.load-more-btn:hover .load-more-count {
    background-color: #c5dff0;
}

/* ===========================
   スマホ（〜600px）
   =========================== */
@media (max-width: 600px) {
    .load-more-wrap {
        flex-direction: column;
        gap: 8px;
    }

    .load-more-btn,
    .load-less-btn {
        width: 100%;
        justify-content: center;
        padding: 14px 24px;
        font-size: 15px;
        border-radius: 20px;
    }
}
</file>

<file path="static/css/mypage.css">
/* static/css/mypage.css - 水色×白 爽やかテーマ版 v2（差し色・視認性改善） */

.mypage-container {
    max-width: 845px;
    margin: 0 auto;
    padding: 32px 24px 60px;
    box-sizing: border-box;
}

/* ===========================
   プロフィールヘッダー
   =========================== */
.profile-header {
    background: #fff;
    padding: 28px 28px 24px;
    border-radius: 12px;
    margin-bottom: 28px;
    border: 1px solid #c5dff0;
    box-shadow: 0 4px 16px rgba(26, 122, 173, 0.07);
}

.profile-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 8px 0;
    color: #0d3a52;
    letter-spacing: -0.01em;
}

.profile-username {
    margin: 4px 0 0;
    color: #5a8ba8;
    font-size: 13px;
}

.profile-post-count {
    margin: 10px 0 0;
    color: #2a4a5e;
    font-size: 14px;
}

.profile-post-count strong {
    color: #1a7aad;
    font-weight: 700;
}

