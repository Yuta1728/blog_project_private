# Pillow の高品質リサンプリング定数。
# Pillow 9.1 以降は Image.Resampling 名前空間、それ以前はトップレベル定数。
try:
    _RESAMPLE = Image.Resampling.LANCZOS
except AttributeError:  # Pillow < 9.1 用のフォールバック
    _RESAMPLE = Image.LANCZOS


