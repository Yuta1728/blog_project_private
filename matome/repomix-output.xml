<file path="static/css/genre.css">
/* static/css/genre.css - 水色×白 爽やかテーマ版（文字色修正済み） */

h1 {
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    margin: 36px 0 20px;
    color: #1a1a1a;
    letter-spacing: -0.01em;
}

.genre-container {
    max-width: 480px;
    margin: 0 auto 60px;
    background: #fff;
    border: 1px solid #c5dff0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(26, 122, 173, 0.07);
}

.genre-list, .sub-genre-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

/* 「全て表示」 */
.genre-item-all a {
    display: block;
    padding: 16px 24px;
    font-size: 15px !important;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 1px solid #dff0fb;
    transition: background 0.15s;
}

.genre-item-all a:hover {
    background: #f0f8fd;
    color: #1a7aad;
    text-decoration: none;
}

.genre-group {
    border-bottom: 1px solid #dff0fb;
}

.genre-group:last-child {
    border-bottom: none;
}

.group-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 24px;
    font-size: 15px;
    font-weight: 600;
    color: #1a1a1a;
    cursor: pointer;
    user-select: none;
    outline: none;
    list-style: none;
    transition: background 0.15s;
    min-height: 52px;
    box-sizing: border-box;
}

.group-title:hover {
    background: #f0f8fd;
}

.group-title::-webkit-details-marker {
    display: none;
}

.group-title .arrow {
    font-size: 10px;
    color: #8cc8e8;
    display: inline-block;
    transition: transform 0.22s ease, color 0.22s;
    flex-shrink: 0;
}

details[open] .group-title .arrow {
    transform: rotate(90deg);
    color: #1a7aad;
}

details[open] .group-title {
    color: #1a1a1a;
    background: #f0f8fd;
    border-bottom: 1px solid #dff0fb;
}

.sub-genre-list {
    background: #f8fbfe;
    padding: 4px 0;
}

.sub-genre-list li a {
    display: flex;
    align-items: center;
    padding: 12px 24px 12px 36px;
    font-size: 14px !important;
    color: #333;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    min-height: 44px;
    box-sizing: border-box;
}

.sub-genre-list li a::before {
