<file path="templates/base.html">
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mycreate1.MITOblog.jp</title>

    {# ============================================================
       ダークモード初期化スクリプト
    ============================================================ #}
    <script>
        (function () {
            try {
                var saved = localStorage.getItem('theme');
                var theme = saved
                    ? saved
                    : ((window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <link rel="icon" href="{{ url_for('static', filename='favicon/favicon.ico') }}" sizes="any">
    <link rel="icon" type="image/svg+xml" href="{{ url_for('static', filename='favicon/favicon.svg') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ url_for('static', filename='favicon/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ url_for('static', filename='favicon/favicon-16x16.png') }}">
    <link rel="apple-touch-icon" href="{{ url_for('static', filename='favicon/apple-touch-icon.png') }}">

    <link rel="stylesheet" href="{{ url_for('static', filename='css/base.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/hashtag.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/dark-mode.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/mobile-editor.css') }}">
</head>
<body>

    <header class="main-header" id="mainHeader">
        <div class="header-container">
            <div class="header-logo">
                <a href="{{ url_for('blog.index') }}">MITO Blog</a>
            </div>

            <div class="header-right">
                <nav class="header-nav">
                    <ul>
                        {% if current_user.is_authenticated %}
                            <li><a href="{{ url_for('admin.create') }}">新規投稿</a></li>
                            <li><a href="{{ url_for('blog.genre_list') }}">ジャンル検索</a></li>
             
                            <li><a href="{{ url_for('blog.about') }}">自己紹介</a></li>
                            <li><a href="{{ url_for('admin.mypage') }}">マイページ</a></li>
                            <li><a href="{{ url_for('auth.logout') }}">ログアウト</a></li>
                        {% else %}
                            <li><a href="{{ url_for('blog.genre_list') }}">ジャンル検索</a></li>
                 
                            <li><a href="{{ url_for('blog.about') }}">自己紹介</a></li>
                        {% endif %}
                    </ul>
                </nav>

                {# ダークモード切り替えボタン #}
                <button class="theme-toggle-btn" id="themeToggleBtn" type="button" aria-label="ダークモードに切り替え">
                    <span class="theme-toggle-icon">🌙</span>
                </button>

                <button class="hamburger-btn" id="hamburgerBtn" aria-label="メニューを開く">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>
    </header>

    <!-- オーバーレイ -->
    <div class="mobile-nav-overlay" id="navOverlay"></div>

    <!-- スマホ用ドロワー -->
    <div class="mobile-nav-drawer" id="navDrawer" aria-hidden="true">
        <div class="mobile-nav-header">
            <span class="mobile-nav-header-logo">MIT Blog</span>
            <button class="mobile-nav-close" id="navCloseBtn" aria-label="メニューを閉じる">✕</button>
        </div>
        <ul>
            {% if current_user.is_authenticated %}
                <li><a href="{{ url_for('admin.create') }}">✏️ 新規投稿</a></li>
                <li><a href="{{ url_for('blog.genre_list') }}">📂 ジャンル検索</a></li>

                <li><a href="{{ url_for('blog.about') }}">🙋 自己紹介</a></li>
                <li><a href="{{ url_for('admin.mypage') }}">👤 マイページ</a></li>
                <li><a href="{{ url_for('auth.logout') }}">🚪 ログアウト</a></li>
            {% else %}
                <li><a href="{{ url_for('blog.genre_list') }}">📂 ジャンル検索</a></li>
  
                <li><a href="{{ url_for('blog.about') }}">🙋 自己紹介</a></li>
            {% endif %}
        </ul>
    </div>

    {% with messages = get_flashed_messages(with_categories=True) %}
      {% if messages %}
        <ul class="flash-messages">
          {% for category, message in messages %}
            <li class="{{ category if category != 'message' else '' }}">{{ message }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    {% endwith %}

    {% block content %}{% endblock %}

    <script>
        /* ============================================================
           ダークモード切り替え
           ============================================================
           - クリックで <html> の data-theme を light / dark で切り替える
           - 選択内容は localStorage に保存し、次回訪問時も維持する
           - ボタンのアイコン（🌙 / ☀️）と aria-label を状態に合わせて更新
           ※ 初期テーマ自体は <head> のインラインスクリプトで
             描画前に設定済み（チラつき防止）。ここではその後の
             切り替え操作とアイコン同期のみを担当する。
           ============================================================ */
        (function () {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (!toggleBtn) return;
            const icon = toggleBtn.querySelector('.theme-toggle-icon');

            function syncButton() {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                // ライト時は「これから暗くする」意味で🌙、ダーク時は☀️を表示
                if (icon) icon.textContent = isDark ? '☀️' : '🌙';
                toggleBtn.setAttribute('aria-label', isDark ? 'ライトモードに切り替え' : 'ダークモードに切り替え');
                toggleBtn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
            }

            // ページ表示時点の状態にアイコンを合わせる
            syncButton();

            toggleBtn.addEventListener('click', function () {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                const next = isDark ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                try { localStorage.setItem('theme', next); } catch (e) {}
                syncButton();
            });
        })();


        /* ============================================================
           スマホの記事編集ツールバー改善（create / update ページ用）
           ------------------------------------------------------------
           ※ #bodyTextarea と #md-toolbar があるページ（create/update）でのみ動作する。
              それ以外のページ・PC 表示では何もしない。
           ============================================================ */
        (function () {
            var textarea = document.getElementById('bodyTextarea');
            var toolbar  = document.getElementById('md-toolbar');
            if (!textarea || !toolbar) return;   

            var wrapper = toolbar.closest('.md-toolbar-wrapper');
            var mq = window.matchMedia('(max-width: 767px)');
            var vv = window.visualViewport;
            var docked = false;
            var spacer = null;
            var mirror = null;

            var CARET_GAP = 16;   

            /* --------------------------------------------------------
               キーボード関連の寸法計算
               -------------------------------------------------------- */
            // キーボードの高さ（レイアウトビューポート − 表示ビューポート）
            function keyboardHeight() {
                if (!vv) return 0;
                return Math.max(0, window.innerHeight - vv.height - vv.offsetTop);
            }
            // キーボードが開いていると判定できるか（iOS 判定用のしきい値）
            function keyboardOpen() {
                return keyboardHeight() > 80;
            }
            function toolbarHeight() {
                return toolbar.offsetHeight || 48;
            }
            // ツールバー上端の「画面（viewport）上での Y 座標」を返す
            function toolbarTopY() {
                var h = toolbarHeight();
                if (vv && keyboardOpen()) {
                    // iOS 等：レイアウトが縮まないので visualViewport 下端基準
                    return vv.offsetTop + vv.height - h;
                }
                // Android 等：レイアウト自体が縮むので innerHeight 下端基準
                return window.innerHeight - keyboardHeight() - h;
            }

            /* --------------------------------------------------------
               ツールバーの固定位置を計算して設定
               -------------------------------------------------------- */
            function positionToolbar() {
                var h = toolbarHeight();
                if (vv && keyboardOpen()) {
                    // iOS 等：キーボード上端に合わせて top を指定
                    toolbar.style.bottom = 'auto';
                    toolbar.style.top = Math.max(vv.offsetTop + vv.height - h, 0) + 'px';
                } else {
                    // Android 等：レイアウトが縮むため bottom:0 が直上になる
                    toolbar.style.top = 'auto';
                    toolbar.style.bottom = '0px';
                }
            }

            // 本文欄下部の余白（最終行がツールバーに潜り込まないように）
            function applyPadding() {
                textarea.style.setProperty('padding-bottom', (toolbarHeight() + 48) + 'px', 'important');
            }

            /* --------------------------------------------------------
               スクロール余地を確保するスペーサー
               -------------------------------------------------------- */
            function ensureSpacer() {
                if (!spacer) {
                    spacer = document.createElement('div');
                    spacer.className = 'md-editing-spacer';
                    spacer.setAttribute('aria-hidden', 'true');
                    document.body.appendChild(spacer);
                }
                spacer.style.height = (keyboardHeight() + toolbarHeight() + 80) + 'px';
            }
            function removeSpacer() {
                if (spacer && spacer.parentNode) spacer.parentNode.removeChild(spacer);
                spacer = null;
            }

            /* --------------------------------------------------------
               カーソル位置の計測（ミラー要素方式）
               --------------------------------------------------------
               textarea 内のカーソル位置は直接取得できないため、
               同じフォント・幅・padding を持つ隠し div（ミラー）に
               「カーソルまでのテキスト」を流し込み、末尾へ置いた
               マーカー要素の offsetTop を測ることでカーソルの
               縦オフセット（textarea 内の px 位置）を求める。
               -------------------------------------------------------- */
            var MIRROR_PROPS = [
                'boxSizing', 'paddingTop', 'paddingRight', 'paddingBottom', 'paddingLeft',
                'borderTopWidth', 'borderRightWidth', 'borderBottomWidth', 'borderLeftWidth',
                'fontFamily', 'fontSize', 'fontWeight', 'fontStyle', 'fontVariant',
                'lineHeight', 'letterSpacing', 'textTransform', 'textIndent',
                'wordSpacing', 'tabSize', 'whiteSpace'
            ];
            function caretOffsetTop() {
                if (!mirror) {
                    mirror = document.createElement('div');
                    mirror.style.position   = 'absolute';
                    mirror.style.top         = '0';
                    mirror.style.left        = '-9999px';
                    mirror.style.visibility  = 'hidden';
                    mirror.style.whiteSpace  = 'pre-wrap';
                    mirror.style.wordWrap    = 'break-word';
                    mirror.style.overflowWrap = 'break-word';
                    document.body.appendChild(mirror);
                }
                var cs = window.getComputedStyle(textarea);
                MIRROR_PROPS.forEach(function (p) { mirror.style[p] = cs[p]; });
                // 折り返し幅を textarea に合わせる（getComputedStyle の width を使用）
                mirror.style.width  = cs.width;
                mirror.style.height = 'auto';

                mirror.textContent = textarea.value.substring(0, textarea.selectionEnd);
                var marker = document.createElement('span');
                marker.textContent = '\u200b';  
                mirror.appendChild(marker);
                return marker.offsetTop;
            }

            /* --------------------------------------------------------
               カーソルをツールバーより上に見えるようスクロール
               -------------------------------------------------------- */
            function ensureCaretVisible() {
                if (!docked) return;
                var cs = window.getComputedStyle(textarea);
                var lineHeight = parseFloat(cs.lineHeight);
                if (isNaN(lineHeight)) lineHeight = parseFloat(cs.fontSize) * 1.6;

                var caretTop = caretOffsetTop();
                var taRect   = textarea.getBoundingClientRect();
                // カーソルの画面上での上端・下端の Y 座標
                var caretViewTop    = taRect.top - textarea.scrollTop + caretTop;
                var caretViewBottom = caretViewTop + lineHeight;

                var lowerLimit = toolbarTopY() - CARET_GAP;   
                if (caretViewBottom > lowerLimit) {
                    // 下に隠れている → ページを下方向へスクロールして持ち上げる
                    window.scrollBy(0, Math.ceil(caretViewBottom - lowerLimit));
                    return;
                }

                // 上（ヘッダー等）に隠れている場合の保険
                var upperLimit = (vv ? vv.offsetTop : 0) + 12;
                if (caretViewTop < upperLimit) {
                    window.scrollBy(0, Math.floor(caretViewTop - upperLimit));
                }
            }

            // 描画・キーボード追従が落ち着いてから測るため 2 段階で実行
            function scheduleCaret() {
                if (!docked) return;
                requestAnimationFrame(ensureCaretVisible);
                setTimeout(ensureCaretVisible, 130);
            }

            /* --------------------------------------------------------
               ドッキング / 解除
               -------------------------------------------------------- */
            function dock() {
                if (!docked) {
                    docked = true;
                    if (wrapper) {
                        wrapper.style.setProperty('--docked-toolbar-h', toolbarHeight() + 'px');
                        wrapper.classList.add('is-toolbar-docked');
                    }
                    toolbar.classList.add('md-toolbar--docked');
                }
                positionToolbar();
                applyPadding();
                ensureSpacer();
            }

            function undock() {
                if (!docked) return;
                docked = false;
                toolbar.classList.remove('md-toolbar--docked');
                toolbar.style.top = '';
                toolbar.style.bottom = '';
                textarea.style.removeProperty('padding-bottom');
                if (wrapper) {
                    wrapper.classList.remove('is-toolbar-docked');
                    wrapper.style.removeProperty('--docked-toolbar-h');
                }
                removeSpacer();
            }

            function update() {
                if (mq.matches && document.activeElement === textarea) {
                    dock();
                } else {
                    undock();
                }
            }

            /* --------------------------------------------------------
               位置決めを数回リトライ（キーボードのアニメーション待ち）
               --------------------------------------------------------
               端末やアニメーション速度によってキーボードが開く
               タイミングがまちまちなため、フォーカス直後に複数回
               update() を走らせて確実にキーボード直上へ固定する。
               -------------------------------------------------------- */
            var retryTimers = [];
            function clearRetries() {
                retryTimers.forEach(clearTimeout);
                retryTimers = [];
            }
            function scheduleUpdates() {
                clearRetries();
                [60, 150, 280, 450, 650].forEach(function (ms) {
                    retryTimers.push(setTimeout(function () {
                        if (document.activeElement === textarea) {
                            update();
                            scheduleCaret();
                        }
                    }, ms));
                });
            }

            /* --------------------------------------------------------
               イベント登録
               -------------------------------------------------------- */
            textarea.addEventListener('focus', function () {
                textarea.classList.add('is-md-editing');
                scheduleUpdates();   
            });

            textarea.addEventListener('blur', function () {
                clearRetries();
                // ツールバー操作でのブラーはボタン側で抑止しているが、念のため少し待つ
                setTimeout(function () {
                    if (document.activeElement !== textarea) {
                        textarea.classList.remove('is-md-editing');
                        undock();
                    }
                }, 100);
            });

            // タップ位置・カーソル移動・入力に追従してカーソルを可視化
            textarea.addEventListener('click',  scheduleCaret);
            textarea.addEventListener('keyup',  scheduleCaret);
            textarea.addEventListener('input', function () {
                if (docked) { applyPadding(); ensureSpacer(); }
                scheduleCaret();
            });
            document.addEventListener('selectionchange', function () {
                if (docked && document.activeElement === textarea) scheduleCaret();
            });

            // キーボードの開閉・スクロールに追従して位置とカーソルを更新
            if (vv) {
                vv.addEventListener('resize', function () {
                    update();
                    if (docked) { ensureSpacer(); scheduleCaret(); }
                });
                vv.addEventListener('scroll', function () {
                    if (docked) positionToolbar();
                });
            }

            // ツールバーのボタンはフォーカスを奪わない
            // → 本文欄のフォーカス（＝キーボードと固定表示）を保ったまま連続操作できる
            toolbar.addEventListener('mousedown', function (e) {
                if (mq.matches && document.activeElement === textarea) {
                    e.preventDefault();
                }
            });
        })();


        /* ============================================================
           ドロワーナビ（スマホ）の開閉
           ============================================================ */
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const navOverlay   = document.getElementById('navOverlay');
        const navDrawer    = document.getElementById('navDrawer');
        const navCloseBtn  = document.getElementById('navCloseBtn');

        function openDrawer() {
            navDrawer.classList.add('open');
            navOverlay.classList.add('open');
            navDrawer.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeDrawer() {
            navDrawer.classList.remove('open');
            navOverlay.classList.remove('open');
            navDrawer.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        hamburgerBtn.addEventListener('click', openDrawer);
        navCloseBtn.addEventListener('click', closeDrawer);
        navOverlay.addEventListener('click', closeDrawer);

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeDrawer();
        });

        /* ============================================================
           スクロール連動ヘッダー表示 / 非表示
           ============================================================
           動作仕様:
             - ページ最上部付近（scrollY < THRESHOLD）: 常に表示
             - 下スクロール: ヘッダーを画面外（上方向）へスライドアウト
             - 上スクロール: ヘッダーをスライドインして再表示

           実装のポイント:
             1. requestAnimationFrame でバッチ処理し、scroll イベントの
                連続発火による過剰な DOM 操作（リフロー）を防ぐ。
             2. ドロワーが開いているときは非表示にしない
                （メニュー操作中にヘッダーが消えると UX が悪い）。
             3. THRESHOLD を設けることで、ページ最上部で微妙に
                上下した際にヘッダーが点滅するのを防ぐ。
           ============================================================ */
        (function () {
            const header    = document.getElementById('mainHeader');
            const THRESHOLD = 80;   
            const DELTA     = 5;    

            let lastScrollY  = window.scrollY;  
            let ticking      = false;            

            function updateHeader() {
                const currentScrollY = window.scrollY;
                const diff           = currentScrollY - lastScrollY;

                if (currentScrollY <= THRESHOLD) {
                    // ページ最上部付近 → 必ず表示
                    header.classList.remove('header-hidden');
                } else if (Math.abs(diff) >= DELTA) {
                    // DELTA 以上の変化があったときだけ方向を判定する
                    if (diff > 0) {
                        // 下スクロール → 非表示
                        // ただしドロワーが開いているときは操作を邪魔しないよう維持
                        if (!navDrawer.classList.contains('open')) {
                            header.classList.add('header-hidden');
                        }
                    } else {
                        // 上スクロール → 再表示
                        header.classList.remove('header-hidden');
                    }
                }

                lastScrollY = currentScrollY;
                ticking     = false;
            }

            window.addEventListener('scroll', function () {
                // rAF がまだ予約されていなければ新たに予約する
                // これにより 1 フレームに最大 1 回だけ updateHeader() が走る
                if (!ticking) {
                    requestAnimationFrame(updateHeader);
                    ticking = true;
                }
            }, { passive: true });  
        })();
    </script>
</body>
</html>
</file>

<file path="templates/create.html">
{% extends "base.html" %}
{% block content %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/create_update.css') }}">

<h1>新規投稿作成</h1>
<div>
    <form action="{{ url_for('admin.create') }}" method="post" enctype="multipart/form-data" class="post-form">
        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
        
        <label for="title">タイトル</label>
        <input type="text" name="title" required>

        <p>
            <label for="genre_select">ジャンル</label>
            <select name="genre_select" id="genre_select" onchange="toggleNewGenreInput()">
                <option value="未分類" selected>-- ジャンルを選択（選択なしは未分類） --</option>
                
                {% for genre in genres %}
                    <option value="{{ genre }}">{{ genre }}</option>
                {% endfor %}
                <option value="__NEW__">+ 新しいジャンルを作成する</option>
            </select>
        </p>

        <p id="new_genre_wrapper">
            <label for="genre_new">新しいジャンル名</label>
            <input type="text" name="genre_new" id="genre_new" placeholder="新しいジャンル名を入力">
        </p>

        <p>
            <label>公開設定</label>
            <input type="hidden" name="is_published" id="is_published" value="false">
            
            <button type="button" id="toggle_status_btn" class="toggle-status-btn private" onclick="handleStatusToggle()">
                <span class="status-icon">🔒</span>
                <span class="status-text">非公開</span>
            </button>
        </p>

        <script>
        function handleStatusToggle() {
            const hiddenInput = document.getElementById('is_published');
            const btn = document.getElementById('toggle_status_btn');
            const icon = btn.querySelector('.status-icon');
            const text = btn.querySelector('.status-text');

            if (hiddenInput.value === 'false') {
                hiddenInput.value = 'true';
                btn.classList.remove('private');
                btn.classList.add('published');
                icon.textContent = '🔓';
                text.textContent = '全体公開';
            } else {
                hiddenInput.value = 'false';
                btn.classList.remove('published');
                btn.classList.add('private');
                icon.textContent = '🔒';
                text.textContent = '非公開';
            }
        }
        </script>

        <label for="bodyTextarea">内容</label>

        <div class="md-toolbar-wrapper">

        <!-- ===== マークダウンツールバー ===== -->
        <div class="md-toolbar" id="md-toolbar">
            <button type="button" class="md-btn" onclick="mdInsertHeading2()">H2 見出し</button>
            <button type="button" class="md-btn" onclick="mdInsertHeading3()">H3 見出し</button>
            <button type="button" class="md-btn" onclick="mdWrapBold()"><b>太字</b></button>
            <button type="button" class="md-btn" onclick="mdInsertToc()">[toc] 目次</button>
            <button type="button" class="md-btn md-btn-list" onclick="mdInsertList('bullet')" title="箇条書きリストを挿入">
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="1.5" cy="3.5"  r="1.5" fill="currentColor"/>
                    <rect   x="5"   y="2.5" width="10" height="2" rx="1" fill="currentColor"/>
                    <circle cx="1.5" cy="7.5"  r="1.5" fill="currentColor"/>
                    <rect   x="5"   y="6.5" width="10" height="2" rx="1" fill="currentColor"/>
                    <circle cx="1.5" cy="11.5" r="1.5" fill="currentColor"/>
                    <rect   x="5"   y="10.5" width="10" height="2" rx="1" fill="currentColor"/>
                </svg>
                リスト
            </button>
            <span class="md-btn-separator"></span>
            <button type="button" class="md-btn md-btn-map" onclick="openMapModal()">🗺️ 地図</button>
            <button type="button" class="md-btn md-btn-youtube" onclick="openYoutubeModal()">▶ YouTube</button>
            <span class="md-btn-separator"></span>
            <span id="img-btn-group"></span>
        </div>

        <!-- ===== 地図挿入モーダル ===== -->
        <div id="map-modal-overlay" class="map-modal-overlay" onclick="closeMapModal()"></div>
        <div id="map-modal" class="map-modal" role="dialog" aria-modal="true" aria-label="地図挿入">
            <div class="map-modal-header">
                <span class="map-modal-title">🗺️ 地図を挿入</span>
                <button type="button" class="map-modal-close" onclick="closeMapModal()">✕</button>
            </div>
            <div class="map-modal-body">
                <label class="map-modal-label" for="map-place-input">場所・住所を入力</label>
                <input type="text" id="map-place-input" class="map-modal-input"
                       placeholder="例：東京スカイツリー、京都市伏見稲荷大社"
                       autocomplete="off"
                       oninput="updateMapPreview(this.value)">
                <div class="map-preview-area" id="map-preview-area">
                    <p class="map-preview-placeholder">場所を入力するとプレビューが表示されます</p>
                </div>
            </div>
            <div class="map-modal-footer">
                <button type="button" class="map-modal-cancel" onclick="closeMapModal()">キャンセル</button>
                <button type="button" class="map-modal-insert" id="map-insert-btn"
                        onclick="insertMapTag()" disabled>本文に挿入</button>
            </div>
        </div>

        <!-- ===== YouTube 挿入モーダル ===== -->
        <div id="youtube-modal-overlay" class="map-modal-overlay" onclick="closeYoutubeModal()"></div>
        <div id="youtube-modal" class="map-modal" role="dialog" aria-modal="true" aria-label="YouTube動画挿入">
            <div class="map-modal-header">
                <span class="map-modal-title">▶ YouTube 動画を挿入</span>
                <button type="button" class="map-modal-close" onclick="closeYoutubeModal()">✕</button>
            </div>
            <div class="map-modal-body">
                <label class="map-modal-label" for="youtube-url-input">YouTube URL または動画 ID を入力</label>
                <input type="text" id="youtube-url-input" class="map-modal-input"
                       placeholder="例：https://www.youtube.com/watch?v=dQw4w9WgXcQ"
                       autocomplete="off"
                       oninput="updateYoutubePreview(this.value)">
                <div class="map-preview-area map-preview-area--dark" id="youtube-preview-area">
                    <p class="map-preview-placeholder youtube-preview-placeholder">URL を入力するとプレビューが表示されます</p>
                </div>
            </div>
            <div class="map-modal-footer">
                <button type="button" class="map-modal-cancel" onclick="closeYoutubeModal()">キャンセル</button>
                <button type="button" class="map-modal-insert" id="youtube-insert-btn"
                        onclick="insertYoutubeTag()" disabled>本文に挿入</button>
            </div>
        </div>

        <textarea name="body" id="bodyTextarea" rows="17" required
                  placeholder="ここに文章を書く&#10;[img1]&#10;ここに続きの文章を書く..."></textarea>

        </div>

        <!-- ===== ハッシュタグ入力 ===== -->
        <p>
            <label for="hashtag_input">ハッシュタグ</label>
            ※スペース・カンマ区切りで複数入力できます。「#」は省略しても OK<br>
            　例：<code>#Flask Python ブログ開発</code>
        </p>
        <div class="hashtag-input-wrapper">
            <span class="hashtag-prefix">#</span>
            <input type="text"
                   name="hashtag_input"
                   id="hashtag_input"
                   class="hashtag-text-input"
                   placeholder="Flask Python ブログ開発 …"
                   autocomplete="off"
                   oninput="renderHashtagPreview(this.value)">
        </div>
        <div id="hashtag-preview" class="hashtag-preview-area"></div>

        <!-- ===== 画像アップロード（本文中に載せる画像） ===== -->
        <p>
            <label>画像（本文中に [imgN] で挿入されます）</label>
        </p>

        <!-- 既存：複数一括選択 input（img-input-hidden で非表示にして JS から参照） -->
        <input type="file" name="img[]" id="imgUpload" multiple accept="image/*"
               onchange="onBulkSelect(this)" class="img-input-hidden">

        <!-- 追加：1枚ずつ選択用 input（img-input-hidden で非表示） -->
        <input type="file" name="" id="imgUploadOne" accept="image/*"
               onchange="onOneSelect(this)" class="img-input-hidden">

        <!-- ボタン群 -->
        <div class="img-upload-btn-row">
            <button type="button" class="img-upload-btn img-upload-btn--bulk"
                    onclick="document.getElementById('imgUpload').click()">
                📂 複数まとめて選択
            </button>
            <button type="button" class="img-upload-btn img-upload-btn--one"
                    onclick="document.getElementById('imgUploadOne').click()">
                ＋ 1枚追加
            </button>
        </div>

        <!-- ===== 画像プレビュー＆キャプション入力エリア =====
             初期非表示（create_update.css の #preview-area）。JSが表示を切り替える -->
        <div id="preview-area">
            <p class="preview-area-title">
                📸 アップロード画像プレビュー
            </p>
            <div id="preview-list"></div>
        </div>

        {# ============================================================
           【機能追加】サムネイル専用画像のアップロード
           ------------------------------------------------------------
           以前は「本文画像の先頭」がサムネイルに流用されていたが、
           本文に載せたい画像とサムネイルにしたい画像は別なので、
           サムネイルを個別にアップロードできるようにした。
           アップロードしない場合は下のデフォルトサムネイルが使われる。
           ============================================================ #}
        <p>
            <label>サムネイル画像（任意）</label>
            ※記事一覧などで表示されるサムネイルを個別にアップロードできます。<br>
            　アップロードしない場合は、下で選択したデフォルトサムネイルが使用されます。
        </p>

        <!-- サムネイル選択用の隠し input（ボタンから .click() で起動） -->
        <input type="file" name="thumbnail_img" id="thumbnailUpload" accept="image/*"
               onchange="onThumbnailSelect(this)" class="img-input-hidden">

        <div class="img-upload-btn-row">
            <button type="button" class="img-upload-btn img-upload-btn--one"
                    onclick="document.getElementById('thumbnailUpload').click()">
                🖼️ サムネイル画像を選択
            </button>
        </div>

        <!-- サムネイルプレビュー（初期非表示。JS が style.display を切り替える） -->
        <div id="thumbnail-preview-area" style="display: none; margin-bottom: 20px;">
            <div class="preview-item preview-item--thumb">
                <img id="thumbnail-preview-img" src="" alt="サムネイルプレビュー">
                <div class="preview-label">アップロードするサムネイル</div>
                <button type="button" class="preview-delete-btn" onclick="clearThumbnail()">✕ 選択を解除</button>
            </div>
        </div>

        <p>
            <label for="default_thumb_select">デフォルトサムネイル画像を選択（サムネイル画像をアップロードしない場合）</label>
            <select name="default_thumb_select" id="default_thumb_select" onchange="previewDefaultThumb(this)">
                <option value="none" selected>-- 選択なし（システム共通のデフォルトになります） --</option>
                <option value="thumb_option1.jpg">選択肢1：趣味（thumb_option1.jpg）</option>
                <option value="thumb_option2.jpg">選択肢2：旅行（thumb_option2.jpg）</option>
                <option value="thumb_option3.jpg">選択肢3：スポーツ（thumb_option3.jpg）</option>
                <option value="thumb_option4.jpg">選択肢4：アニメ（thumb_option4.jpg）</option>
                <option value="thumb_option5.jpg">選択肢5：本（thumb_option5.jpg）</option>
                <option value="thumb_option6.jpg">選択肢6：ゲーム（thumb_option6.jpg）</option>
                <option value="thumb_option7.jpg">選択肢7：音楽（thumb_option7.jpg）</option>
                <option value="thumb_option8.jpg">選択肢8：映画（thumb_option8.jpg）</option>
                <option value="thumb_option9.jpg">選択肢9：ドラマ（thumb_option9.jpg）</option>
                <option value="thumb_option10.jpg">選択肢10：開発（thumb_option10.jpg）</option>
                <option value="thumb_option11.jpg">選択肢11：勉強（thumb_option11.jpg）</option>
            </select>
        </p>

        <div id="default-thumb-preview-area">
            <div class="preview-item preview-item--thumb">
                <img id="default-thumb-preview-img" src="" alt="デフォルトサムネイルプレビュー">
                <div class="preview-label">選択中のサムネイル</div>
            </div>
        </div>

        <input type="submit" value="投稿する">
    </form>
</div>


<script>
/* =========================================================
   画像ファイル管理（追加・削除・プレビュー再描画）
   =========================================================
   _fileList : File オブジェクトの配列（正データ）
   _captions : キャプション文字列の配列（インデックス対応）

   input[name="img[]"] の files は DataTransfer で都度再構築して同期する。
   これにより既存の Flask バックエンド（request.files.getlist('img[]')）は
   一切変更せずに動作する。
   ========================================================= */
var _fileList = [];   // File オブジェクトを格納する配列
var _captions = [];   // キャプション文字列を格納する配列

/**
 * input[name="img[]"] の files プロパティを _fileList と同期する。
 * DataTransfer を使うことでブラウザ制限を回避してファイルリストを書き換える。
 */
function _syncInputFiles() {
    var dt    = new DataTransfer();
    var input = document.getElementById('imgUpload');
    _fileList.forEach(function(f) { dt.items.add(f); });
    input.files = dt.files;
}

/**
 * 既存の「複数まとめて選択」: _fileList を完全置き換えして再描画。
 * 元の previewImages(input) の動作を維持。
 */
function onBulkSelect(input) {
    var newFiles = Array.from(input.files);
    if (newFiles.length === 0) return;

    // 既存キャプションを一旦保存（枚数が変わるのでリセット）
    _fileList = newFiles;
    _captions = new Array(newFiles.length).fill('');
    _syncInputFiles();
    renderPreviews();
}

/**
 * 新規追加：「1枚追加」ボタン用。_fileList に1枚追記して再描画。
 */
function onOneSelect(input) {
    var newFiles = Array.from(input.files);
    if (newFiles.length === 0) return;

    // キャプションを現在の枚数分保存してから追加
    _saveCaptions();
    newFiles.forEach(function(f) {
        _fileList.push(f);
        _captions.push('');
    });
    _syncInputFiles();
    renderPreviews();

    // 同じファイルを再度選べるよう input をリセット
    input.value = '';
}

/**
 * 指定インデックスの画像を削除して再描画。
 */
function deleteImage(index) {
    _saveCaptions();          
    _fileList.splice(index, 1);
    _captions.splice(index, 1);
    _syncInputFiles();
    renderPreviews();
}

/**
 * DOM 上のキャプション入力欄の値を _captions に保存する。
 * 再描画前に必ず呼ぶことで入力内容を引き継ぐ。
 */
function _saveCaptions() {
    var inputs = document.querySelectorAll('.preview-caption-input');
    inputs.forEach(function(el, i) {
        if (i < _captions.length) {
            _captions[i] = el.value;
        }
    });
}

/**
 * プレビューエリアを _fileList の内容で再描画する。
 * [imgN] ボタン・キャプション入力・削除ボタンもここで生成する。
 */
function renderPreviews() {
    var previewArea = document.getElementById('preview-area');
    var previewList = document.getElementById('preview-list');
    previewList.innerHTML = '';

    if (_fileList.length === 0) {
        previewArea.style.display = 'none';
        rebuildImgBtns(0);
        return;
    }
    previewArea.style.display = 'block';

    _fileList.forEach(function(file, index) {
        var reader = new FileReader();
        reader.onload = function(e) {
            var item = document.createElement('div');
            item.className = 'preview-item';
            item.style.width = '150px';

            // サムネイル
            var img = document.createElement('img');
            img.src = e.target.result;
            img.alt = file.name;

            // [imgN] ラベル
            var label = document.createElement('div');
            label.className = 'preview-label';
            label.textContent = '[img' + (index + 1) + ']';

            // ファイル名
            var filename = document.createElement('div');
            filename.className = 'preview-filename';
            filename.textContent = file.name;
            filename.title = file.name;

            // キャプション入力
            var captionWrapper = document.createElement('div');
            captionWrapper.className = 'preview-caption-wrapper';
            var captionInput = document.createElement('input');
            captionInput.type        = 'text';
            captionInput.name        = 'img_caption_' + (index + 1);
            captionInput.placeholder = '画像の説明（省略可）';
            captionInput.className   = 'preview-caption-input';
            captionInput.maxLength   = 100;
            captionInput.value       = _captions[index] || '';
            captionWrapper.appendChild(captionInput);

            // 削除ボタン（クロージャでインデックスを束縛）
            var deleteBtn = document.createElement('button');
            deleteBtn.type      = 'button';
            deleteBtn.className = 'preview-delete-btn';
            deleteBtn.textContent = '✕ この画像を削除';
            (function(i) {
                deleteBtn.onclick = function() { deleteImage(i); };
            })(index);

            item.appendChild(img);
            item.appendChild(label);
            item.appendChild(filename);
            item.appendChild(captionWrapper);
            item.appendChild(deleteBtn);
            previewList.appendChild(item);
        };
        reader.readAsDataURL(file);
    });

    rebuildImgBtns(_fileList.length);
}

/* =========================================================
   【機能追加】サムネイル専用画像のプレビュー
   =========================================================
   本文画像とは独立した 1 枚のサムネイルを選択・プレビューする。
   input[name="thumbnail_img"] は単一ファイルなので、
   File オブジェクトの管理配列は不要で、選択されたファイルを
   そのままプレビュー表示する（送信は input が担う）。
   ========================================================= */
function onThumbnailSelect(input) {
    var file = input.files && input.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
        document.getElementById('thumbnail-preview-img').src = e.target.result;
        document.getElementById('thumbnail-preview-area').style.display = 'block';
    };
    reader.readAsDataURL(file);
}

/** サムネイルの選択を解除してプレビューを消す。 */
function clearThumbnail() {
    var input = document.getElementById('thumbnailUpload');
    input.value = '';
    document.getElementById('thumbnail-preview-img').src = '';
    document.getElementById('thumbnail-preview-area').style.display = 'none';
}

/* =========================================================
   ジャンル入力切替
   ========================================================= */
function toggleNewGenreInput() {
    const selectBox = document.getElementById('genre_select');
    const newGenreWrapper = document.getElementById('new_genre_wrapper');
    const newGenreInput   = document.getElementById('genre_new');

    if (selectBox.value === '__NEW__') {
        newGenreWrapper.style.display = 'block';
        newGenreInput.required = true;
    } else {
        newGenreWrapper.style.display = 'none';
        newGenreInput.required = false;
        newGenreInput.value = '';
    }
}

/* =========================================================
   デフォルトサムネイルプレビュー
   ========================================================= */
function previewDefaultThumb(select) {
    const previewArea = document.getElementById('default-thumb-preview-area');
    const previewImg  = document.getElementById('default-thumb-preview-img');
    if (select.value === 'none') {
        previewArea.style.display = 'none';
        previewImg.src = '';
    } else {
        previewArea.style.display = 'block';
        previewImg.src = "/static/img/thbnails/" + select.value;
    }
}

/* =========================================================
   マークダウンツールバー共通ユーティリティ
   ========================================================= */
function mdInsertAt(ta, text, selectFrom, selectTo) {
    const start = ta.selectionStart;
    const end   = ta.selectionEnd;
    const before = ta.value.substring(0, start);
    const after  = ta.value.substring(end);
    ta.value = before + text + after;
    const newPos = selectFrom !== undefined ? start + selectFrom : start + text.length;
    const newEnd = selectTo   !== undefined ? start + selectTo   : newPos;
    ta.setSelectionRange(newPos, newEnd);
    ta.focus();
}

function mdInsertLinePrefix(ta, prefix) {
    const start = ta.selectionStart;
    const val   = ta.value;
    const lineStart = val.lastIndexOf('\n', start - 1) + 1;
    const before = val.substring(0, lineStart);
    const after  = val.substring(lineStart);
    ta.value = before + prefix + after;
    const newPos = start + prefix.length;
    ta.setSelectionRange(newPos, newPos);
    ta.focus();
}

function mdInsertHeading2() { mdInsertLinePrefix(document.getElementById('bodyTextarea'), '## '); }
function mdInsertHeading3() { mdInsertLinePrefix(document.getElementById('bodyTextarea'), '### '); }

function mdWrapBold() {
    const ta    = document.getElementById('bodyTextarea');
    const start = ta.selectionStart;
    const end   = ta.selectionEnd;
    const selected = ta.value.substring(start, end);
    if (selected.length > 0) {
        mdInsertAt(ta, '**' + selected + '**', 2, 2 + selected.length);
    } else {
        mdInsertAt(ta, '**太字テキスト**', 2, 6);
    }
}

function mdInsertToc() {
    const ta  = document.getElementById('bodyTextarea');
    const pos = ta.selectionStart;
    const val = ta.value;
    const before = val.substring(0, pos);
    const leadingNewlines = before.length === 0      ? ''
                          : before.endsWith('\n\n')  ? ''
                          : before.endsWith('\n')     ? '\n'
                          :                              '\n\n';
    const after = val.substring(pos);
    const trailingNewlines = after.length === 0      ? '\n'
                           : after.startsWith('\n\n') ? ''
                           : after.startsWith('\n')   ? '\n'
                           :                              '\n\n';
    mdInsertAt(ta, leadingNewlines + '[toc]' + trailingNewlines);
}

function mdInsertImg(n) { mdInsertAt(document.getElementById('bodyTextarea'), '[img' + n + ']'); }

function rebuildImgBtns(count) {
    const group = document.getElementById('img-btn-group');
    group.innerHTML = '';
    for (let i = 1; i <= count; i++) {
        const btn = document.createElement('button');
        btn.type      = 'button';
        btn.className = 'md-btn md-btn-img';
        btn.textContent = '[img' + i + ']';
        btn.onclick   = (function(n){ return function(){ mdInsertImg(n); }; })(i);
        group.appendChild(btn);
    }
}

/* =========================================================
   箇条書きリスト挿入
   ========================================================= */
var LIST_PREFIXES = { bullet: '●  ' };

function mdInsertList(type) {
    var ta     = document.getElementById('bodyTextarea');
    var prefix = LIST_PREFIXES[type];
    if (!prefix) return;
    var start        = ta.selectionStart;
    var end          = ta.selectionEnd;
    var hasSelection = (start !== end);
    if (hasSelection) { _mdListWrapSelection(ta, prefix, start, end); }
    else              { _mdListInsertEmpty(ta, prefix, start); }
}

function _mdListInsertEmpty(ta, prefix, cursorPos) {
    var val       = ta.value;
    var lineStart = val.lastIndexOf('\n', cursorPos - 1) + 1;
    var lineEnd   = val.indexOf('\n', cursorPos);
    var currentLine = val.substring(lineStart, lineEnd === -1 ? val.length : lineEnd);
    if (currentLine.trim() === '') {
        ta.value = val.substring(0, cursorPos) + prefix + val.substring(cursorPos);
        var newPos = cursorPos + prefix.length;
        ta.setSelectionRange(newPos, newPos);
    } else if (!currentLine.startsWith(prefix)) {
        ta.value = val.substring(0, lineStart) + prefix + val.substring(lineStart);
        var newPos2 = cursorPos + prefix.length;
        ta.setSelectionRange(newPos2, newPos2);
    } else {
        ta.setSelectionRange(cursorPos, cursorPos);
    }
    ta.focus();
}

function _mdListWrapSelection(ta, prefix, start, end) {
    var val      = ta.value;
    var selText  = val.substring(start, end);
    var converted = selText.split('\n').map(function(line) {
        if (line.trim() === '')       return line;
        if (line.startsWith(prefix)) return line;
        return prefix + line;
    }).join('\n');
    ta.value = val.substring(0, start) + converted + val.substring(end);
    ta.setSelectionRange(start, start + converted.length);
    ta.focus();
}

/* =========================================================
   ハッシュタグ入力プレビュー
   =========================================================
   【セキュリティ修正】innerHTML による文字列組み立てを廃止し、
   DOM API（createElement + textContent）に置き換えた。
   従来は入力値をそのまま HTML 文字列に連結していたため、
   <img src=x onerror=...> のような入力がそのまま実行される
   自己 XSS の経路になっていた。textContent への代入は
   ブラウザが常にプレーンテキストとして扱うため安全。
   ========================================================= */
function renderHashtagPreview(value) {
    var area   = document.getElementById('hashtag-preview');
    var tokens = value.trim().split(/[\s\u3000,、]+/).filter(Boolean);

    // 一旦クリアしてから安全な DOM ノードとして再構築する
    area.textContent = '';
    tokens.forEach(function(t) {
        var name = t.replace(/^#+/, '');
        if (!name) return;
        var span = document.createElement('span');
        span.className   = 'hashtag-badge-preview';
        span.textContent = '#' + name;   
        area.appendChild(span);
    });
}

/* =========================================================
   地図挿入モーダル
   ========================================================= */
var _mapPreviewTimer = null;

function openMapModal() {
    var ta = document.getElementById('bodyTextarea');
    window._mapInsertPos = { start: ta.selectionStart, end: ta.selectionEnd };
    document.getElementById('map-place-input').value = '';
    document.getElementById('map-preview-area').innerHTML =
        '<p class="map-preview-placeholder">場所を入力するとプレビューが表示されます</p>';
    document.getElementById('map-insert-btn').disabled = true;
    document.getElementById('map-modal-overlay').classList.add('open');
    document.getElementById('map-modal').classList.add('open');
    setTimeout(function() { document.getElementById('map-place-input').focus(); }, 80);
}
function closeMapModal() {
    document.getElementById('map-modal-overlay').classList.remove('open');
    document.getElementById('map-modal').classList.remove('open');
}
function updateMapPreview(value) {
    var insertBtn   = document.getElementById('map-insert-btn');
    var previewArea = document.getElementById('map-preview-area');
    clearTimeout(_mapPreviewTimer);
    var place = value.trim();
    if (!place) {
        previewArea.innerHTML = '<p class="map-preview-placeholder">場所を入力するとプレビューが表示されます</p>';
        insertBtn.disabled = true;
        return;
    }
    insertBtn.disabled = false;
    _mapPreviewTimer = setTimeout(function() {
        var encoded = encodeURIComponent(place);
        previewArea.innerHTML =
            '<iframe class="map-preview-iframe"' +
            ' src="https://maps.google.com/maps?q=' + encoded + '&output=embed&hl=ja"' +
            ' loading="lazy" allowfullscreen></iframe>';
    }, 600);
}
function insertMapTag() {
    var place = document.getElementById('map-place-input').value.trim();
    if (!place) return;
    var ta        = document.getElementById('bodyTextarea');
    var pos       = window._mapInsertPos || { start: ta.value.length, end: ta.value.length };
    var val       = ta.value;
    var lineStart = val.lastIndexOf('\n', pos.start - 1) + 1;
    var tag       = (pos.start === lineStart ? '' : '\n') + '[map:' + place + ']\n';
    ta.value      = val.substring(0, pos.start) + tag + val.substring(pos.end);
    var newPos    = pos.start + tag.length;
    ta.setSelectionRange(newPos, newPos);
    ta.focus();
    closeMapModal();
}

/* =========================================================
   YouTube 挿入モーダル
   ========================================================= */
var _ytPreviewTimer = null;

function openYoutubeModal() {
    var ta = document.getElementById('bodyTextarea');
    window._youtubeInsertPos = { start: ta.selectionStart, end: ta.selectionEnd };
    document.getElementById('youtube-url-input').value = '';
    document.getElementById('youtube-preview-area').innerHTML =
        '<p class="map-preview-placeholder youtube-preview-placeholder">URL を入力するとプレビューが表示されます</p>';
    document.getElementById('youtube-insert-btn').disabled = true;
    document.getElementById('youtube-modal-overlay').classList.add('open');
    document.getElementById('youtube-modal').classList.add('open');
    setTimeout(function() { document.getElementById('youtube-url-input').focus(); }, 80);
}
function closeYoutubeModal() {
    document.getElementById('youtube-modal-overlay').classList.remove('open');
    document.getElementById('youtube-modal').classList.remove('open');
}
function extractYoutubeId(raw) {
    raw = raw.trim();
    var m = raw.match(/[?&]v=([A-Za-z0-9_-]{11})/);
    if (m) return m[1];
    m = raw.match(/youtu\.be\/([A-Za-z0-9_-]{11})/);
    if (m) return m[1];
    m = raw.match(/\/shorts\/([A-Za-z0-9_-]{11})/);
    if (m) return m[1];
    m = raw.match(/\/embed\/([A-Za-z0-9_-]{11})/);
    if (m) return m[1];
    if (/^[A-Za-z0-9_-]{11}$/.test(raw)) return raw;
    return null;
}
function updateYoutubePreview(value) {
    var insertBtn   = document.getElementById('youtube-insert-btn');
    var previewArea = document.getElementById('youtube-preview-area');
    clearTimeout(_ytPreviewTimer);
    var videoId = extractYoutubeId(value);
    if (!videoId) {
        previewArea.innerHTML = '<p class="map-preview-placeholder youtube-preview-placeholder">URL を入力するとプレビューが表示されます</p>';
        insertBtn.disabled = true;
        return;
    }
    insertBtn.disabled = false;
    _ytPreviewTimer = setTimeout(function() {
        var thumbUrl = 'https://img.youtube.com/vi/' + videoId + '/hqdefault.jpg';
        previewArea.innerHTML =
            '<img src="' + thumbUrl + '" alt="サムネイルプレビュー"' +
            ' style="width:100%; height:100%; object-fit:cover; display:block;"' +
            ' onerror="this.parentNode.innerHTML=\'<p class=map-preview-placeholder>サムネイルを取得できませんでした</p>\'">';
    }, 600);
}
function insertYoutubeTag() {
    var rawUrl = document.getElementById('youtube-url-input').value.trim();
    if (!rawUrl || !extractYoutubeId(rawUrl)) return;
    var ta        = document.getElementById('bodyTextarea');
    var pos       = window._youtubeInsertPos || { start: ta.value.length, end: ta.value.length };
    var val       = ta.value;
    var lineStart = val.lastIndexOf('\n', pos.start - 1) + 1;
    var tag       = (pos.start === lineStart ? '' : '\n') + '[youtube:' + rawUrl + ']\n';
    ta.value      = val.substring(0, pos.start) + tag + val.substring(pos.end);
    var newPos    = pos.start + tag.length;
    ta.setSelectionRange(newPos, newPos);
    ta.focus();
    closeYoutubeModal();
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeMapModal(); closeYoutubeModal(); }
});

/* =========================================================
   Sticky ツールバー
   ========================================================= */
(function () {
    'use strict';
    var toolbar = document.getElementById('md-toolbar');
    if (!toolbar) return;
    var sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;top:0;height:1px;pointer-events:none;';
    toolbar.parentElement.insertBefore(sentinel, toolbar);
    var observer = new IntersectionObserver(
        function(entries) { toolbar.classList.toggle('is-sticky', !entries[0].isIntersecting); },
        { rootMargin: '-85px 0px 0px 0px', threshold: 0 }
    );
    observer.observe(sentinel);
    var mq = window.matchMedia('(max-width: 767px)');
    function updateRootMargin(e) {
        observer.disconnect();
        var offset = e.matches ? '-63px' : '-85px';
        observer = new IntersectionObserver(
            function(entries) { toolbar.classList.toggle('is-sticky', !entries[0].isIntersecting); },
            { rootMargin: offset + ' 0px 0px 0px', threshold: 0 }
        );
        observer.observe(sentinel);
    }
    mq.addEventListener('change', updateRootMargin);
})();
</script>

{% endblock %}
</file>

<file path="templates/detail.html">
{% extends "base.html" %}
{% block content %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/detail.css') }}">

<div class="detail-container">
    <article>
        <h1>
            {{ post.title }}
        </h1>

        {% set genre_display = post.genre if post.genre else '未分類' %}

        <div class="post-meta">
            <div class="detail-tag-row">
                <a href="{{ url_for('blog.index', genre=genre_display) }}" class="genre-badge">
                    📂 {{ genre_display }}
                </a>

                {% if post.hashtags %}
                    {% for tag in post.hashtags %}
                        <a href="{{ url_for('blog.index', genre=post.genre, hashtag=tag.name) }}"
                           class="hashtag-badge">
                            #{{ tag.name }}
                        </a>
                    {% endfor %}
                {% endif %}
            </div>

            <div class="post-user-info">
                <img src="https://api.dicebear.com/7.x/identicon/svg?seed={{ post.user.nickname if post.user.nickname else 'admin' }}" 
                    alt="avatar">
                <span>{{ post.user.nickname if post.user.nickname else '管理者' }}</span>
            </div>
            
            <div class="post-time">
                投稿日時: {{ post.created_at.strftime('%Y年%m月%d日') }}
                &nbsp;
                {% if post.updated_at %}
                    更新日時: {{ post.updated_at.strftime('%Y年%m月%d日') }}
                {% endif %}
            </div>
        </div>

        {% if toc_html and '<li>' in toc_html %}
            <div class="post-toc">
                <p class="toc-title">目次</p>
                {{ toc_html | safe }}
            </div>
        {% endif %}

        <div class="detail-article-body">{{ display_body | safe }}</div>
    </article>

    <hr>
    <div class="detail-actions">
        <button type="button" class="detail-btn detail-btn-back" onclick="goBack();">
            <svg class="detail-btn-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            前の画面に戻る
        </button>
        {% if current_user.is_authenticated and post.user_id == current_user.id %}
            <a href="{{ url_for('admin.update', id=post.id) }}" class="detail-btn detail-btn-edit">
                <svg class="detail-btn-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M14.7 3.3a1 1 0 0 1 1.4 0l.6.6a1 1 0 0 1 0 1.4L5.5 16.5l-2.5.5.5-2.5L14.7 3.3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                この記事を編集する
            </a>
        {% endif %}
    </div>

    {# ================================================================
       関連記事セクション（単一ブロック、最大4件）
       ================================================================ #}
    {% if related_posts %}
        <section class="related-section">

            <h2 class="related-heading">
                <span class="related-heading-icon">🔗</span>
                関連記事
                {% if related_sub_label %}
                    <span class="related-heading-sub">{{ related_sub_label }}</span>
                {% endif %}
            </h2>

            <ul class="related-list">
                {% for rel in related_posts %}
                    <li class="related-item">
                        <a href="{{ url_for('blog.detail', id=rel.id) }}" class="related-card">
                            <div class="related-thumb">
                                {# サムネイル表示の優先順位:
                                   1. thumbnail_img（アップロードされた専用サムネイル）
                                   2. default_thumb（プリセットから選択したデフォルトサムネイル）
                                   3. system-default.jpg（システム共通のデフォルト） #}
                                {% if rel.thumbnail_img %}
                                    <img src="{{ url_for('static', filename='img/posts/' + rel.thumbnail_img) }}"
                                         alt="{{ rel.title }}" loading="lazy">
                                {% elif rel.default_thumb %}
                                    <img src="{{ url_for('static', filename='img/thbnails/' + rel.default_thumb) }}"
                                         alt="{{ rel.title }}" loading="lazy">
                                {% else %}
                                    <img src="{{ url_for('static', filename='img/thbnails/system-default.jpg') }}"
                                         alt="{{ rel.title }}" loading="lazy">
                                {% endif %}
                            </div>
                            <div class="related-body">
                                <p class="related-title">{{ rel.title }}</p>
                                <p class="related-date">{{ rel.created_at.strftime('%Y年%m月%d日') }}</p>
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>

        </section>
    {% endif %}
    {# ================================================================ #}

</div>

<script>
/* ============================================================
   前の画面に戻る
   ============================================================ */
function goBack() {
    const referrer = document.referrer;
    if (referrer && new URL(referrer).origin === location.origin) {
        location.href = referrer;
    } else {
        history.back();
    }
}

/* ============================================================
   YouTube ファサード再生
   ============================================================ */
function ytPlay(facadeEl) {
    const wrapper  = facadeEl.closest('.post-youtube-wrapper');
    const embedUrl = wrapper.dataset.embedUrl;

    const iframe = document.createElement('iframe');
    iframe.src             = embedUrl;
    iframe.className       = 'post-youtube-iframe';
    iframe.allow           = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.allowFullscreen = true;
    iframe.referrerPolicy  = 'strict-origin-when-cross-origin';

    wrapper.appendChild(iframe);
    facadeEl.style.display = 'none';
}
</script>

{% endblock %}
</file>

