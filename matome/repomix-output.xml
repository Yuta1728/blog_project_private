.nickname-input:focus {
    border-color: #1a7aad;
    background: #fff;
}

.nickname-submit-btn {
    padding: 8px 18px;
    background-color: #1a7aad;
    color: #fff;
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    transition: background 0.18s;
    white-space: nowrap;
    flex-shrink: 0;
}

.nickname-submit-btn:hover {
    background-color: #155f8a;
}

/* ===========================
   セクション見出し
