                    <img src="{{ url_for('static', filename='img/' + post.default_thumb) }}" alt="選択されたデフォルトサムネイル" class="thumb-img">
                
                {% else %}
                    <img src="{{ url_for('static', filename='img/system-default.jpg') }}" alt="システム共通デフォルトサムネイル" class="thumb-img">
