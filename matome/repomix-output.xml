    background: #fff;
    padding: 28px 28px 24px;
    border-radius: 12px;
    margin-bottom: 28px;
    border: 1px solid #c5dff0;
    box-shadow: 0 4px 16px rgba(26, 122, 173, 0.07);
}

.profile-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 8px 0;
    color: #0d3a52;
