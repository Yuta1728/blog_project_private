<file path="static/css/mobile-editor.css">
/* ============================================================
   static/css/mobile-editor.css
   スマホでの記事編集（create / update）ツールバー操作性の改善
   ============================================================
   【役割】
   base.html から全ページで読み込まれるが、対象の要素
   （#md-toolbar / #bodyTextarea）は create / update ページにしか
   存在しないため、それ以外のページには一切影響しない。

   実際のフォーカス検知・位置計算・カーソル追従スクロールは
   base.html の JS が担当し、このファイルは「固定表示時の見た目」
   と「編集時の下部余白・スクロール確保用スペーサー」の
   スタイルだけを定義する。

   【解決する2つの問題（Notion 風 UI へ改良）】
   問題1: 本文欄をタップした最初のタイミングで、ツールバーが
          キーボードの下に隠れてしまう
          → JS が visualViewport 連動＋複数回リトライで
            キーボード直上へ確実にドッキングさせる。
            ここでは .md-toolbar--docked の固定表示スタイルを定義。
   問題2: text 枠の一番下付近の末尾をタップ／入力すると、
          文章の末尾がキーボードやツールバーの下に隠れて
          入力状況が見えない
          → JS がカーソル位置を計測し「ツールバーより上」に
            来るよう自動スクロールする。そのスクロール余地を
            確保するため、本文欄下部の余白（.is-md-editing）と
            ページ末尾のスペーサー（.md-editing-spacer）を用意する。
   ============================================================ */

@media (max-width: 767px) {

    /* ------------------------------------------------------------
       【問題2】最終行がキーボード／ツールバーに隠れる対策（本文欄側）
       ------------------------------------------------------------
       本文欄フォーカス中（JS が .is-md-editing を付与）に下部余白を
       確保し、最終行のカーソルがツールバーの上に出やすくする。
       ドッキング時は JS がツールバー高さに合わせて padding-bottom を
       インラインで上書きする（このルールはフォールバック値）。
       ------------------------------------------------------------ */
    #bodyTextarea.is-md-editing {
        padding-bottom: 96px !important;
    }

    /* ------------------------------------------------------------
       【問題1】ツールバーをキーボードの直上に固定
       ------------------------------------------------------------
       本文欄フォーカス中、JS が .md-toolbar--docked を付与して
       ツールバーを画面下部（キーボードの直上）に固定表示する。
       - 位置（top / bottom）は端末差に応じて JS が設定する
         （iOS はレイアウトが縮まないので visualViewport 下端に合わせた
          top、Android は bottom:0 で自然に直上）
       - 縦幅を節約するため、折り返さず横スクロールできる1行にする
       ------------------------------------------------------------ */
    .md-toolbar.md-toolbar--docked {
        position: fixed !important;
        left: 0;
        right: 0;
        bottom: 0;                     /* iOS では JS が top を設定して上書き */
        margin: 0 !important;
        border-radius: 0 !important;
        border-left: none !important;
        border-right: none !important;
        border-top: 1px solid #7dd3fa !important;
        border-bottom: none !important;
        box-shadow: 0 -6px 16px rgba(14, 165, 233, 0.28) !important;
        z-index: 1000 !important;
        flex-wrap: nowrap !important;  /* 折り返さず1行に */
        overflow-x: auto !important;   /* ボタンが多い時は横スクロール */
        -webkit-overflow-scrolling: touch;
        /* 位置変更（top）をアニメーションさせるとキーボード追従が
           カクつくため、位置は即時反映（transition なし）にする */
        transition: none !important;
        /* iOS でツールバー自身がスクロール時にちらつかないよう明示 */
        will-change: top;
    }

    /* 固定表示中はボタンが縮まないようにして横スクロールで全ボタンに届くようにする */
    .md-toolbar.md-toolbar--docked > * {
        flex-shrink: 0;
    }

    /* ツールバーが固定表示に切り替わって通常配置（フロー）から外れた分、
       元の位置に空きを作ってレイアウトのガタつきを防ぐ。
       高さは JS が --docked-toolbar-h に実測値を入れる。 */
    .md-toolbar-wrapper.is-toolbar-docked {
        padding-top: var(--docked-toolbar-h, 48px);
    }

    /* ------------------------------------------------------------
       【問題2】カーソル追従スクロールの「スクロール余地」を確保
       ------------------------------------------------------------
       本文欄の末尾付近にカーソルがある状態で、それを
       「ツールバーより上」へ持ち上げるには、ページを下方向へ
       スクロールできる余白が本文欄の下に必要になる。
       JS が編集開始時に body 末尾へこのスペーサーを差し込み、
       高さ（キーボード高さ＋ツールバー高さ相当）を動的に設定する。
       編集終了時には JS が取り除く。
       ------------------------------------------------------------ */
    .md-editing-spacer {
        width: 100%;
        pointer-events: none;
        height: 0;   /* 実際の高さは JS が設定。未設定時の保険値 */
    }

    /* ダークモード時の固定ツールバーの見た目 */
    html[data-theme="dark"] .md-toolbar.md-toolbar--docked {
        background-color: var(--dk-surface-2) !important;
        border-top-color: var(--dk-border) !important;
        box-shadow: 0 -6px 16px rgba(0, 0, 0, 0.55) !important;
    }
}
</file>

<file path="static/css/mypage.css">
/* ============================================================
   static/css/mypage.css - Coastal Dawn v2
   【対象ページ】 mypage.html（マイページ）
   ============================================================
   このファイルはマイページ専用のスタイルをまとめている
   （記事カード自体のデザインは index.css を共用）。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【mypage.html】ページ全体のレイアウト
   ------------------------------------------------------------ */
.mypage-container {
    max-width: 940px;
    margin: 0 auto;
    padding: 38px 28px 60px;
    box-sizing: border-box;
}

/* ------------------------------------------------------------
   【mypage.html】ページ送り後に投稿一覧の先頭へ戻すための目印（非表示要素）
   ------------------------------------------------------------
   ページ番号リンクの #mypage-articles-anchor フラグメントで
   ここへスクロールする。固定ヘッダー（position: fixed）の下に
   隠れないよう scroll-margin-top をヘッダーの高さ分だけ確保しておく。
   （index.css の #index-articles-anchor と同じ考え方）
   ------------------------------------------------------------ */
#mypage-articles-anchor {
    scroll-margin-top: 100px;
}

@media (max-width: 767px) {
    #mypage-articles-anchor {
        scroll-margin-top: 80px;
    }
}

/* ============================================================
   【mypage.html】プロフィールカード（ニックネーム・投稿数・変更フォーム）
   ============================================================ */
.profile-header {
    background: #fff;
    padding: 28px 28px 24px;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    margin-bottom: 30px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.profile-title {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 8px 0;
    color: #0c1f35;
    letter-spacing: -0.01em;
}

.profile-username {
    margin: 4px 0 0;
    color: #4a7a96;
    font-size: 13px;
}

.profile-post-count {
    font-weight: 500;
    margin: 10px 0 0;
    color: #2a4a5e;
    font-size: 14px;
}

.profile-post-count strong {
    color: #0369a1;
    font-weight: 700;
}

/* ------------------------------------------------------------
   【mypage.html】ニックネーム変更フォーム
   ------------------------------------------------------------ */
.nickname-form-wrapper {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid #e0f2fe;
}

.nickname-form-wrapper > p,
.nickname-form label {
    font-size: 13px;
    color: #4a7a96;
    margin: 0 0 8px;
    font-weight: 500;
}

.nickname-form {
    display: flex;
    gap: 8px;
    align-items: center;
}

.nickname-input {
    flex: 1;
    min-width: 0;
    padding: 8px 14px;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.18s, box-shadow 0.18s;
    background: #f0f9ff;
    color: #0c1f35;
    font-family: inherit;
}

.nickname-input:focus {
    border-color: #0ea5e9;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

.nickname-submit-btn {
    padding: 8px 18px;
    background-color: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    transition: background 0.18s;
    white-space: nowrap;
    flex-shrink: 0;
    font-family: inherit;
}

.nickname-submit-btn:hover {
    background-color: #0369a1;
}

/* ------------------------------------------------------------
   【mypage.html】セクション見出し（「📂 使用ジャンル」「📝 投稿一覧」）
   ------------------------------------------------------------ */
.section-title-genre,
.section-title-posts {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 36px 0 20px;
    letter-spacing: 0.02em;
}

/* ------------------------------------------------------------
   【mypage.html】使用ジャンルのタグ一覧
   ------------------------------------------------------------ */
.user-genre-list { margin-bottom: 8px; }

.genre-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.genre-tag-item {
    background: #dbeafe;
    border: 1px solid #38bdf8;
    padding: 4px 14px;
    border-radius: 15px;
    display: inline-block;
    transition: all 0.15s;
}

.genre-tag-item:hover {
    background: #bae6fd;
    border-color: #0ea5e9;
}

.genre-tag-link {
    text-decoration: none;
    color: #0369a1;
    font-size: 13px;
    font-weight: 600;
}

/* ------------------------------------------------------------
   【mypage.html】ジャンル管理欄にジャンルが1件もないときの注記
   ------------------------------------------------------------ */
.genre-empty-note {
    color: #aaa;
    font-size: 14px;
}

/* ------------------------------------------------------------
   【mypage.html】投稿が1件もない場合の案内メッセージ
   ------------------------------------------------------------ */
.empty-message {
    color: #4a7a96;
    text-align: center;
    margin-top: 48px;
    font-size: 15px;
    line-height: 2;
}

.empty-message a {
    color: #0369a1;
    text-decoration: underline;
}

/* ------------------------------------------------------------
   【mypage.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .mypage-container { padding: 15px 12px 48px; width: 100% !important; box-sizing: border-box; }
    .profile-header { padding: 20px 16px 18px; border-radius: 0 10px 10px 0; margin-bottom: 20px; }
    .profile-title { font-size: 17px; }
    .nickname-form { flex-direction: column; align-items: stretch; gap: 8px; }
    .nickname-input { font-size: 16px; width: 100% !important; box-sizing: border-box; }
    .nickname-submit-btn { text-align: center; margin-top: 4px; padding: 10px; font-size: 14px; width: 100%; min-height: 40px; }
    .section-title-genre, .section-title-posts { font-size: 15px; margin: 28px 0 16px; }
    .genre-tag-item { padding: 6px 14px; }
}
</file>

<file path="static/css/top_sections.css">
/* ============================================================
   static/css/top_sections.css - Coastal Dawn v2（白ヘッダー・視認性改善版）
   【対象ページ】 index.html（hero・stats・記事一覧見出し・検索エリア）
                 about.html / howto.html（静的情報ページ共通レイアウト）
   ============================================================
   複数ページで共用する「セクション単位」のパーツをまとめたファイル。
   どのページ・どの機能のデザインかをブロックごとに明記している。
   ============================================================ */


/* ------------------------------------------------------------
   【index.html】hero（自己紹介）セクションの見出し「📋 自己紹介」
   ------------------------------------------------------------ */
.hero-section-title {
    font-size: 16px;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 0 0 20px;
    text-align: left;
    letter-spacing: 0.02em;
    margin-top: 45px;
}


/* ------------------------------------------------------------
   【共通】セクション間の余白（hero / howto / stats 共通）
   ------------------------------------------------------------ */
.hero-section,
.howto-section,
.stats-section {
    margin-bottom: 40px;
}


/* ============================================================
   【index.html】hero（自己紹介）セクション本体（hero.htmlをinclude）
   ============================================================ */
.hero-section {
    display: flex;
    align-items: center;
    gap: 24px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 28px 32px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

/* 管理者アバター画像 */
.hero-avatar img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid #bae6fd;
    background: #e0f2fe;
    flex-shrink: 0;
    display: block;
}

.hero-body {
    flex: 1;
}

/* ブログ名見出し（「◯◯ のブログ」） */
.hero-name {
    font-size: 20px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0 0 10px;
    text-align: left;
    letter-spacing: -0.02em;
}

/* 自己紹介の一言テキスト */
.hero-bio {
    font-weight: 500;
    font-size: 15px;
    color: #2a4a5e;
    line-height: 1.75;
    margin: 0;
}

/* 「👤 自己紹介を読む」「📖 使い方を見る」リンクボタン */
.hero-links {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    flex-wrap: wrap;
}

.hero-link-btn {
    display: inline-block;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
    color: #0369a1;
    background: #e0f2fe;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.18s;
    white-space: nowrap;
}

.hero-link-btn:hover {
    background: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}


/* ============================================================
   【現状未使用】howto セクション用スタイル
   ============================================================
   このブロックは元々 howto.html 内の「使い方リスト」表示用に
   作られたものだが、howto.html は現在
   about.html と同じ .info-page-container 系レイアウト
   （このファイル内の「about/howtoページ共通」セクション）
   に統一されているため、.howto-section 系クラスは
   現状どのテンプレートからも参照されていない。
   将来 howto 用の別レイアウトを作る際の下敷きとして残している。
   ============================================================ */
.howto-section {
    background: #f4fbff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 24px 28px;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.08);
}

.howto-title {
    font-size: 16px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0 0 16px;
    text-align: left;
}

.howto-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.howto-item {
    font-weight: 500;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 14px;
    color: #2a4a5e;
    line-height: 1.65;
}

.howto-icon {
    font-size: 20px;
    flex-shrink: 0;
    line-height: 1.4;
}

.howto-item strong {
    color: #0c1f35;
    font-weight: 700;
}


/* ============================================================
   【index.html】サイト統計セクション（stats.htmlをinclude、
   絞り込みなしのトップ表示時のみ表示）
   ============================================================ */
.stats-section {
    display: flex;
    gap: 16px;
    height: 70%;
}

/* 「総投稿数」「ハッシュタグ数」「最終更新日」の各カード */
.stats-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-top: 4px solid #0ea5e9;
    border-radius: 0 0 12px 12px;
    padding: 16px 10px;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.12);
    text-align: center;
}

.stats-icon {
    font-size: 20px;
    line-height: 1;
}

.stats-number {
    font-size: 26px;
    font-weight: 700;
    color: #0369a1;
    line-height: 1.2;
    letter-spacing: -0.03em;
}

.stats-label {
    font-size: 12px;
    color: #4a7a96;
    font-weight: 600;
    letter-spacing: 0.03em;
}


/* ------------------------------------------------------------
   【index.html】「📋 最新の記事」一覧見出し
   ------------------------------------------------------------
   注意: 同名クラス .posts-section-title は index.css 側でも
   フォントサイズ等を再定義している（index.css の定義が優先される）。
   ここではスマホ以外の基本デザインを担当。
   ------------------------------------------------------------ */
.posts-section-title {
    font-size: 16px;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 0 0 20px;
    text-align: left;
    letter-spacing: 0.02em;
    border-top: 100px;
}


/* ============================================================
   【about.html / howto.html 共通】静的情報ページのレイアウト
   ============================================================ */
.info-page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 36px 24px 60px;
    box-sizing: border-box;
}

/* ページ上部のアバター＋タイトル行 */
.info-page-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
}

.info-page-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 3px solid #bae6fd;
    background: #e0f2fe;
    flex-shrink: 0;
}

.info-page-title {
    font-size: 22px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0;
    text-align: left;
    letter-spacing: -0.02em;
}

/* 本文を囲むカード */
.info-page-body {
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 32px 36px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
    margin-bottom: 28px;
}

/* 本文内の各セクション（見出し＋段落のセット） */
.info-section {
    margin-bottom: 32px;
}

.info-section:last-child {
    margin-bottom: 0;
}

.info-section-title {
    font-size: 17px;
    font-weight: 700;
    color: #0c1f35;
    border-left: 4px solid #0ea5e9;
    padding-left: 12px;
    margin: 0 0 12px;
    text-align: left;
}

.info-section p {
    font-weight: 500;
    font-size: 15px;
    color: #2a4a5e;
    line-height: 1.8;
    margin: 0;
}

/* 「← トップに戻る」フッターボタン */
.info-page-footer {
    text-align: center;
}

.info-back-btn {
    display: inline-block;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    color: #0369a1;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.18s;
}

.info-back-btn:hover {
    background: #e0f2fe;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}


/* ============================================================
   【index.html】インページ検索エリア（search_area.htmlをinclude、常に表示）
   ジャンル選択＋キーワード入力を同時に指定できる検索フォーム
   ============================================================ */
.index-search-area {
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-radius: 12px;
    padding: 20px 24px 22px;
    margin-bottom: 30px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.index-search-title {
    font-size: 16px;
    font-weight: 700;
    color: #0369a1;
    margin: 0 0 18px;
    letter-spacing: 0.03em;
}

.index-search-form {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    flex-wrap: wrap;
}

.index-search-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.index-search-genre {
    flex: 0 0 180px;
}

.index-search-keyword {
    flex: 1 1 180px;
    min-width: 160px;
}

.index-search-action {
    flex: 0 0 auto;
}

/* 各入力欄のラベル（「ジャンル」「キーワード」） */
.index-search-label {
    font-size: 12px;
    font-weight: 700;
    color: #4a7a96;
    letter-spacing: 0.02em;
    white-space: nowrap;
}

/* 検索ボタン列でラベルと縦位置を揃えるための空白スペーサー（PCのみ） */
.index-search-label-spacer {
    display: block;
    height: 18px;
    pointer-events: none;
}

/* ------------------------------------------------------------
   【index.html】検索エリア内「ジャンル」セレクトボックス
   ------------------------------------------------------------ */
.index-search-select-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

.index-search-select {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    padding: 10px 36px 10px 14px;
    font-size: 14px;
    color: #0c1f35;
    background: #f0f9ff;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    outline: none;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.18s, background 0.18s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.index-search-select:focus {
    border-color: #0ea5e9;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* セレクトボックスのカスタム矢印アイコン */
.index-search-select-arrow {
    position: absolute;
    right: 10px;
    width: 16px;
    height: 16px;
    color: #4a7a96;
    pointer-events: none;
    flex-shrink: 0;
    transition: color 0.18s;
}

.index-search-select-wrap:focus-within .index-search-select-arrow {
    color: #0ea5e9;
}

/* ------------------------------------------------------------
   【index.html】検索エリア内「キーワード」テキスト入力欄
   ------------------------------------------------------------ */
.index-search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

/* 入力欄左側の虫眼鏡アイコン */
.index-search-input-icon {
    position: absolute;
    left: 12px;
    width: 16px;
    height: 16px;
    color: #7dd3fa;
    pointer-events: none;
    flex-shrink: 0;
    transition: color 0.18s;
}

.index-search-input-wrap:focus-within .index-search-input-icon {
    color: #0ea5e9;
}

.index-search-input {
    width: 100%;
    padding: 10px 36px 10px 36px;
    font-size: 14px;
    color: #0c1f35;
    background: #f0f9ff;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    outline: none;
    font-family: inherit;
    box-sizing: border-box;
    transition: border-color 0.18s, background 0.18s;
}

.index-search-input:focus {
    border-color: #0ea5e9;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

.index-search-input::placeholder {
    color: #7ab8d8;
}

/* 入力内容をクリアする「✕」ボタン
   ------------------------------------------------------------
      初期状態は非表示。入力値の有無に応じて JS（updateClear）が
      インラインで flex / none を切り替える。ページロード時にも
      updateClear() が走るため、値がある場合は正しく表示される。 */
.index-search-clear {
    position: absolute;
    right: 8px;
    display: none;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: none;
    border: none;
    border-radius: 50%;
    color: #7ab8d8;
    font-size: 13px;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.15s, background 0.15s;
}

.index-search-clear:hover {
    color: #c0392b;
    background: #fff0ee;
}

/* ------------------------------------------------------------
   【index.html】検索エリア内「検索する」ボタン・「絞り込みを解除」リンク
   ------------------------------------------------------------ */
.index-search-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 22px;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
    background: #0ea5e9;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: background-color 0.18s, transform 0.13s;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
    min-height: 42px;
}

.index-search-btn:hover {
    background: #0369a1;
    transform: translateY(-1px);
}

.index-search-btn:active {
    transform: translateY(0);
    background: #075985;
}

.index-search-reset {
    display: inline-block;
    margin-top: 6px;
    font-size: 12px;
    font-weight: 600;
    color: #c0392b;
    text-decoration: none;
    padding: 4px 10px;
    border: 1px solid #f5b7b1;
    border-radius: 20px;
    background: #ffffff;
    transition: all 0.15s;
    white-space: nowrap;
}

.index-search-reset:hover {
    background: #fff0ee;
    border-color: #e74c3c;
    color: #a93226;
    text-decoration: none;
}


/* ==========================================================================
   【共通】レスポンシブ（スマホ）
   ========================================================================== */

@media (max-width: 600px) {
    /* --- hero（自己紹介）セクション --- */
    .hero-section {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        padding: 20px 16px;
    }

    .hero-avatar img {
        width: 64px;
        height: 64px;
    }

    .hero-name {
        font-size: 17px;
    }

    .hero-bio {
    font-weight: 500;
        font-size: 14px;
    }

    .hero-links {
        flex-direction: column;
        gap: 17px;
    }

    .hero-link-btn {
        text-align: center;
    }

    /* --- howto セクション（現状未使用） --- */
    .howto-section {
        padding: 18px 16px;
    }

    .howto-title {
        font-size: 15px;
    }

    .howto-item {
    font-weight: 500;
        font-size: 13px;
        gap: 10px;
    }

    .howto-icon {
        font-size: 18px;
    }

    /* --- stats（統計）セクション --- */
    .stats-section {
        gap: 10px;
    }

    .stats-card {
        padding: 14px 8px;
    }

    .stats-icon {
        font-size: 18px;
    }

    .stats-number {
        font-size: 20px;
    }

    .stats-label {
        font-size: 11px;
    }

    /* --- about/howto 静的ページ共通レイアウト --- */
    .info-page-container {
        padding: 20px 0 48px;
    }

    .info-page-header {
        padding: 0 16px;
        gap: 14px;
        margin-bottom: 20px;
    }

    .info-page-avatar {
        width: 56px;
        height: 56px;
    }

    .info-page-title {
        font-size: 18px;
    }

    .info-page-body {
        padding: 24px 16px;
        border-radius: 0 10px 10px 0;
    }

    .info-section-title {
