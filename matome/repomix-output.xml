/* ============================================================
   static/css/base.css - Coastal Dawn v2（白ヘッダー・視認性改善版 / ヘッダー固定化対応）
   【対象ページ】 base.html（全ページ共通のレイアウト・ヘッダー・ドロワー）
   ============================================================
   ※ ヘッダーのキーワード検索ボックスは廃止済み。
      キーワード検索は index ページの検索エリア
      （search_area.html / top_sections.css）に一本化した。
   ============================================================ */

/* ------------------------------------------------------------
   【共通】グローバルリセット
   ------------------------------------------------------------ */
*, *::before, *::after {
    box-sizing: border-box;
}


/* ------------------------------------------------------------
   【共通レイアウト】ページ背景（html要素）
   ------------------------------------------------------------ */
html {
    background-color: #f0f9ff;
}


/* ------------------------------------------------------------
   【共通レイアウト】ページ背景（body要素）
   ------------------------------------------------------------ */
body {
    font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Noto Sans JP", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #2a4a5e;
    background-color: #f0f9ff;
    line-height: 1.7;
    font-weight: 500;
    margin: 0;
    padding: 0;
    padding-top: 85px;   
    min-height: 100vh;   
    min-height: 100dvh;  
    -webkit-font-smoothing: antialiased;
    /* ダークモード切り替え時に背景・文字色をなめらかに変化させる */
    transition: background-color 0.25s ease, color 0.25s ease;
}

/* ------------------------------------------------------------
   【共通】見出し（h2）の汎用スタイル
   ------------------------------------------------------------ */
h2 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 24px 0;
    text-align: center;
    color: #0c1f35;
}

/* ------------------------------------------------------------
   【共通】リンクの基本スタイル
   ------------------------------------------------------------ */
a {
    color: #0369a1;
    text-decoration: none;
}

a:hover {
    color: #0ea5e9;
    text-decoration: underline;
}


/* ------------------------------------------------------------
   【共通】フラッシュメッセージ（ログイン成功／エラー通知など）
   ------------------------------------------------------------ */
.flash-messages {
    list-style: none;
    padding: 0;
    max-width: 680px;
    margin: 16px auto;
    text-align: center;
}

.flash-messages li {
    font-size: 14px;
    color: #033f5f;
    background-color: #f4fbff;
    border: 1px solid #7dd3fa;
    padding: 10px 16px;
    margin-bottom: 8px;
    border-radius: 6px;
}

.flash-messages li.danger {
    color: #922b21;
    background-color: #fff0ee;
    border: 1px solid #f5b7b1;
}


/* ============================================================
   【共通ヘッダー】ヘッダー本体（固定ヘッダー）
   ============================================================ */
.main-header {
    background-color: #ffffff;
    border-bottom: 3px solid #0ea5e9;
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transform: translateY(0);
    visibility: visible;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0s,
                background-color 0.25s ease,
                border-color 0.25s ease;
}

/* 下スクロール時にヘッダーを画面外へスライドアウトさせる状態（JSが付与） */
.main-header.header-hidden {
    transform: translateY(-100%);
    visibility: hidden;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0.2s;
}

/* ヘッダー内側のレイアウト（ロゴ／ナビを横並びに配置） */
.header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    height: 85px;
    gap: 24px;
}

/* ------------------------------------------------------------
   【共通ヘッダー】ヘッダー右側の操作群
   ------------------------------------------------------------
   ナビ・テーマ切り替えボタン・ハンバーガーを1つの塊にまとめ、
   ロゴ（左）と右側操作群（右）を space-between で両端に配置する。
   ------------------------------------------------------------ */
.header-right {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 0 0 auto;
}

/* ------------------------------------------------------------
   【共通ヘッダー】ロゴ（「MIT Blog」）
   ------------------------------------------------------------
   ロゴは Noto Serif JP（明朝体）のインク色（#0c1f35）。
   白背景上でくっきりと読める十分なコントラストを確保。
   ------------------------------------------------------------ */
.header-logo {
    flex: 0 0 auto;
}

.header-logo a {
    color: #0c1f35 !important;
    text-decoration: none !important;
    font-size: 35px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    display: block;
}

.header-logo a:hover {
    color: #0369a1 !important;
    text-decoration: none !important;
}

/* ------------------------------------------------------------
   【共通ヘッダー】PC用ナビゲーション（新規投稿／ジャンル検索／自己紹介／マイページ／ログアウト）
   ------------------------------------------------------------
   白背景上のナビリンク。テキストを #0369a1（濃いセルリアン）に設定し
   白背景でも確実に視認できるコントラストを確保。
   ------------------------------------------------------------ */
.header-nav {
    flex: 0 0 auto;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.header-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.header-nav ul li {
    display: inline-block;
    line-height: 1;
}

.header-nav ul li a {
    color: #0369a1;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 20px;
    background-color: #e0f2fe;
    border: 1px solid #38bdf8;
    transition: all 0.18s ease;
    display: inline-block;
    white-space: nowrap;
}

.header-nav ul li a:hover {
    color: #0c1f35;
    border-color: #0ea5e9;
    background-color: #bae6fd;
    text-decoration: none;
}

/* 先頭の「新規投稿」だけセルリアン塗りつぶしで強調 */
.header-nav ul li:first-child a {
    background-color: #0ea5e9;
    color: #ffffff;
    border-color: #0ea5e9;
    font-weight: 700;
}

.header-nav ul li:first-child a:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #ffffff;
}


/* ------------------------------------------------------------
   【共通ヘッダー】ダークモード切り替えボタン（🌙 / ☀️）
   ------------------------------------------------------------
   PC・スマホ共通で常時表示。クリックで data-theme を切り替え、
   選択内容は localStorage に保存される（JS は base.html 側）。
   ------------------------------------------------------------ */
.theme-toggle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border-radius: 50%;
    border: 1.5px solid #38bdf8;
    background-color: #e0f2fe;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    flex-shrink: 0;
    transition: background-color 0.18s ease, border-color 0.18s ease, transform 0.13s ease;
}

.theme-toggle-btn:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    transform: translateY(-1px);
}

.theme-toggle-btn:active {
    transform: translateY(0);
    background-color: #7dd3fa;
}

.theme-toggle-icon {
    display: block;
    pointer-events: none;
}


/* ------------------------------------------------------------
   【共通ヘッダー】ハンバーガーボタン（スマホ・PC非表示のメニュー開閉ボタン）
   ------------------------------------------------------------
   白ヘッダー上のハンバーガーラインはセルリアン系の濃い色で視認性を確保。
   ------------------------------------------------------------ */
.hamburger-btn {
    display: none;
    background: none;
    border: 1.5px solid #bae6fd;
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
}

.hamburger-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #0369a1;
    border-radius: 2px;
    transition: all 0.25s ease;
}


/* ============================================================
   【共通ヘッダー】スマホ用ドロワーメニュー（ハンバーガーで開閉）
   ============================================================ */

/* 背景を暗く覆うオーバーレイ */
.mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(12, 31, 53, 0.45);
    z-index: 999;
}

.mobile-nav-overlay.open {
    display: block;
}

/* 右からスライドインするドロワー本体 */
.mobile-nav-drawer {
    position: fixed;
    top: 0;
    right: -290px;
