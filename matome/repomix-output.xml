/* static/css/base.css - 水色×白 爽やかテーマ版 v2（差し色・視認性改善） */

*, *::before, *::after {
    box-sizing: border-box;
}

body {
    font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Noto Sans JP", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #2a4a5e;
    background-color: #e1f4ff;
    line-height: 1.7;
    margin: 0;
    padding: 0;
    -webkit-font-smoothing: antialiased;
}

h2 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 24px 0;
    text-align: center;
    color: #0d3a52;
}

a {
    color: #2a4a5e;
    text-decoration: none;
}

a:hover {
    color: #1a7aad;
    text-decoration: underline;
}

/* ===========================
   フラッシュメッセージ
   =========================== */
.flash-messages {
    list-style: none;
    padding: 0;
    max-width: 680px;
    margin: 16px auto;
    text-align: center;
}

/* success / info → 水色系 */
.flash-messages li {
    font-size: 14px;
    color: #033f5f;
    background-color: #f4fbff;
    border: 1px solid #5db4e0;
    padding: 10px 16px;
    margin-bottom: 8px;
    border-radius: 6px;
}

/* danger カテゴリ（Flaskの flash(..., 'danger')）*/
.flash-messages li.danger {
    color: #922b21;
    background-color: #fff0ee;
    border: 1px solid #f5b7b1;
}

/* ===========================
   ヘッダー
   =========================== */
.main-header {
    background-color: #ffffff;
    border-bottom: 1px solid #c5dff0;
    width: 100%;

    /* ===== スクロール連動の核心部分 ===== */
    position: sticky;      /* スクロールに追従して画面上部に固定 */
    top: 0;
    z-index: 100;

    /* transform で Y 方向に動かすことでヘッダーをスライドイン/アウトさせる。
       visibility を合わせることでスクリーンリーダーや Tab キー移動からも隠す。
       transition は cubic-bezier で自然な加速感を出している。 */
    transform: translateY(0);
    visibility: visible;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0s;
}

/* JS が付与するクラス: ヘッダーを画面外（上方向）へ追い出す */
.main-header.header-hidden {
    transform: translateY(-100%);
    /* visibility の遅延: transform アニメーションが終わってから hidden にする
       （アニメーション中はまだ見えているので visibility=hidden にしてはいけない）*/
    visibility: hidden;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0.2s;
}

