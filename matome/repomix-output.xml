<file path="static/css/detail.css">
/* ============================================================
   static/css/detail.css - Coastal Dawn v2
   【対象ページ】 detail.html（記事詳細ページ）
   ============================================================
   このファイルは記事詳細ページ専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【detail.html】ページ全体のコンテナ
   ------------------------------------------------------------ */
.detail-container {
    max-width: 860px !important;
    margin: 0 auto;
    padding: 36px 32px 60px;
    box-sizing: border-box;
}

/* ------------------------------------------------------------
   【detail.html】記事本文カード（一覧カードと左アクセントラインで統一）
   ------------------------------------------------------------ */
article {
    background: #fff;
    padding: 52px 60px;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    margin-bottom: 32px;
    box-sizing: border-box;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

/* ------------------------------------------------------------
   【detail.html】記事タイトル
   ------------------------------------------------------------ */
h1 {
    font-size: 24px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0 0 20px;
    text-align: left;
    line-height: 1.4;
    letter-spacing: -0.02em;
}

/* ------------------------------------------------------------
   【detail.html】ジャンルバッジ（クリックでジャンル絞り込みへ遷移するリンク）
   ------------------------------------------------------------ */
.genre-badge {
    display: inline-block;
    background-color: #dbeafe;
    color: #0369a1;
    padding: 2px 7px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 8px;
    font-weight: 600;
    border: 1px solid #38bdf8;
    text-decoration: none;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
}

.genre-badge:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}

/* ------------------------------------------------------------
   【detail.html】ジャンルバッジ＋ハッシュタグを1行に並べる行
   ------------------------------------------------------------
   ジャンルバッジを左端に、その右にハッシュタグが並ぶ形にする。
   （旧: ジャンルとハッシュタグが別々の行に分かれていたのを一体化）
   ------------------------------------------------------------ */
.detail-tag-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-bottom: 5px;
}

/* 行内に並べるジャンルバッジは、単体表示用の下マージン（margin-bottom: 8px）を
   打ち消して、ハッシュタグと高さ・縦位置をそろえる */
.detail-tag-row .genre-badge {
    margin-bottom: 0;
}

/* ------------------------------------------------------------
   【detail.html】メタ情報エリア（ジャンル・投稿者・日時・ハッシュタグをまとめる領域）
   ------------------------------------------------------------ */
.post-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
    font-size: 13px;
    color: #4a7a96;
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e0f2fe;
    width: 100%;
}

/* 投稿者アイコン＋ニックネーム表示 */
.post-user-info {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #0369a1;
    font-weight: 600;
    font-size: 12px;
}

.post-user-info img {
    width: 21px;
    height: 21px;
    border-radius: 50%;
    background: #dbeafe;
    border: 1px solid #7dd3fa;
    margin: 0 !important;
}

/* 投稿日時・更新日時テキスト */
.post-time { color: #4a7a96; font-size: 12px; }

/* ============================================================
   【detail.html】目次（本文中の [toc] マーカーから自動生成）
   ============================================================ */
.post-toc,
.detail-article-body .toc {
    background-color: #f0f9ff !important;
    border: 1px solid #7dd3fa !important;
    border-left: 4px solid #0ea5e9 !important;
    border-radius: 0 8px 8px 0;
    padding: 20px 24px;
    margin: 36px 0;
    box-sizing: border-box;
}

/* 本文中の[toc]位置に挿入された目次の見出しラベル */
.detail-article-body .toc::before {
    content: "目次" !important;
    display: block !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    margin: 0 0 14px !important;
    color: #0c1f35 !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

/* 記事先頭に自動表示される目次の見出しラベル（[toc]未使用時） */
.post-toc .toc-title, .toc-fixed .toc-title, .toc-sticky .toc-title {
    display: block !important;
    font-weight: 700 !important;
    font-size: 16px !important;
    margin: 0 0 14px !important;
    color: #0c1f35 !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

.post-toc > ul, .post-toc .toc > ul, .detail-article-body .toc > ul {
    list-style-type: none !important;
    padding-left: 0 !important;
    margin: 0 !important;
    text-align: left !important;
    display: block !important;
}

/* 本文中の見出し（H1〜H3）に、固定ヘッダー分のスクロール余白を確保 */
.detail-article-body h1,
.detail-article-body h2,
.detail-article-body h3 { scroll-margin-top: 100px; }

.post-toc > ul > li, .post-toc .toc > ul > li, .detail-article-body .toc > ul > li {
    text-align: left !important;
    margin-bottom: 0 !important;
    padding: 11px 0 !important;
    font-size: 15px !important;
    font-weight: bold !important;
    display: block !important;
    background: none !important;
    border: none !important;
    border-bottom: 1px solid #bae6fd !important;
    color: #0c1f35 !important;
}

.post-toc ul ul, .post-toc .toc ul ul, .detail-article-body .toc ul ul {
    list-style-type: none !important;
    padding-left: 20px !important;
    margin: 6px 0 0 !important;
    display: block !important;
}

.post-toc ul ul li, .post-toc .toc ul ul li, .detail-article-body .toc ul ul li {
    font-size: 14px !important;
    font-weight: normal !important;
    padding: 4px 0 !important;
    border-bottom: none !important;
    position: relative !important;
    display: block !important;
    color: #2a4a5e !important;
}

.post-toc ul ul li::before, .post-toc .toc ul ul li::before, .detail-article-body .toc ul ul li::before {
    content: "•" !important;
    color: #38bdf8 !important;
    margin-right: 6px !important;
    font-size: 13px !important;
}

.post-toc > ul > li:last-child, .post-toc .toc > ul > li:last-child, .detail-article-body .toc > ul > li:last-child {
    margin-bottom: 0 !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

.post-toc > ul > li:first-child, .post-toc .toc > ul > li:first-child, .detail-article-body .toc > ul > li:first-child {
    padding-top: 4px !important;
}

.post-toc a, .detail-article-body .toc a {
    color: #0369a1 !important;
    text-decoration: none !important;
    transition: color 0.15s !important;
    display: inline-block !important;
}

.post-toc a:hover, .detail-article-body .toc a:hover {
    color: #0ea5e9 !important;
    text-decoration: underline !important;
}

/* ============================================================
   【detail.html】記事本文（Markdown→HTML変換後のテキスト）
   ============================================================ */
.detail-article-body {
    font-weight: 400;
    font-size: 17px;
    line-height: 1.8;
    word-break: break-word;
    text-align: left;
    white-space: normal;
    color: #1e3a4f;
}

.detail-article-body strong { font-weight: 700 !important; color: #0c1f35; }

.detail-article-body p { margin-top: 9px !important; margin-bottom: 1.4em; font-size: 17px; font-weight: 400; }

.detail-article-body h2 {
    font-size: 22px;
    font-weight: 700;
    border-bottom: 2px solid #7dd3fa;
    padding-bottom: 6px;
    margin: 40px 0 16px;
    text-align: left;
    color: #0c1f35;
}

.detail-article-body h3 {
    font-size: 19px;
    font-weight: 700;
    margin: 28px 0 0;
    text-align: left;
    color: #0c1f35;
    border-left: 4px solid #0ea5e9;
    padding-left: 10px;
}

/* 本文内の画像共通スタイル */
article img { max-width: 100%; height: auto; display: block; margin: 25px auto; border-radius: 5px; }

/* ------------------------------------------------------------
   【detail.html】本文内の画像キャプション（[imgN]＋キャプション文）
   ------------------------------------------------------------ */
.post-figure { display: block; margin: 16px auto 8px; text-align: center; }
.post-figure img { max-width: 100% !important; height: auto !important; display: block !important; margin: 0 auto !important; border-radius: 5px; }
.post-figcaption { margin-top: 6px; text-align: center !important; font-size: 15px; color: #0369a1; line-height: 1.5; display: block; width: 100%; }
.post-figure + p { margin-top: 0.6em; }

/* ------------------------------------------------------------
   【detail.html】本文内の地図埋め込み（[map:場所名]タグから生成）
   ------------------------------------------------------------ */
.post-map-wrapper { margin: 24px 0; border-radius: 0 10px 10px 0; overflow: hidden; border: 1.5px solid #7dd3fa; border-left: 4px solid #0ea5e9; box-shadow: 0 3px 10px rgba(14, 165, 233, 0.10); }
.post-map-label { padding: 8px 14px; font-size: 13px; font-weight: 600; color: #0369a1; background: #f0f9ff; border-bottom: 1px solid #7dd3fa; }
.post-map-iframe { width: 100%; height: 380px; border: none; display: block; }

/* ------------------------------------------------------------
   【detail.html】本文内のYouTube埋め込み（[youtube:URL]タグから生成、
   サムネイルをタップすると再生が始まる「ファサード」形式）
   ------------------------------------------------------------ */
.post-youtube-wrapper { margin: 24px 0; border-radius: 10px; overflow: hidden; border: 1px solid #7dd3fa; box-shadow: 0 3px 10px rgba(14, 165, 233, 0.10); position: relative; width: 100%; aspect-ratio: 16 / 9; background: #000; }
.post-youtube-facade { position: absolute; inset: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.post-youtube-thumb { width: 100%; height: 100%; object-fit: cover; display: block; transition: filter 0.2s ease; }
.post-youtube-facade:hover .post-youtube-thumb { filter: brightness(0.85); }
.post-youtube-play-btn { position: absolute; background: none; border: none; cursor: pointer; padding: 0; transition: transform 0.15s ease; }
.post-youtube-facade:hover .post-youtube-play-btn { transform: scale(1.1); }
.yt-btn-bg { fill: #ff0000; fill-opacity: 0.9; transition: fill-opacity 0.15s ease; }
.post-youtube-facade:hover .yt-btn-bg { fill-opacity: 1; }
.yt-btn-icon { fill: #fff; }
.post-youtube-iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; display: block; }

/* ------------------------------------------------------------
   【detail.html】本文下の区切り線
   ------------------------------------------------------------ */
hr { border: 0; border-top: 1px solid #e0f2fe; margin: 0 0 24px; }

/* ------------------------------------------------------------
   【detail.html】「前の画面に戻る」「この記事を編集する」ボタン行
   ------------------------------------------------------------ */
.detail-actions { display: flex; justify-content: center; align-items: center; gap: 12px; padding: 4px 0 32px; flex-wrap: wrap; }

.detail-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 11px 24px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background-color 0.18s, border-color 0.18s, color 0.18s, box-shadow 0.18s, transform 0.13s;
    white-space: nowrap;
    min-height: 44px;
    line-height: 1;
}

.detail-btn-icon { width: 17px; height: 17px; flex-shrink: 0; }

/* 「前の画面に戻る」ボタン（白背景） */
.detail-btn-back {
    background-color: #ffffff;
    color: #4a7a96;
    border: 1px solid #7dd3fa;
    box-shadow: 0 1px 4px rgba(14, 165, 233, 0.08);
}

.detail-btn-back:hover {
    background-color: #f0f9ff;
    border-color: #38bdf8;
    color: #0c1f35;
    box-shadow: 0 3px 10px rgba(14, 165, 233, 0.14);
    transform: translateY(-1px);
}

.detail-btn-back:active { transform: translateY(0); box-shadow: none; background-color: #dbeafe; }

/* 「この記事を編集する」ボタン（セルリアン塗りつぶし・投稿者本人のみ表示） */
.detail-btn-edit {
    background-color: #0ea5e9;
    color: #ffffff;
    border: 1px solid #0ea5e9;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
}

.detail-btn-edit:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #ffffff;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.30);
    transform: translateY(-1px);
    text-decoration: none;
}

.detail-btn-edit:active { transform: translateY(0); box-shadow: none; background-color: #075985; }

/* ============================================================
   【detail.html】関連記事セクション（記事末尾、最大4件表示）
   ============================================================ */
.related-section { margin-top: 20px; padding-top: 8px; }

.related-heading {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 20px;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 32px 0 14px;
    text-align: left;
    letter-spacing: 0.02em;
}

.related-heading-icon { font-size: 16px; flex-shrink: 0; }

/* 「📂○○ / #タグ を表示中」のサブラベルバッジ */
.related-heading-sub {
    font-size: 13px;
    font-weight: 500;
    color: #0369a1;
    background: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 10px;
    padding: 2px 10px;
    margin-left: 4px;
    white-space: nowrap;
    letter-spacing: 0;
    line-height: 1.6;
    flex-shrink: 0;
}

.related-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }

/* 関連記事カード（一覧カードと同じ左アクセントラインデザイン、ホバーでゴールドに変化） */
.related-card {
    display: flex;
    align-items: center;
    gap: 18px;
    background: #fff;
    border: 1.5px solid #7dd3fa;
    border-left: 4px solid #0ea5e9;
    border-radius: 0 10px 10px 0;
    padding: 14px 18px 14px 14px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.18s, border-color 0.18s, background 0.18s, transform 0.15s;
    overflow: hidden;
}

.related-card:hover {
    border-left-color: #f59e0b;
    border-color: #fbbf24;
    background: #fffbeb;
    box-shadow: 0 6px 20px rgba(245, 158, 11, 0.15);
    transform: translateY(-1px);
    text-decoration: none;
    color: inherit;
}

.related-thumb {
    flex: 0 0 120px;
    width: 120px;
    height: 85px;
    border-radius: 6px;
    overflow: hidden;
    background: #dbeafe;
    border: 1px solid #7dd3fa;
    transition: border-color 0.18s;
}

.related-card:hover .related-thumb { border-color: #fbbf24; background: #fef3c7; }

.related-thumb img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; margin: 0 !important; border-radius: 0; }

.related-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }

.related-title {
    font-size: 15px;
    font-weight: 600;
    color: #0c1f35;
    line-height: 1.45;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
}

.related-card:hover .related-title { color: #0369a1; }
.related-date { font-size: 12px; color: #0369a1; margin: 0; font-weight: 500; }

/* ------------------------------------------------------------
   【detail.html】後方互換用の旧ボタンデザイン（現状未使用の予備クラス）
   ------------------------------------------------------------ */
.detail-ul { display: flex; justify-content: center; gap: 16px; padding: 0; margin: 0; list-style: none; flex-wrap: wrap; }
.detail-ul-li { background: none; border: none; padding: 0; }
.detail-ul-li-a { font-size: 14px; color: #0369a1; text-decoration: none; padding: 10px 22px; border: 1px solid #7dd3fa; border-radius: 20px; display: inline-block; transition: all 0.18s; background: none; cursor: pointer; font-family: inherit; }
.detail-ul-li-a:hover { border-color: #0ea5e9; color: #0c1f35; background: #dbeafe; text-decoration: none; }

/* ------------------------------------------------------------
   【detail.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .detail-container { padding: 16px 0 48px !important; width: 100% !important; overflow-x: hidden; }
    article { padding: 28px 16px; border-radius: 0 10px 10px 0; border-left: none; border-right: none; margin-bottom: 16px; }
    h1 { font-size: 20px; letter-spacing: -0.01em; line-height: 1.45; }
    .post-meta { font-size: 12px; margin-bottom: 24px; padding-bottom: 16px; }
    .post-user-info { font-size: 13px; }
    .detail-article-body {
    font-weight: 500; font-size: 15px !important; line-height: 1.75 !important; word-break: break-all; }
    .detail-article-body p { margin-top: 9px !important; margin-bottom: 1.4em; font-size: 15px; }
    .detail-article-body pre, .detail-article-body code, .detail-article-body table { max-width: 100% !important; overflow-x: auto !important; display: block; word-break: normal; }
    .detail-article-body h2 { font-size: 18px; margin: 32px 0 12px; }
    .detail-article-body h3 { font-size: 16px; margin: 24px 0 0; padding-left: 8px; }
    .post-toc, .detail-article-body .toc { padding: 16px !important; border-radius: 0 6px 6px 0 !important; margin: 24px 0 !important; }
    .post-toc > ul > li, .post-toc .toc > ul > li, .detail-article-body .toc > ul > li { font-size: 14px !important; padding: 10px 0 !important; }
    .post-toc ul ul, .post-toc .toc ul ul, .detail-article-body .toc ul ul { padding-left: 16px !important; margin: 4px 0 0 !important; }
    .post-toc ul ul li, .post-toc .toc ul ul li, .detail-article-body .toc ul ul li { font-size: 13px !important; padding: 5px 0 !important; }
    .post-map-iframe { height: 260px; }
    .post-youtube-wrapper { border-radius: 6px; margin: 16px 0; }
    hr { margin: 0 16px 20px; }
    .detail-actions { flex-direction: column; gap: 10px; padding: 0 16px 28px; }
    .detail-btn { width: 100%; justify-content: center; padding: 13px 24px; font-size: 15px; border-radius: 8px; box-sizing: border-box; }
    .detail-ul { flex-direction: column; align-items: center; gap: 12px; padding: 0 16px 12px; box-sizing: border-box; }
    .detail-ul-li { width: 100%; }
    .detail-ul-li-a { font-size: 15px; padding: 13px 24px; display: block; text-align: center; width: 100%; box-sizing: border-box; min-height: 48px; }
    .post-figure { margin: 12px auto 6px; }
    .post-figcaption { font-size: 12px; }
    .related-section { margin-top: 28px; padding: 0 0 8px; }
    .related-heading { font-size: 16px; margin: 24px 0 12px; padding-bottom: 8px; }
    .related-heading-sub { margin-left: 0; font-size: 11px; }
    .related-list { gap: 8px; }
    .related-card { gap: 14px; padding: 12px 14px 12px 12px; border-radius: 0 8px 8px 0; }
    .related-thumb { flex: 0 0 100px; width: 100px; height: 70px; }
    .related-title { font-size: 14px; }
    .related-date { font-size: 12px; }
}
