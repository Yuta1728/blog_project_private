}
html[data-theme="dark"] .map-modal-title {
    color: var(--dk-text);
}
html[data-theme="dark"] .map-modal-close {
    color: var(--dk-text-muted);
}
html[data-theme="dark"] .map-modal-close:hover {
    background: var(--dk-surface-3);
    color: var(--dk-text);
}
html[data-theme="dark"] .map-modal-label {
    color: var(--dk-link);
}
html[data-theme="dark"] .map-preview-area {
    background: var(--dk-surface-2);
    border-color: var(--dk-border);
}
html[data-theme="dark"] .map-modal-footer {
    border-top-color: var(--dk-border);
}


/* ============================================================
   [11] ジャンル一覧ページ
   ============================================================ */
html[data-theme="dark"] .genre-item-all a {
    color: var(--dk-link);
    border-bottom-color: var(--dk-border);
}
html[data-theme="dark"] .genre-item-all a:hover {
    background: var(--dk-surface-3);
    color: var(--dk-text);
}
html[data-theme="dark"] .genre-group {
    border-bottom-color: var(--dk-border);
}
html[data-theme="dark"] .group-title:hover,
html[data-theme="dark"] details[open] .group-title {
    background: var(--dk-surface-2);
    color: var(--dk-text);
}
html[data-theme="dark"] details[open] .group-title {
    border-bottom-color: var(--dk-border);
}
html[data-theme="dark"] .sub-genre-list {
    background: var(--dk-surface-2);
}
html[data-theme="dark"] .sub-genre-list li a {
    color: var(--dk-link);
}
html[data-theme="dark"] .sub-genre-list li a:hover {
    background: var(--dk-surface-3);
    color: var(--dk-text);
}


/* ============================================================
   [12] マイページ
   ============================================================ */
html[data-theme="dark"] .nickname-form-wrapper {
    border-top-color: var(--dk-border);
}
html[data-theme="dark"] .nickname-form-wrapper > p,
html[data-theme="dark"] .nickname-form label {
    color: var(--dk-text-muted);
}


/* ============================================================
   [13] ハッシュタグ絞り込みバー
   ============================================================ */
html[data-theme="dark"] .hashtag-filter-label {
    color: var(--dk-link);
}


/* ============================================================
   [14] アバター画像の縁・背景
   ============================================================ */
html[data-theme="dark"] .hero-avatar img,
html[data-theme="dark"] .info-page-avatar {
