.nickname-form-wrapper {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid #dff0fb;
}

.nickname-form-wrapper > p,
.nickname-form label {
    font-size: 13px;
    color: #5a8ba8;
    margin: 0 0 8px;
    font-weight: 500;
}

.nickname-form {
    display: flex;
    gap: 8px;
    align-items: center;
}

.nickname-input {
    flex: 1;
    min-width: 0;
    padding: 8px 14px;
    border: 1.5px solid #c5dff0;
    border-radius: 20px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.18s;
    background: #f5f9fd;
    color: #0d3a52;
