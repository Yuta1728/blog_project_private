.post-form input[type="submit"] {
    display: block;
    width: 100%;
    padding: 14px;
    background-color: #1a7aad;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.18s;
    font-family: inherit;
    letter-spacing: 0.02em;
}

.post-form input[type="submit"]:hover {
    background-color: #155f8a;
}

/* ===========================
   画像プレビュー
   =========================== */
.preview-item {
    position: relative;
    border: 1px solid #c5dff0;
    border-radius: 8px;
    overflow: hidden;
    background: #f5f9fd;
    width: 150px;
    margin-bottom: 8px;
}

.preview-item img {
    width: 150px;
    height: 112px;
    object-fit: cover;
