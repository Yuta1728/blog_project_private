<file path="static/css/detail.css">
/* static/css/detail.css - 水色×白 爽やかテーマ版 v2（差し色・視認性改善） */

.detail-container {
    max-width: 720px !important;
    margin: 0 auto;
    padding: 36px 24px 60px;
    box-sizing: border-box;
}

article {
    background: #fff;
    padding: 48px 52px;
    border: 1px solid #c5dff0;
    border-radius: 12px;
    margin-bottom: 32px;
    box-sizing: border-box;
    box-shadow: 0 4px 16px rgba(26, 122, 173, 0.07);
}

h1 {
    font-size: 25px;
    font-weight: 800;
    color: #0d3a52;
    margin: 0 0 20px;
    text-align: left;
    line-height: 1.4;
    letter-spacing: -0.02em;
}

/* ジャンルバッジ */
.genre-badge {
    background-color: #e7f7ff;
    color: #1a5f85;            /* 十分な濃さ */
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 8px;
    font-weight: 600;
    border: 1px solid #9fd0ec;
}

/* メタ情報エリア */
.post-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
    color: #5a8ba8;            /* #7aaec8より濃く、読みやすく */
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid #dff0fb;
    width: 100%;
}

.post-user-info {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #1a5f85;            /* 投稿者名は濃くして目立たせる */
    font-weight: 600;
    font-size: 12px;
}

.post-user-info img {
    width: 21px;
    height: 21px;
    border-radius: 50%;
    background: #dff0fb;
    border: 1px solid #c5dff0;
    margin: 0 !important;
}

/* 日付テキスト（視認性改善） */
.post-time {
    color: #5a8ba8;            /* #7aaec8→#5a8ba8 で読みやすく */
    font-size: 12px;
}

/* ===========================
   目次（TOC）視覚的差別化
   =========================== */
.post-toc,
.detail-article-body .toc {
    background-color: #f4fbff !important;
    border: 1px solid #90c6e8 !important;  /* 少し濃いボーダーで存在感 */
    border-left: 4px solid #1a7aad !important;  /* 左アクセントライン */
    border-radius: 8px;
    padding: 20px 24px;
    margin: 36px 0;
    box-sizing: border-box;
}

.detail-article-body .toc::before {
    content: "目次" !important;
    display: block !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    margin: 0 0 14px !important;
    color: #0d3a52 !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

.post-toc .toc-title,
.toc-fixed .toc-title,
.toc-sticky .toc-title {
    display: block !important;
    font-weight: 700 !important;
    font-size: 17px !important;
    margin: 0 0 14px !important;
    color: #0d3a52 !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

.post-toc > ul,
.post-toc .toc > ul,
.detail-article-body .toc > ul {
    list-style-type: none !important;
    padding-left: 0 !important;
    margin: 0 !important;
    text-align: left !important;
    display: block !important;
}

/* 目次のリンク先となる見出し（h1, h2, h3など）に一括適用 */
.detail-article-body h1,
.detail-article-body h2,
.detail-article-body h3 {
    /* 100px の部分を、あなたのサイトの固定ヘッダーの高さ（＋少しの余白）に調整してください */
    scroll-margin-top: 100px;
}

/* 大見出しリスト：文字を濃くして読みやすく */
.post-toc > ul > li,
.post-toc .toc > ul > li,
.detail-article-body .toc > ul > li {
    text-align: left !important;
    margin-bottom: 0 !important;
    padding: 11px 0 !important;
    font-size: 15px !important;
    font-weight: bold !important;
    display: block !important;
    background: none !important;
    border: none !important;
    border-bottom: 1px solid #9ccced !important;
    color: #0d3a52 !important;
}

.post-toc ul ul,
.post-toc .toc ul ul,
.detail-article-body .toc ul ul {
    list-style-type: none !important;
    padding-left: 20px !important;
    margin: 6px 0 0 !important;
    display: block !important;
}

/* 中見出し：黒に近い色で本文との差別化 */
.post-toc ul ul li,
.post-toc .toc ul ul li,
.detail-article-body .toc ul ul li {
    font-size: 14px !important;
    font-weight: normal !important;
    padding: 4px 0 !important;
    border-bottom: none !important;
    position: relative !important;
    display: block !important;
    color: #2a4a5e !important;  /* 読みやすい中間色 */
}

.post-toc ul ul li::before,
.post-toc .toc ul ul li::before,
.detail-article-body .toc ul ul li::before {
    content: "•" !important;
    color: #5a8ba8 !important;  /* 少し濃くして見えやすく */
    margin-right: 6px !important;
    font-size: 13px !important;
}

.post-toc > ul > li:last-child,
.post-toc .toc > ul > li:last-child,
.detail-article-body .toc > ul > li:last-child {
    margin-bottom: 0 !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

.post-toc > ul > li:first-child,
.post-toc .toc > ul > li:first-child,
.detail-article-body .toc > ul > li:first-child {
    padding-top: 4px !important;
}

/* 目次リンク */
.post-toc a,
.detail-article-body .toc a {
    color: #1a6a96 !important;  /* 明るすぎない青、リンクとして認識しやすい */
    text-decoration: none !important;
    transition: color 0.15s !important;
    display: inline-block !important;
}

.post-toc a:hover,
.detail-article-body .toc a:hover {
    color: #1a7aad !important;
    text-decoration: underline !important;
}

/* ===========================
   本文（読みやすさ優先）
   =========================== */
.detail-article-body {
    font-size: 18px;
    line-height: 1.8;
    word-break: break-word;
    text-align: left;
    white-space: normal;
    color: #1e3a4f;            /* 本文は最も濃い色で読みやすく */
}

.detail-article-body strong {
    font-weight: 700 !important;
    color: #0d3a52;
}

.detail-article-body p {
    margin-top: 9px !important;
    margin-bottom: 1.4em;
    font-size: 18px;
}

.detail-article-body h2 {
    font-size: 23px;
    font-weight: 700;
    border-bottom: 2px solid #b0d5ec;
    padding-bottom: 6px;
    margin: 40px 0 16px;
    text-align: left;
    color: #0d3a52;
}

.detail-article-body h3 {
    font-size: 20px;
    font-weight: 700;
    margin: 28px 0 0;
    text-align: left;
    color: #0d3a52;
    border-left: 3px solid #5aaedc;  /* H3に左ライン追加で差別化 */
    padding-left: 10px;
}

article img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 25px auto;
    border-radius: 5px;
}

/* ===========================
   フッター
   =========================== */
hr {
    border: 0;
    border-top: 1px solid #dff0fb;
    margin: 0 0 24px;
}

.detail-ul {
    display: flex;
    justify-content: center;
    gap: 16px;
    padding: 0;
    margin: 0;
    list-style: none;
    flex-wrap: wrap;
}

.detail-ul-li {
    background: none;
    border: none;
    padding: 0;
}

.detail-ul-li-a {
    font-size: 14px;
    color: #1a5f85;
    text-decoration: none;
    padding: 10px 22px;
    border: 1.5px solid #8cc8e8;
    border-radius: 20px;
    display: inline-block;
    transition: all 0.18s;
    background: none;
    cursor: pointer;
    font-family: inherit;
}

.detail-ul-li-a:hover {
    border-color: #1a7aad;
    color: #1a7aad;
    background: #dff0fb;
    text-decoration: none;
}

/* ===========================
   スマホ（〜767px）
   =========================== */
@media (max-width: 767px) {
    .detail-container {
        padding: 16px 0 48px !important;
        width: 100% !important;
        overflow-x: hidden;
    }

    article {
        padding: 28px 16px;
        border-radius: 0;
        border-left: none;
        border-right: none;
        margin-bottom: 16px;
    }

    h1 {
        font-size: 21px;
        letter-spacing: -0.01em;
        line-height: 1.45;
    }

    .post-meta {
        font-size: 12px;
        gap: 6px;
        margin-bottom: 24px;
        padding-bottom: 16px;
    }

    .post-user-info {
        font-size: 13px;
    }

    .detail-article-body {
        font-size: 16px !important;
        line-height: 1.75 !important;
        word-break: break-all;
    }

    .detail-article-body p {
        margin-top: 9px !important;
        margin-bottom: 1.4em;
        font-size: 16px;
    }

    .detail-article-body pre,
    .detail-article-body code,
    .detail-article-body table {
        max-width: 100% !important;
        overflow-x: auto !important;
        display: block;
        word-break: normal;
    }

    .detail-article-body h2 {
        font-size: 19px;
        margin: 32px 0 12px;
    }

    .detail-article-body h3 {
        font-size: 17px;
        margin: 24px 0 0;
        padding-left: 8px;
    }

    .post-toc,
    .detail-article-body .toc {
        padding: 16px !important;
        border-radius: 6px !important;
        margin: 24px 0 !important;
    }

    .post-toc > ul > li,
    .post-toc .toc > ul > li,
    .detail-article-body .toc > ul > li {
        font-size: 14px !important;
        padding: 10px 0 !important;
    }

    .post-toc ul ul,
    .post-toc .toc ul ul,
    .detail-article-body .toc ul ul {
        padding-left: 16px !important;
        margin: 4px 0 0 !important;
    }

    .post-toc ul ul li,
    .post-toc .toc ul ul li,
    .detail-article-body .toc ul ul li {
        font-size: 13px !important;
        padding: 5px 0 !important;
    }

    .post-toc ul ul li::before,
    .post-toc .toc ul ul li::before,
    .detail-article-body .toc ul ul li::before {
        font-size: 12px !important;
        margin-right: 5px !important;
    }

    hr {
        margin: 0 16px 20px;
    }

    .detail-ul {
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 0 16px 12px;
        box-sizing: border-box;
    }

    .detail-ul-li {
        width: 100%;
    }

    .detail-ul-li-a {
        font-size: 15px;
        padding: 13px 24px;
        display: block;
        text-align: center;
        width: 100%;
        box-sizing: border-box;
        min-height: 48px;
    }
}


/* ===========================
   画像キャプション表示（detail）
   =========================== */
.post-figure {
    display: block;
    /* 上下余白：article img の 25px より小さく抑える */
    margin: 16px auto 8px;
    text-align: center;
}

.post-figure img {
    max-width: 100% !important;
    height: auto !important;
    display: block !important;
    /* article img の margin: 25px auto を上書きして figure 内では詰める */
    margin: 0 auto !important;
    border-radius: 5px;
}

.post-figcaption {
    margin-top: 6px;
    /* figure 自体が text-align:center なので継承されるが、
       detail.css の .detail-article-body { text-align: left } を
       明示的に上書きして確実に中央寄せにする */
    text-align: center !important;
    font-size: 15px;
    color: #214f69;
    line-height: 1.5;
    display: block;
    width: 100%;
}

/* figure の直後の段落との余白も詰める */
.post-figure + p {
    margin-top: 0.6em;
}

@media (max-width: 767px) {
    .preview-caption-input {
        font-size: 14px;
    }

    .post-figure {
        margin: 12px auto 6px;
    }

    .post-figcaption {
        font-size: 12px;
    }
}


/* ==============================================
   detail.css への追記分
   post.body 中の [map:場所名] が変換された
   .post-map-wrapper / iframe のスタイル
   ============================================== */

.post-map-wrapper {
    margin: 24px 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #c5dff0;
    box-shadow: 0 3px 10px rgba(26, 122, 173, 0.09);
}

.post-map-label {
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #1a5f85;
    background: #f0faff;
    border-bottom: 1px solid #c5dff0;
}

.post-map-iframe {
    width: 100%;
    height: 380px;
    border: none;
    display: block;
}

@media (max-width: 767px) {
    .post-map-iframe {
        height: 260px;
    }
}


/* ==============================================
   detail.css への追記分
   [youtube:XXX] が変換された
   .post-youtube-wrapper のスタイル
   ============================================== */

.post-youtube-wrapper {
    margin: 24px 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #c5dff0;
    box-shadow: 0 3px 10px rgba(26, 122, 173, 0.09);
    /* 16:9 アスペクト比を維持するためにラッパーで高さを制御する */
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
}

/* ---- ファサード（サムネイル表示層）---- */
.post-youtube-facade {
    position: absolute;
    inset: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* サムネイル画像：コンテナ全体を覆う */
.post-youtube-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* サムネイルのホバー時に少し暗くして「クリックできる」感を演出 */
    transition: filter 0.2s ease;
}

.post-youtube-facade:hover .post-youtube-thumb {
    filter: brightness(0.85);
}

/* ---- 再生ボタン（YouTube 公式デザインに準拠した SVG）---- */
.post-youtube-play-btn {
    position: absolute;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    /* ホバー時にボタンを拡大してクリックしやすく */
    transition: transform 0.15s ease;
}

.post-youtube-facade:hover .post-youtube-play-btn {
    transform: scale(1.1);
}

/* SVG 内の赤い背景ボタン */
.yt-btn-bg {
    fill: #ff0000;
    fill-opacity: 0.9;
    transition: fill-opacity 0.15s ease;
}

.post-youtube-facade:hover .yt-btn-bg {
    fill-opacity: 1;
}

/* SVG 内の白い再生三角アイコン */
.yt-btn-icon {
    fill: #fff;
}

/* ---- 再生後に挿入される iframe ---- */
.post-youtube-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
}

/* ---- スマホ対応 ---- */
@media (max-width: 767px) {
    .post-youtube-wrapper {
        border-radius: 6px;
        margin: 16px 0;
    }
}



/* ==============================================
   関連記事セクション（detail.css 追記分）
   ============================================== */

.related-section {
    margin-top: 40px;
    padding-top: 8px;
}

/* セクション見出し */
.related-heading {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: #0d3a52;
    border-bottom: 2px solid #1a7aad;
    padding-bottom: 10px;
    margin: 32px 0 14px;
    text-align: left;
    letter-spacing: 0.02em;
}

.related-heading-icon {
    font-size: 16px;
    flex-shrink: 0;
}

/* 見出し右側のサブラベル（「〇〇 を表示中」） */
.related-heading-sub {
    font-size: 12px;
    font-weight: 500;
    color: #5a8ba8;
    background: #f0faff;
    border: 1px solid #c5dff0;
    border-radius: 20px;
    padding: 2px 10px;
    margin-left: 4px;
    white-space: nowrap;
    letter-spacing: 0;
    line-height: 1.6;
    flex-shrink: 0;
}

/* カードリスト */
.related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

/* 1件分のカード */
.related-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #fff;
    border: 1px solid #c5dff0;
    border-radius: 10px;
    padding: 10px 14px 10px 10px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.18s, border-color 0.18s, transform 0.15s;
    overflow: hidden;
}

.related-card:hover {
    border-color: #5aaedc;
    box-shadow: 0 4px 14px rgba(26, 122, 173, 0.12);
    transform: translateY(-1px);
    text-decoration: none;
    color: inherit;
}

/* サムネイル */
.related-thumb {
    flex: 0 0 88px;
    width: 88px;
    height: 60px;
    border-radius: 6px;
    overflow: hidden;
    background: #dff0fb;
    border: 1px solid #c5dff0;
}

.related-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    /* detail.css の article img に上書きされないよう明示 */
    margin: 0 !important;
    border-radius: 0;
}

/* テキストエリア */
.related-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.related-title {
    font-size: 14px;
    font-weight: 600;
    color: #0d3a52;
    line-height: 1.45;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    /* stylelint-disable-next-line */
    -webkit-line-clamp: 2;
    line-clamp: 2;
    /* stylelint-disable-next-line */
    -webkit-box-orient: vertical;
}

.related-card:hover .related-title {
    color: #1a7aad;
}

.related-date {
    font-size: 11px;
    color: #7aaec8;
    margin: 0;
}

/* ===========================
   スマホ（〜767px）
   =========================== */
@media (max-width: 767px) {
    .related-section {
        margin-top: 28px;
        padding: 0 0 8px;
    }

    .related-heading {
        font-size: 14px;
        margin: 24px 0 12px;
        padding-bottom: 8px;
    }

    .related-heading-sub {
        margin-left: 0;
        font-size: 11px;
    }

    .related-list {
        gap: 8px;
    }

    .related-card {
        gap: 10px;
        padding: 8px 10px 8px 8px;
        border-radius: 8px;
    }

    .related-thumb {
        flex: 0 0 72px;
        width: 72px;
        height: 52px;
    }

    .related-title {
        font-size: 13px;
    }

    .related-date {
        font-size: 11px;
    }
}


/* ==============================================
   記事下部ボタンエリア（detail.css 追記分）
   ============================================== */

.detail-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    padding: 4px 0 32px;
    flex-wrap: wrap;
}

/* ボタン共通ベース */
.detail-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 11px 24px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background-color 0.18s, border-color 0.18s,
                color 0.18s, box-shadow 0.18s, transform 0.13s;
    white-space: nowrap;
    min-height: 44px;
    line-height: 1;
}

.detail-btn-icon {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
}

/* 「前の画面に戻る」— アウトライン・グレー系 */
.detail-btn-back {
    background-color: #ffffff;
    color: #4a7a96;
    border: 1.5px solid #a8cfe0;
    box-shadow: 0 1px 4px rgba(26, 122, 173, 0.07);
}

.detail-btn-back:hover {
    background-color: #f0f8fd;
    border-color: #5aaedc;
    color: #0d3a52;
    box-shadow: 0 3px 10px rgba(26, 122, 173, 0.13);
    transform: translateY(-1px);
}

.detail-btn-back:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #dff0fb;
}

/* 「この記事を編集する」— 塗りつぶし・アクセントブルー */
.detail-btn-edit {
    background-color: #1a7aad;
    color: #ffffff;
    border: 1.5px solid #1a7aad;
    box-shadow: 0 2px 8px rgba(26, 122, 173, 0.22);
}

.detail-btn-edit:hover {
    background-color: #155f8a;
    border-color: #155f8a;
    color: #ffffff;
    box-shadow: 0 4px 14px rgba(26, 122, 173, 0.30);
    transform: translateY(-1px);
    text-decoration: none;
}

.detail-btn-edit:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #0f4a6e;
}

/* スマホ（〜767px） */
@media (max-width: 767px) {
    .detail-actions {
        flex-direction: column;
        gap: 10px;
        padding: 0 16px 28px;
    }

    .detail-btn {
        width: 100%;
        justify-content: center;
        padding: 13px 24px;
        font-size: 15px;
        border-radius: 8px;
        box-sizing: border-box;
    }
}
