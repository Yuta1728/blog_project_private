<file path="templates/index.html">
{% extends "base.html" %}
{% block content %}

<link rel="stylesheet" href="{{ url_for('static', filename='css/index.css') }}">
<link rel="stylesheet" href="{{ url_for('static', filename='css/top_sections.css') }}">


<div class="page-wrapper">

    {# ===== フィルターなし かつ 1ページ目のときだけ stats を表示 =====
       サーバー側ページネーションに変更したため、2ページ目以降で
       「統計」「最新の記事」「自己紹介」が繰り返し表示されないよう
       pagination.page == 1 の条件を追加している。 #}
    {% if not selected_genre and not search_word and not selected_hashtag and pagination.page == 1 %}
        {% include 'stats.html' %}
    {% endif %}
    {# ======================================================================= #}

    {# ===== インページ検索エリア（常に表示） ===== #}
    {% include 'search_area.html' %}
    {# ============================================ #}

    {% if selected_genre or search_word or selected_hashtag %}
        <p class="filter-label">
            🔍
            {% if search_word %}「{{ search_word }}」{% endif %}
            {% if selected_genre %}ジャンル「{{ selected_genre }}」{% endif %}
            {% if selected_hashtag %}ハッシュタグ「#{{ selected_hashtag }}」{% endif %}
            の検索結果
        </p>
    {% endif %}

    {# ===== ハッシュタグ絞り込みバー（ジャンル選択中のみ表示） ===== #}
    {% if selected_genre and hashtags_in_genre %}
        <div class="hashtag-filter-bar">
            <span class="hashtag-filter-label">🏷️ タグで絞り込む：</span>
            <div class="hashtag-filter-list">
                {% for tag in hashtags_in_genre %}
                    <a href="{{ url_for('blog.index', genre=selected_genre, hashtag=tag.name) }}"
                       class="hashtag-filter-badge {% if selected_hashtag == tag.name %}active{% endif %}">
                        #{{ tag.name }}
                    </a>
                {% endfor %}
                {% if selected_hashtag %}
                    <a href="{{ url_for('blog.index', genre=selected_genre) }}"
                       class="hashtag-filter-clear">✕ タグ解除</a>
                {% endif %}
            </div>
        </div>
    {% endif %}
    {# ========================================================= #}

    {# ===== ページ送りのリンク先がここへ来るようにするための目印 =====
       固定ヘッダーに隠れないよう scroll-margin-top を index.css で確保。
       ページ番号リンクの #index-articles-anchor フラグメントで
       記事一覧の先頭へジャンプする。 #}
    <div id="index-articles-anchor"></div>
    {# ========================================================= #}

    {# ===== 記事一覧の見出し（フィルターなし かつ 1ページ目のみ） ===== #}
    {% if not selected_genre and not search_word and not selected_hashtag and pagination.page == 1 %}
        <h3 class="posts-section-title">📋 最新の記事</h3>
    {% endif %}
    {# =========================== #}

    {% for post in posts %}
        <article class="post-card">
            <div class="post-thumbnail">
                {# サムネイル表示の優先順位:
                   1. thumbnail_img（アップロードされた専用サムネイル）
                   2. default_thumb（プリセットから選択したデフォルトサムネイル）
                   3. system-default.jpg（システム共通のデフォルト）
                   ※ 以前は img_name の先頭画像をサムネイルに流用していたが、
                     サムネイルは thumbnail_img で独立管理する方式に変更した。 #}
                {% if post.thumbnail_img %}
                    <img src="{{ url_for('static', filename='img/posts/' + post.thumbnail_img) }}" alt="{{ post.title }}" class="thumb-img" loading="lazy">
                {% elif post.default_thumb %}
                    <img src="{{ url_for('static', filename='img/thbnails/' + post.default_thumb) }}" alt="選択されたデフォルトサムネイル" class="thumb-img" loading="lazy">
                {% else %}
                    <img src="{{ url_for('static', filename='img/thbnails/system-default.jpg') }}" alt="システム共通デフォルトサムネイル" class="thumb-img" loading="lazy">
                {% endif %}
            </div>

            <div class="post-content">
                <div class="post-header-meta">
                    <span class="badge-genre">📂 {{ post.genre if post.genre else '未分類' }}</span>

                    {% if not post.is_published %}
                        <span class="badge-private">🔒 非公開</span>
                    {% endif %}
                </div>

                <h2 class="post-title">
                    <a href="{{ url_for('blog.detail', id=post.id) }}">{{ post.title }}</a>
                </h2>

                {# ===== ハッシュタグバッジ ===== #}
                {% if post.hashtags %}
                    <div class="post-hashtags">
                        {% for tag in post.hashtags %}
                            <a href="{{ url_for('blog.index', genre=post.genre, hashtag=tag.name) }}" class="hashtag-badge">
                                #{{ tag.name }}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
                {# ============================= #}

                <p class="post-date">
                    🕒 投稿: {{ post.created_at.strftime('%Y年%m月%d日') }}
                    {% if post.updated_at %}
                        <span class="updated-date">（更新: {{ post.updated_at.strftime('%Y年%m月%d日') }}）</span>
                    {% endif %}
                </p>

                {% if current_user.is_authenticated and post.user_id == current_user.id %}
                    <div class="post-actions">
                        <a href="{{ url_for('admin.update', id=post.id) }}" role="button" class="btn-edit">編集</a>
                        <form action="{{ url_for('admin.delete', id=post.id) }}" method="POST" onsubmit="return confirm('本当にこの投稿を削除しますか？');">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                            <button type="submit" class="btn-delete">削除</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </article>
    {% else %}
        <p class="index-empty-message">
            該当する記事が見つかりませんでした。
        </p>
    {% endfor %}

    {# ============================================================
       ページ番号によるページ送り（サーバー側ページネーション）
       ------------------------------------------------------------
       【変更点】
       以前はサーバー側で最大4件しか渡していないのに、クライアント
       JS が「全記事がレンダリングされている前提」でページ分割して
       いたため、常に totalPages=1 となりページ送りUIが表示されず、
       最新4件より古い記事に一切到達できないバグがあった。

       これを解消するため、クライアント JS のページ送りを廃止し、
       ビューから渡される Flask-SQLAlchemy の pagination オブジェクトを
       もとに、サーバー側ページネーションのリンクを描画する方式へ一本化した。

       - 各リンクは現在の絞り込み条件（genre / search / hashtag）を
         引き継ぐ。url_for は値が None のクエリを自動で省くため、
         絞り込みなしのときは余計なパラメータが付かない。
       - #index-articles-anchor フラグメントを付与し、ページ遷移後に
         記事一覧の先頭へスクロールする（固定ヘッダー分は
         scroll-margin-top で吸収）。
       ============================================================ #}
    {% if pagination.pages > 1 %}
        <nav class="index-pagination" aria-label="記事一覧のページ送り">

            {# --- 前へ --- #}
            {% if pagination.has_prev %}
                <a href="{{ url_for('blog.index', page=pagination.prev_num, genre=selected_genre, search=search_word, hashtag=selected_hashtag, _anchor='index-articles-anchor') }}"
                   class="page-btn page-btn-arrow" aria-label="前のページ" rel="prev">‹</a>
            {% else %}
                <span class="page-btn page-btn-arrow page-btn-disabled" aria-hidden="true">‹</span>
            {% endif %}

            {# --- ページ番号（前後2ページ + 端を表示、間は … で省略） --- #}
            {% for p in pagination.iter_pages(left_edge=1, left_current=2, right_current=2, right_edge=1) %}
                {% if p %}
                    {% if p == pagination.page %}
                        <span class="page-btn active" aria-current="page">{{ p }}</span>
                    {% else %}
                        <a href="{{ url_for('blog.index', page=p, genre=selected_genre, search=search_word, hashtag=selected_hashtag, _anchor='index-articles-anchor') }}"
                           class="page-btn">{{ p }}</a>
                    {% endif %}
                {% else %}
                    <span class="page-ellipsis" aria-hidden="true">…</span>
                {% endif %}
            {% endfor %}

            {# --- 次へ --- #}
            {% if pagination.has_next %}
                <a href="{{ url_for('blog.index', page=pagination.next_num, genre=selected_genre, search=search_word, hashtag=selected_hashtag, _anchor='index-articles-anchor') }}"
                   class="page-btn page-btn-arrow" aria-label="次のページ" rel="next">›</a>
            {% else %}
                <span class="page-btn page-btn-arrow page-btn-disabled" aria-hidden="true">›</span>
            {% endif %}

        </nav>
    {% endif %}
    {# ================================================ #}


    {# ===== フィルターなし かつ 1ページ目のときだけ hero を表示 ===== #}
    {% if not selected_genre and not search_word and not selected_hashtag and pagination.page == 1 %}
        {% include 'hero.html' %}
    {% endif %}
    {# ======================================================================= #}

</div>

{% endblock %}
</file>

