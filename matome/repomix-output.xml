<file path="templates/mypage.html">
{% extends "base.html" %}
{% block content %}

<link rel="stylesheet" href="{{ url_for('static', filename='css/index.css') }}">
<link rel="stylesheet" href="{{ url_for('static', filename='css/mypage.css') }}">
<link rel="stylesheet" href="{{ url_for('static', filename='css/load_more.css') }}">

<div class="mypage-container">
    
    <div class="profile-header">
        <h2 class="profile-title">
            👤 {% if current_user.nickname %}{{ current_user.nickname }}{% endif %} さんのマイページ
        </h2>

        <p class="profile-post-count">
            これまでの総投稿数: <strong>{{ posts|length }}</strong> 件
        </p>

        <div class="nickname-form-wrapper">
            <form method="POST" action="{{ url_for('admin.mypage') }}" class="nickname-form">
                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                
                <label for="nickname">ニックネーム変更:</label>
                <input type="text" name="nickname" id="nickname" 
                    class="nickname-input"
                    placeholder="新しいニックネーム" 
                    maxlength="50">
                <button type="submit" class="nickname-submit-btn">変更する</button>
            </form>
        </div>
    </div>

    <h3 class="section-title-genre">📂 あなたの作成・使用したジャンル</h3>
    <div class="user-genre-list">
        {% if user_genres %}
            <ul class="genre-tags">
                {% for genre_item in user_genres %}
                <li class="genre-tag-item">
                    <a href="{{ url_for('blog.index', genre=genre_item) }}" class="genre-tag-link">{{ genre_item }}</a>
                </li>
                {% endfor %}
            </ul>
        {% else %}
            <p style="color: #aaa; font-size: 14px;">登録されたジャンルはありません。</p>
        {% endif %}
    </div>

    <h3 class="section-title-posts">📝 投稿一覧</h3>

    {% for post in posts %}
        <article class="post-card">
            <div class="post-thumbnail">
                {% if post.img_name %}
                    {% set first_img = post.img_name.split(',')[0] %}
                    <img src="{{ url_for('static', filename='img/posts/' + first_img) }}" alt="{{ post.title }}" class="thumb-img">
                {% elif post.default_thumb %}
                    <img src="{{ url_for('static', filename='img/thbnails/' + post.default_thumb) }}" alt="選択されたデフォルトサムネイル" class="thumb-img">
                {% else %}
                    <img src="{{ url_for('static', filename='img/thbnails/system-default.jpg') }}" alt="システム共通デフォルトサムネイル" class="thumb-img">
                {% endif %}
            </div>

            <div class="post-content">
                <div class="post-header-meta">
                    <span class="badge-genre">📂 {{ post.genre if post.genre else '未分類' }}</span>
                    {% if not post.is_published %}
                        <span class="badge-private">🔒 非公開</span>
                    {% endif %}
                </div>

                <h2 class="post-title">
                    <a href="{{ url_for('blog.detail', id=post.id) }}">{{ post.title }}</a>
                </h2>

                {# ===== ハッシュタグバッジ ===== #}
                {% if post.hashtags %}
                    <div class="post-hashtags">
                        {% for tag in post.hashtags %}
                            <a href="{{ url_for('blog.index', genre=post.genre, hashtag=tag.name) }}" class="hashtag-badge">
                                #{{ tag.name }}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
                {# ============================= #}

                <div class="post-actions">
                    <a href="{{ url_for('admin.update', id=post.id) }}" role="button" class="btn-edit">編集</a>
                    <form action="{{ url_for('admin.delete', id=post.id) }}" method="POST" onsubmit="return confirm('本当にこの投稿を削除しますか？');" style="display:inline;">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                        <button type="submit" class="btn-delete">削除</button>
                    </form>
                </div>

                <p class="post-date">
                    🕒 投稿: {{ post.created_at.strftime('%Y年%m月%d日') }}
                    {% if post.created_at != post.updated_at %}
                        <span class="updated-date">（更新: {{ post.updated_at.strftime('%Y年%m月%d日') }}）</span>
                    {% endif %}
                </p>
            </div>
        </article>
    {% else %}
        <p class="empty-message">まだ投稿がありません。<br><a href="{{ url_for('admin.create') }}">最初の記事を書いてみましょう</a></p>
    {% endfor %}

    {# ===== 「もっと見る」ボタン ===== #}
    <div class="load-more-wrap" id="mypage-load-more-wrap">
        <button class="load-more-btn" id="mypage-load-more-btn" type="button"
                onclick="mypageLoadMore()">
            もっと見る
            <span class="load-more-count" id="mypage-load-more-count"></span>
        </button>
    </div>
    {# ================================ #}

</div>

<script>
(function () {
    var INITIAL = 1;   /* 最初に表示する件数：最新1件のみ */
    var STEP    = 5;   /* 「もっと見る」1回で追加する件数 */

    var cards   = Array.from(document.querySelectorAll('.mypage-container > article.post-card'));
    var total   = cards.length;
    var shown   = 0;

    var wrap    = document.getElementById('mypage-load-more-wrap');
    var countEl = document.getElementById('mypage-load-more-count');

    /* 全カードをいったん非表示にしてから必要枚数だけ開く */
    cards.forEach(function (c) { c.style.display = 'none'; });

    function showCards(n) {
        var end = Math.min(shown + n, total);
        for (var i = shown; i < end; i++) {
            cards[i].style.display = '';  /* index.css の flex レイアウトに戻す */
        }
        shown = end;
        updateBtn();
    }

    function updateBtn() {
        var remaining = total - shown;
        if (remaining <= 0) {
            wrap.style.display = 'none';
        } else {
            wrap.style.display = 'block';
            countEl.textContent = 'あと ' + remaining + ' 件';
        }
    }

    window.mypageLoadMore = function () { showCards(STEP); };

    /* 初期表示：最新1件のみ */
    showCards(INITIAL);
})();
</script>

{% endblock %}
</file>

