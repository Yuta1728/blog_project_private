/* ===========================
   スマホ（〜767px）
   =========================== */
@media (max-width: 767px) {
    .mypage-container {
        padding: 15px 12px 48px;
        width: 100% !important;
        box-sizing: border-box;
    }

    .profile-header {
        padding: 20px 16px 18px;
