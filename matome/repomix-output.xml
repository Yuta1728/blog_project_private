<file path="static/css/auth.css">
/* ============================================================
   static/css/auth.css - Coastal Dawn v2
   【対象ページ】 login.html（管理者ログインページ）
   ============================================================
   このファイルはログインページ専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */


/* ------------------------------------------------------------
   【login.html】カード全体（フォームを囲む枠）
   ------------------------------------------------------------ */
.auth-container {
    max-width: 400px;
    margin: 72px auto 60px;
    padding: 40px 40px 36px;
    background-color: #ffffff;
    border-radius: 0 12px 12px 0;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
    box-sizing: border-box;
    font-family: inherit;
}

/* ------------------------------------------------------------
   【login.html】見出し「管理者画面」
   ------------------------------------------------------------ */
h2 {
    text-align: center;
    color: #0c1f35;
    margin: 0 0 20px;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
}

/* ------------------------------------------------------------
   【login.html】フォームグループ（ユーザー名／パスワード欄の間隔）
   ------------------------------------------------------------ */
.form-group {
    margin-bottom: 20px;
}

/* ------------------------------------------------------------
   【login.html】各入力欄のラベル（「ユーザー名」「パスワード」）
   ------------------------------------------------------------ */
label {
    display: block;
    margin-bottom: 8px;
    font-weight: 700;
    font-size: 13px;
    color: #0369a1;
    letter-spacing: 0.03em;
}

/* ------------------------------------------------------------
   【login.html】ユーザー名・パスワードの入力欄
   ------------------------------------------------------------ */
input[type="text"],
input[type="password"] {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 16px;
    outline: none;
    background: #f0f9ff;
    color: #0c1f35;
    transition: border-color 0.18s, background 0.18s;
    font-family: inherit;
}

input[type="text"]:focus,
input[type="password"]:focus {
    border-color: #0ea5e9;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* ------------------------------------------------------------
   【login.html】「ログイン」送信ボタン
   ------------------------------------------------------------ */
.submit-btn {
    width: 100%;
    padding: 12px;
    background-color: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    margin-top: 15px;
    transition: background-color 0.18s;
    font-family: inherit;
}

.submit-btn:hover {
    background-color: #0369a1;
}

/* ------------------------------------------------------------
   【login.html】カード下部の補足リンク（現状未使用の予備クラス）
   ------------------------------------------------------------ */
.footer-link {
    text-align: center;
    margin-top: 18px;
    font-size: 13px;
    color: #0369a1;
}

/* ------------------------------------------------------------
   【login.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .auth-container {
        margin: 24px 16px;
        padding: 28px 22px;
        border-radius: 0 10px 10px 0;
    }
    h2 { font-size: 18px; margin-bottom: 20px; }
    .form-group { margin-bottom: 16px; }
    .submit-btn { padding: 14px; font-size: 15px; }
}
</file>

<file path="static/css/base.css">
/* ============================================================
   static/css/base.css - Coastal Dawn v2（白ヘッダー・視認性改善版 / ヘッダー固定化対応）
   【対象ページ】 base.html（全ページ共通のレイアウト・ヘッダー・ドロワー）
   ============================================================
   このファイルは全ページで読み込まれる共通パーツ
   （ページ背景・ヘッダー・スマホ用ドロワーメニュー・フラッシュメッセージ）
   のスタイルをまとめている。機能・パーツ単位で見出しコメントを付け、
   どのUI要素のデザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【共通】グローバルリセット
   ------------------------------------------------------------ */
*, *::before, *::after {
    box-sizing: border-box;
}


/* ------------------------------------------------------------
   【共通レイアウト】ページ背景（html要素）
   ------------------------------------------------------------
   ヘッダーを position: fixed 化したことに伴う変更点:
   従来は .main-header を position: sticky で実装しており、
   スマホ／macOSトラックパッド等で発生する
   「ページ端を超えて引っ張るとバウンドする」オーバースクロール時に、
   sticky 要素はドキュメントの流れの中に存在するため、
   その要素の“外側”（＝ページ最上部より上の領域）に
   html 要素の背景色がそのまま露出してしまう問題があった。

   これを解消するため、ヘッダーを画面（ビューポート）基準で
   常に固定される position: fixed に変更した（note等の大手ブログサービスと同様の実装）。
   fixed 要素はスクロール量やバウンドの影響を一切受けず、
   常に画面最上部を覆い続けるため、
   「限界までスクロールしても背景が見えてしまう」現象が根本的に解消される。

   これに伴い、以前 html 要素に施していた
   「オーバースクロール時だけヘッダー分の高さを白くする」
   グラデーションによる応急処置は不要になったため削除し、
   代わりに body 要素に固定ヘッダーの高さ分の padding-top を設定して
   本文がヘッダーの下に隠れないよう調整している。
   ------------------------------------------------------------ */
html {
    background-color: #f0f9ff;
}


/* ------------------------------------------------------------
   【共通レイアウト】ページ背景（body要素）
   ------------------------------------------------------------
   min-height を指定し、コンテンツが短いページ
   （ログイン画面など）でも body の背景色が
   ビューポート全体を必ず覆うようにする。

   padding-top: 85px（PC）／63px（スマホ、@mediaで上書き）
   ヘッダーを position: fixed にしてドキュメントの流れから
   外した分、本文の開始位置がヘッダーの高さ（.header-container の
   height と一致）だけ下にずれるよう補正する。
   ------------------------------------------------------------ */
body {
    font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Noto Sans JP", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #2a4a5e;
    background-color: #f0f9ff;
    line-height: 1.7;
    font-weight: 500;
    margin: 0;
    padding: 0;
    padding-top: 85px;   /* 固定ヘッダー（PC: 85px）の高さ分だけ本文を押し下げる */
    min-height: 100vh;   /* フォールバック（dvh未対応ブラウザ向け） */
    min-height: 100dvh;  /* モバイルのアドレスバー分の高さ変動を考慮 */
    -webkit-font-smoothing: antialiased;
}

/* ------------------------------------------------------------
   【共通】見出し（h2）の汎用スタイル
   ------------------------------------------------------------ */
h2 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 24px 0;
    text-align: center;
    color: #0c1f35;
}

/* ------------------------------------------------------------
   【共通】リンクの基本スタイル
   ------------------------------------------------------------ */
a {
    color: #0369a1;
    text-decoration: none;
}

a:hover {
    color: #0ea5e9;
    text-decoration: underline;
}


/* ------------------------------------------------------------
   【共通】フラッシュメッセージ（ログイン成功／エラー通知など）
   ------------------------------------------------------------ */
.flash-messages {
    list-style: none;
    padding: 0;
    max-width: 680px;
    margin: 16px auto;
    text-align: center;
}

.flash-messages li {
    font-size: 14px;
    color: #033f5f;
    background-color: #f4fbff;
    border: 1px solid #7dd3fa;
    padding: 10px 16px;
    margin-bottom: 8px;
    border-radius: 6px;
}

.flash-messages li.danger {
    color: #922b21;
    background-color: #fff0ee;
    border: 1px solid #f5b7b1;
}


/* ============================================================
   【共通ヘッダー】ヘッダー本体（固定ヘッダー）
   ============================================================
   黒ヘッダーを廃止し、白ヘッダーに変更。
   下部に 3px のセルリアンラインを引くことで
   「爽やかな水色」らしさを保ちながら
   清潔感のある仕上がりにする。

   position: sticky → position: fixed に変更した理由:
   sticky はドキュメントの流れの中に留まりながら
   スクロール位置に応じて画面上に張り付く実装だが、
   オーバースクロール（バウンド）時には
   要素の外側の背景が露出してしまう弱点があった。

   fixed はビューポート基準で常に同じ位置に描画されるため、
   スクロール量やバウンドの影響を受けず、
   限界までスクロールしてもヘッダーが画面最上部を
   覆い続ける（＝背景が見えることがない）。

   left: 0; right: 0; を明示することで
   width: 100% と合わせて画面幅いっぱいに固定表示する。

   スクロール方向に応じて transform: translateY(-100%) で
   ヘッダーをスライドイン／スライドアウトさせる挙動（base.html側のJS）は
   fixed 化後もそのまま機能する。
   ============================================================ */
.main-header {
    background-color: #ffffff;
    border-bottom: 3px solid #0ea5e9;
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transform: translateY(0);
    visibility: visible;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0s;
}

/* 下スクロール時にヘッダーを画面外へスライドアウトさせる状態（JSが付与） */
.main-header.header-hidden {
    transform: translateY(-100%);
    visibility: hidden;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0.2s;
}

/* ヘッダー内側のレイアウト（ロゴ／検索／ナビを横並びに配置） */
.header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    height: 85px;
    gap: 24px;
}

/* ------------------------------------------------------------
   【共通ヘッダー】ロゴ（「MIT Blog」）
   ------------------------------------------------------------
   ロゴは Noto Serif JP（明朝体）のインク色（#0c1f35）。
   白背景上でくっきりと読める十分なコントラストを確保。
   ------------------------------------------------------------ */
.header-logo {
    flex: 0 0 auto;
}

.header-logo a {
    color: #0c1f35 !important;
    text-decoration: none !important;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    display: block;
}

.header-logo a:hover {
    color: #0369a1 !important;
    text-decoration: none !important;
}

/* ------------------------------------------------------------
   【共通ヘッダー】キーワード検索フォーム（ヘッダー上部の検索バー）
   ------------------------------------------------------------
   検索バーは白背景に、セルリアン系のボーダーで統一感を出す。
   プレースホルダーは #7ab8d8 で薄すぎず、邪魔にならないトーンに。
   ------------------------------------------------------------ */
.header-search-box {
    flex: 1;
    display: flex;
    justify-content: center;
    padding: 0 20px;
}

.header-search-box form {
    display: flex;
    align-items: center;
    background-color: #dbeafe;
    border-radius: 20px;
    padding: 5px 14px;
    border: 1px solid #38bdf8;
    transition: all 0.3s ease;
    width: 100%;
    max-width: 350px;
}

.header-search-box form:focus-within {
    background-color: #ffffff;
    border-color: #0ea5e9;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.15);
}

.header-search-box input[type="text"] {
    border: none;
    background: transparent;
    outline: none;
    padding: 5px 4px;
    font-size: 14px;
    color: #0c1f35;
    width: 100%;
    font-family: inherit;
}

.header-search-box input[type="text"]::placeholder {
    color: #5a8ba8;
}

/* 検索実行ボタン（虫眼鏡アイコン） */
.search-submit-btn {
    border: none;
    background: transparent;
    cursor: pointer;
    color: #0ea5e9;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    border-radius: 50%;
    transition: color 0.2s, background-color 0.2s;
}

.search-submit-btn:hover {
    color: #0369a1;
    background-color: #e0f2fe;
}

/* 検索解除ボタン（✕）※検索中・絞り込み中のみ表示 */
.search-clear-btn {
    color: #c12c1c;
    text-decoration: none;
    margin-left: 8px;
    font-size: 14px;
    font-weight: bold;
    transition: color 0.15s;
}

.search-clear-btn:hover {
    color: #c63022;
    text-decoration: none;
}

/* ------------------------------------------------------------
   【共通ヘッダー】PC用ナビゲーション（新規投稿／ジャンル検索／マイページ／ログアウト）
   ------------------------------------------------------------
   白背景上のナビリンク。テキストを #0369a1（濃いセルリアン）に設定し
   白背景でも確実に視認できるコントラストを確保。
   ------------------------------------------------------------ */
.header-nav {
    flex: 0 0 auto;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.header-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.header-nav ul li {
    display: inline-block;
    line-height: 1;
}

.header-nav ul li a {
    color: #0369a1;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 20px;
    background-color: #e0f2fe;
    border: 1px solid #38bdf8;
    transition: all 0.18s ease;
    display: inline-block;
    white-space: nowrap;
}

.header-nav ul li a:hover {
    color: #0c1f35;
    border-color: #0ea5e9;
    background-color: #bae6fd;
    text-decoration: none;
}

/* 先頭の「新規投稿」だけセルリアン塗りつぶしで強調 */
.header-nav ul li:first-child a {
    background-color: #0ea5e9;
    color: #ffffff;
    border-color: #0ea5e9;
    font-weight: 700;
}

.header-nav ul li:first-child a:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #ffffff;
}


/* ------------------------------------------------------------
   【共通ヘッダー】ハンバーガーボタン（スマホ・PC非表示のメニュー開閉ボタン）
   ------------------------------------------------------------
   白ヘッダー上のハンバーガーラインはセルリアン系の濃い色で視認性を確保。
   ------------------------------------------------------------ */
.hamburger-btn {
    display: none;
    background: none;
    border: 1.5px solid #bae6fd;
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
}

.hamburger-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #0369a1;
    border-radius: 2px;
    transition: all 0.25s ease;
}


/* ============================================================
   【共通ヘッダー】スマホ用ドロワーメニュー（ハンバーガーで開閉）
   ============================================================ */

/* 背景を暗く覆うオーバーレイ */
.mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(12, 31, 53, 0.45);
    z-index: 999;
}

.mobile-nav-overlay.open {
    display: block;
}

/* 右からスライドインするドロワー本体 */
.mobile-nav-drawer {
    position: fixed;
    top: 0;
    right: -290px;
    width: 270px;
    height: 100dvh;
    background: #ffffff;
    box-shadow: -4px 0 20px rgba(14, 165, 233, 0.15);
    z-index: 1000;
    transition: right 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
}

.mobile-nav-drawer.open {
    right: 0;
}

/* ドロワー上部（ロゴ＋閉じるボタン） */
.mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 3px solid #0ea5e9;
    background: #ffffff;
}

.mobile-nav-header-logo {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #0c1f35;
}

.mobile-nav-close {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #5a8ba8;
    padding: 4px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    transition: background 0.15s;
}

.mobile-nav-close:hover,
.mobile-nav-close:active {
    background: #e0f2fe;
}

/* ドロワー内のメニュー項目 */
.mobile-nav-drawer ul {
    list-style: none;
    margin: 12px 0 0;
    padding: 0 12px;
}

.mobile-nav-drawer ul li {
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 6px;
}

.mobile-nav-drawer ul li a {
    display: block;
    padding: 14px 16px;
    color: #0369a1;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    transition: background 0.15s;
    border-radius: 8px;
    min-height: 48px;
    border-left: 3px solid transparent;
}

.mobile-nav-drawer ul li a:hover,
.mobile-nav-drawer ul li a:active {
    background: #e0f2fe;
    border-left-color: #0ea5e9;
}

/* 先頭の「新規投稿」だけ強調表示 */
.mobile-nav-drawer ul li:first-child a {
    background-color: #0ea5e9;
    color: #fff;
    margin-bottom: 12px;
    text-align: center;
    border-left-color: transparent;
    font-weight: 700;
}

.mobile-nav-drawer ul li:first-child a:hover,
.mobile-nav-drawer ul li:first-child a:active {
    background-color: #0369a1;
}

/* 【共通】floatクリア用ユーティリティ */
.clear { clear: both; }


/* ==========================================================================
   【共通ヘッダー】レスポンシブ（スマホ）
   ========================================================================== */

@media (max-width: 767px) {
    .header-container {
        padding: 0 15px;
        height: 63px;
        gap: 12px;
    }

    /* 固定ヘッダーの高さがスマホでは63pxになるため、
       本文の押し下げ量もそれに合わせて上書きする。 */
    body {
        padding-top: 63px;
    }

    .header-logo a {
        font-size: 24px;
    }

    .header-nav {
        display: none;
    }

    .hamburger-btn {
        display: flex;
    }

    .flash-messages {
        margin: 12px 16px;
    }

    .flash-messages li {
        font-size: 13px;
    }

    h2 {
        font-size: 20px;
        margin: 16px 0;
    }

    .header-search-box {
        padding: 0 5px;
        flex: 1;
        display: flex;
        justify-content: center;
    }

    .header-search-box form {
        width: 100%;
        max-width: 160px;
        padding: 2px 8px;
        border-radius: 15px;
    }

    .header-search-box input[type="text"] {
        font-size: 12px;
        padding: 3px 2px;
    }

    .search-submit-btn svg {
        width: 14px;
        height: 14px;
    }

    .search-clear-btn {
        margin-left: 4px;
        font-size: 11px;
    }
}

@media (max-width: 480px) {
    .header-search-box form {
        max-width: 145px;
    }

    .header-search-box input[type="text"]::placeholder {
        font-size: 12px;
    }
}
</file>

<file path="static/css/create_update.css">
/* ============================================================
   static/css/create_update.css - Coastal Dawn v2
   【対象ページ】 create.html（新規投稿）／ update.html（記事編集）
   ============================================================
   このファイルは投稿作成・編集フォーム専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【create.html / update.html】ページ見出し（「新規投稿作成」「編集」）
   ------------------------------------------------------------ */
h1 {
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    margin: 36px 0 24px;
    color: #0c1f35;
    letter-spacing: -0.01em;
}

/* ------------------------------------------------------------
   【create.html / update.html】フォームカード全体
   ------------------------------------------------------------ */
.post-form {
    max-width: 720px;
    margin: 0 auto 60px;
    background: #fff;
    padding: 40px 44px;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    box-sizing: border-box;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.post-form label {
    display: block;
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 8px;
    color: #0c1f35;
    letter-spacing: 0.02em;
}

/* ------------------------------------------------------------
   【create.html / update.html】タイトル入力欄・ジャンル選択セレクト
   ------------------------------------------------------------ */
.post-form input[type="text"],
.post-form select {
    width: 100% !important;
    padding: 10px 14px;
    font-size: 15px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    box-sizing: border-box;
    margin-bottom: 22px;
    outline: none;
    background-color: #f0f9ff;
    color: #0c1f35;
    transition: border-color 0.18s, background 0.18s, box-shadow 0.18s;
    font-family: inherit;
}

.post-form input[type="text"]:focus,
.post-form select:focus {
    border-color: #0ea5e9;
    background-color: #fff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* ------------------------------------------------------------
   【create.html / update.html】本文（Markdown）入力用テキストエリア
   ------------------------------------------------------------ */
.post-form textarea {
    width: 100% !important;
    padding: 18px !important;
    font-size: 20px !important;
    line-height: 1.9 !important;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace !important;
    letter-spacing: normal !important;
    border: 1px solid #7dd3fa !important;
    border-radius: 8px !important;
    box-sizing: border-box !important;
    margin-bottom: 22px !important;
    outline: none !important;
    background-color: #f0f9ff !important;
    color: #0c1f35 !important;
    min-height: 520px !important;
    resize: vertical !important;
    transition: border-color 0.18s, background 0.18s !important;
}

.post-form textarea:focus {
    border-color: #0ea5e9 !important;
    background-color: #fff !important;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12) !important;
}

/* フォーム内の補足説明テキスト（各項目のヘルプ文） */
.post-form p { font-size: 15px; color: #2a4a5e; margin: 0 0 8px; line-height: 1.5; font-weight: 500; }

/* 画像アップロード用のネイティブ input[type=file]（JS制御で非表示にする場合あり） */
.post-form input[type="file"] { display: block; margin-bottom: 24px; font-size: 13px; color: #0c1f35; width: 100%; }

/* ------------------------------------------------------------
   【create.html / update.html】「投稿する」「更新」送信ボタン
   ------------------------------------------------------------ */
.post-form input[type="submit"] {
    display: block;
    width: 100%;
    padding: 14px;
    background-color: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.18s;
    font-family: inherit;
    letter-spacing: 0.02em;
}

.post-form input[type="submit"]:hover { background-color: #0369a1; }

/* ------------------------------------------------------------
   【create.html / update.html】画像アップロードのプレビューカード
   （[imgN]ラベル・ファイル名・削除ボタンを含むカード）
   ------------------------------------------------------------ */
.preview-item {
    position: relative;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    overflow: hidden;
    background: #f0f9ff;
    width: 150px;
    margin-bottom: 8px;
}

.preview-item img { width: 150px; height: 112px; object-fit: cover; display: block; }

.preview-label {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    color: #0369a1;
    padding: 5px 0 3px;
    background: #dbeafe;
    border-top: 1px solid #7dd3fa;
    letter-spacing: 0.03em;
}

.preview-filename {
    text-align: center;
    font-size: 10px;
    color: #4a7a96;
    padding: 2px 6px 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* ------------------------------------------------------------
   【create.html / update.html】公開設定トグルボタン（🔒非公開／🔓全体公開）
   ------------------------------------------------------------ */
.toggle-status-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 700;
    border-radius: 20px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.2s ease;
    font-family: inherit;
    margin-bottom: 22px;
    outline: none;
}

.toggle-status-btn.private {
    background-color: #f0f9ff;
    color: #0369a1;
    border-color: #7dd3fa;
}

.toggle-status-btn.private:hover { background-color: #dbeafe; border-color: #38bdf8; }

.toggle-status-btn.published {
    background-color: #dbeafe;
    color: #0369a1;
    border-color: #38bdf8;
}

.toggle-status-btn.published:hover { background-color: #bae6fd; border-color: #0ea5e9; }

/* ============================================================
   【create.html / update.html】Markdown編集ツールバー
   （H2/H3見出し・太字・目次・リスト・地図・YouTubeの各挿入ボタン）
   ============================================================ */
.md-toolbar-wrapper { position: relative; }

/* ツールバー本体：本文欄の上に張り付くスティッキーバー */
.md-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 12px;
    background: #e0f2fe;
    border: 1px solid #7dd3fa;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    margin-bottom: 0 !important;
    position: sticky;
    top: 85px;
    z-index: 50;
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.12);
    transition: box-shadow 0.2s ease;
}

/* スクロールでツールバーが本文上部に貼り付いた際の強調影 */
.md-toolbar.is-sticky { box-shadow: 0 6px 20px rgba(14, 165, 233, 0.18); border-color: #38bdf8; }

/* ツールバー内の各ボタン共通スタイル（H2見出し・太字・[toc]目次など） */
.md-btn {
    padding: 7px 13px;
    font-size: 13px;
    font-weight: 600;
    color: #0c1f35;
    background: #fff;
    border: 1px solid #7dd3fa;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    line-height: 1;
    min-width: 44px;
    min-height: 36px;
    text-align: center;
}

.md-btn:hover, .md-btn:active { background: #dbeafe; border-color: #38bdf8; color: #0c1f35; }

/* ツールバー内のボタン間の区切り線 */
.md-btn-separator {
    display: inline-block;
    width: 1px;
    height: 24px;
    background: #7dd3fa;
    margin: 0 4px;
    vertical-align: middle;
    flex-shrink: 0;
}

/* [imgN] 画像挿入ボタン（アップロード枚数に応じて動的に生成） */
.md-btn-img { color: #0369a1; background: #dbeafe; border-color: #38bdf8; }
.md-btn-img:hover, .md-btn-img:active { background: #bae6fd; border-color: #0ea5e9; color: #0c1f35; }

/* 🗺️ 地図挿入ボタン */
.md-btn-map { color: #166534; background: #dcfce7; border-color: #86efac; }
.md-btn-map:hover, .md-btn-map:active { background: #bbf7d0; border-color: #4ade80; color: #14532d; }

/* ▶ YouTube挿入ボタン */
.md-btn-youtube { color: #fff; background: rgba(220,38,38,0.75); border-color: rgba(185,28,28,0.6); font-weight: 700; }
.md-btn-youtube:hover, .md-btn-youtube:active { background: rgba(185,28,28,0.85); color: #fff; }

/* 箇条書きリスト挿入ボタン（SVGアイコン付き） */
.md-btn-list { display: inline-flex; align-items: center; gap: 5px; color: #0c1f35; }
.md-btn-list:hover, .md-btn-list:active { background: #dbeafe; border-color: #38bdf8; }

/* ツールバー直下に接続する本文テキストエリアの角丸調整 */
#bodyTextarea {
    border-radius: 0 0 8px 8px !important;
    border-top: none !important;
    scroll-margin-top: calc(85px + 48px + 8px);
}

/* ============================================================
   【create.html / update.html】🗺️ 地図挿入モーダル
   （md-btn-map クリックで開くポップアップ）
   ============================================================
   同じ .map-modal 系クラスは、下部の ▶ YouTube挿入モーダル
   （youtube-modal-overlay / youtube-modal）でも共用している。
   ============================================================ */
.map-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(12,31,53,0.45); z-index: 1100; }
.map-modal-overlay.open { display: block; }

.map-modal {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -48%);
    width: min(560px, calc(100vw - 32px));
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(14,165,233,0.18);
    z-index: 1200;
    overflow: hidden;
    flex-direction: column;
}

.map-modal.open { display: flex; }

.map-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e0f2fe;
    background: #f0f9ff;
}


.map-modal-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: #4a7a96;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    padding: 0;
}

.map-modal-close:hover { background: #dbeafe; color: #0c1f35; }
.map-modal-body { padding: 20px 20px 8px; }
.map-modal-label { display: block; font-size: 13px; font-weight: 700; color: #0369a1; margin-bottom: 8px; }

/* モーダル内の場所・URL入力欄（地図／YouTube共通デザイン） */
.map-modal-input {
    width: 100%;
    padding: 10px 14px;
    font-size: 15px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    box-sizing: border-box;
    outline: none;
    background: #f0f9ff;
    color: #0c1f35;
    font-family: inherit;
    transition: border-color 0.18s, background 0.18s;
    margin-bottom: 14px;
}

.map-modal-input:focus { border-color: #0ea5e9; background: #fff; box-shadow: 0 0 0 3px rgba(14,165,233,0.12); }

/* モーダル内プレビュー領域（地図iframe／YouTubeサムネイル共通の枠） */
.map-preview-area {
    width: 100%;
    height: 260px;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    overflow: hidden;
    background: #f0f9ff;
    display: flex;
    align-items: center;
    justify-content: center;
}

.map-preview-placeholder { color: #4a7a96; font-size: 14px; text-align: center; margin: 0; padding: 0 20px; }
.map-preview-iframe { width: 100%; height: 100%; border: none; display: block; }

/* モーダル下部のキャンセル／挿入ボタン行 */
.map-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 14px 20px 18px;
    border-top: 1px solid #e0f2fe;
}

.map-modal-cancel {
    padding: 9px 20px;
    font-size: 14px;
    font-weight: 600;
    background: #fff;
    color: #4a7a96;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
}

.map-modal-cancel:hover { background: #f0f9ff; }

.map-modal-insert {
    padding: 9px 22px;
    font-size: 14px;
    font-weight: 700;
    background: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.18s;
}

.map-modal-insert:hover:not(:disabled) { background: #0369a1; }
.map-modal-insert:disabled { background: #bae6fd; cursor: not-allowed; }

/* ------------------------------------------------------------
   【create.html / update.html】画像プレビューのキャプション入力欄
   ------------------------------------------------------------ */
.preview-caption-wrapper { padding: 8px 8px 2px; background: #dbeafe; border-top: 1px solid #7dd3fa; }

.preview-caption-input {
    width: 100%;
    padding: 5px 10px;
    font-size: 12px;
    border: 1px solid #38bdf8;
    border-radius: 6px;
    box-sizing: border-box;
    outline: none;
    background: #fff;
    color: #0c1f35;
    font-family: inherit;
    transition: border-color 0.18s;
}

.preview-caption-input:focus { border-color: #0ea5e9; }
.preview-caption-input::placeholder { color: #7dd3fa; font-size: 11px; }

/* ------------------------------------------------------------
   【create.html / update.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    h1 { font-size: 17px; margin: 20px 0 16px; }
    .post-form { padding: 24px 16px; border-radius: 0 10px 10px 0; border-left: none; border-right: none; margin-bottom: 0; width: 100% !important; box-sizing: border-box; }
    .post-form p { font-size: 13px; margin: 0 0 6px; line-height: 1.5; }
    .post-form label { font-size: 13px; }
    .post-form input[type="text"], .post-form select { font-size: 16px !important; padding: 12px !important; border-radius: 6px; margin-bottom: 16px; }
    .post-form textarea { font-size: 16px !important; line-height: 1.75 !important; padding: 14px !important; min-height: 320px !important; border-radius: 6px !important; margin-bottom: 16px !important; }
    .post-form input[type="submit"] { padding: 14px; font-size: 15px; border-radius: 8px; min-height: 48px; }
    #preview-list, .post-form div[style*="display: flex"] { gap: 12px !important; justify-content: flex-start; }
    .preview-item { width: calc(50% - 6px); box-sizing: border-box; margin-bottom: 12px; }
    .preview-item img { width: 100%; height: 110px; }
    .toggle-status-btn { padding: 12px 20px; font-size: 14px; margin-bottom: 16px; width: 100%; box-sizing: border-box; }
    .md-btn { padding: 10px 12px; font-size: 14px; min-width: 48px; min-height: 44px; }
    .md-btn-list { padding: 10px 12px; font-size: 14px; min-width: 48px; min-height: 44px; gap: 4px; }
    .md-toolbar { top: 63px; padding: 8px 10px; gap: 5px; overflow-x: hidden; }
    #bodyTextarea { scroll-margin-top: calc(63px + 56px + 8px); }
    .map-modal { top: auto; bottom: 0; left: 0; right: 0; transform: none; width: 100%; border-radius: 16px 16px 0 0; max-height: 90dvh; overflow-y: auto; }
    .map-preview-area { height: 200px; }
    .preview-caption-input { font-size: 14px; }
}
</file>

<file path="static/css/detail.css">
/* ============================================================
   static/css/detail.css - Coastal Dawn v2
   【対象ページ】 detail.html（記事詳細ページ）
   ============================================================
   このファイルは記事詳細ページ専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【detail.html】ページ全体のコンテナ
   ------------------------------------------------------------ */
.detail-container {
    max-width: 860px !important;
    margin: 0 auto;
    padding: 36px 32px 60px;
    box-sizing: border-box;
}

/* ------------------------------------------------------------
   【detail.html】記事本文カード（一覧カードと左アクセントラインで統一）
   ------------------------------------------------------------ */
article {
    background: #fff;
    padding: 52px 60px;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    margin-bottom: 32px;
    box-sizing: border-box;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

/* ------------------------------------------------------------
   【detail.html】記事タイトル
   ------------------------------------------------------------ */
h1 {
    font-size: 24px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0 0 20px;
    text-align: left;
    line-height: 1.4;
    letter-spacing: -0.02em;
}

/* ------------------------------------------------------------
   【detail.html】ジャンルバッジ（クリックでジャンル絞り込みへ遷移するリンク）
   ------------------------------------------------------------
   .genre-badge を <span> から <a> へ変更したことに伴い、
   ハッシュタグバッジ（.hashtag-badge）と統一感のある
   インタラクティブなスタイルを追加。
   display: inline-block / text-decoration: none / transition / hover
   を付与し、「タップできるタグ」であることが視覚的に伝わるようにする。
   ------------------------------------------------------------ */
.genre-badge {
    display: inline-block;
    background-color: #dbeafe;
    color: #0369a1;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 8px;
    font-weight: 600;
    border: 1px solid #38bdf8;
    text-decoration: none;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
}

.genre-badge:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}

/* ------------------------------------------------------------
   【detail.html】メタ情報エリア（ジャンル・投稿者・日時・ハッシュタグをまとめる領域）
   ------------------------------------------------------------ */
.post-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
    color: #4a7a96;
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e0f2fe;
    width: 100%;
}

/* 投稿者アイコン＋ニックネーム表示 */
.post-user-info {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #0369a1;
    font-weight: 600;
    font-size: 12px;
}

.post-user-info img {
    width: 21px;
    height: 21px;
    border-radius: 50%;
    background: #dbeafe;
    border: 1px solid #7dd3fa;
    margin: 0 !important;
}

/* 投稿日時・更新日時テキスト */
.post-time { color: #4a7a96; font-size: 12px; }

/* ============================================================
   【detail.html】目次（本文中の [toc] マーカーから自動生成）
   ============================================================ */
.post-toc,
.detail-article-body .toc {
    background-color: #f0f9ff !important;
    border: 1px solid #7dd3fa !important;
    border-left: 4px solid #0ea5e9 !important;
    border-radius: 0 8px 8px 0;
    padding: 20px 24px;
    margin: 36px 0;
    box-sizing: border-box;
}

/* 本文中の[toc]位置に挿入された目次の見出しラベル */
.detail-article-body .toc::before {
    content: "目次" !important;
    display: block !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    margin: 0 0 14px !important;
    color: #0c1f35 !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

/* 記事先頭に自動表示される目次の見出しラベル（[toc]未使用時） */
.post-toc .toc-title, .toc-fixed .toc-title, .toc-sticky .toc-title {
    display: block !important;
    font-weight: 700 !important;
    font-size: 16px !important;
    margin: 0 0 14px !important;
    color: #0c1f35 !important;
    text-align: left !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

.post-toc > ul, .post-toc .toc > ul, .detail-article-body .toc > ul {
    list-style-type: none !important;
    padding-left: 0 !important;
    margin: 0 !important;
    text-align: left !important;
    display: block !important;
}

/* 本文中の見出し（H1〜H3）に、固定ヘッダー分のスクロール余白を確保 */
.detail-article-body h1,
.detail-article-body h2,
.detail-article-body h3 { scroll-margin-top: 100px; }

.post-toc > ul > li, .post-toc .toc > ul > li, .detail-article-body .toc > ul > li {
    text-align: left !important;
    margin-bottom: 0 !important;
    padding: 11px 0 !important;
    font-size: 15px !important;
    font-weight: bold !important;
    display: block !important;
    background: none !important;
    border: none !important;
    border-bottom: 1px solid #bae6fd !important;
    color: #0c1f35 !important;
}

.post-toc ul ul, .post-toc .toc ul ul, .detail-article-body .toc ul ul {
    list-style-type: none !important;
    padding-left: 20px !important;
    margin: 6px 0 0 !important;
    display: block !important;
}

.post-toc ul ul li, .post-toc .toc ul ul li, .detail-article-body .toc ul ul li {
    font-size: 14px !important;
    font-weight: normal !important;
    padding: 4px 0 !important;
    border-bottom: none !important;
    position: relative !important;
    display: block !important;
    color: #2a4a5e !important;
}

.post-toc ul ul li::before, .post-toc .toc ul ul li::before, .detail-article-body .toc ul ul li::before {
    content: "•" !important;
    color: #38bdf8 !important;
    margin-right: 6px !important;
    font-size: 13px !important;
}

.post-toc > ul > li:last-child, .post-toc .toc > ul > li:last-child, .detail-article-body .toc > ul > li:last-child {
    margin-bottom: 0 !important;
    border-bottom: none !important;
    padding-bottom: 0 !important;
}

.post-toc > ul > li:first-child, .post-toc .toc > ul > li:first-child, .detail-article-body .toc > ul > li:first-child {
    padding-top: 4px !important;
}

.post-toc a, .detail-article-body .toc a {
    color: #0369a1 !important;
    text-decoration: none !important;
    transition: color 0.15s !important;
    display: inline-block !important;
}

.post-toc a:hover, .detail-article-body .toc a:hover {
    color: #0ea5e9 !important;
    text-decoration: underline !important;
}

/* ============================================================
   【detail.html】記事本文（Markdown→HTML変換後のテキスト）
   ============================================================ */
.detail-article-body {
    font-weight: 400;
    font-size: 17px;
    line-height: 1.8;
    word-break: break-word;
    text-align: left;
    white-space: normal;
    color: #1e3a4f;
}

.detail-article-body strong { font-weight: 700 !important; color: #0c1f35; }

.detail-article-body p { margin-top: 9px !important; margin-bottom: 1.4em; font-size: 17px; font-weight: 400; }

.detail-article-body h2 {
    font-size: 22px;
    font-weight: 700;
    border-bottom: 2px solid #7dd3fa;
    padding-bottom: 6px;
    margin: 40px 0 16px;
    text-align: left;
    color: #0c1f35;
}

.detail-article-body h3 {
    font-size: 19px;
    font-weight: 700;
    margin: 28px 0 0;
    text-align: left;
    color: #0c1f35;
    border-left: 4px solid #0ea5e9;
    padding-left: 10px;
}

/* 本文内の画像共通スタイル */
article img { max-width: 100%; height: auto; display: block; margin: 25px auto; border-radius: 5px; }

/* ------------------------------------------------------------
   【detail.html】本文内の画像キャプション（[imgN]＋キャプション文）
   ------------------------------------------------------------ */
.post-figure { display: block; margin: 16px auto 8px; text-align: center; }
.post-figure img { max-width: 100% !important; height: auto !important; display: block !important; margin: 0 auto !important; border-radius: 5px; }
.post-figcaption { margin-top: 6px; text-align: center !important; font-size: 15px; color: #0369a1; line-height: 1.5; display: block; width: 100%; }
.post-figure + p { margin-top: 0.6em; }

/* ------------------------------------------------------------
   【detail.html】本文内の地図埋め込み（[map:場所名]タグから生成）
   ------------------------------------------------------------ */
.post-map-wrapper { margin: 24px 0; border-radius: 0 10px 10px 0; overflow: hidden; border: 1.5px solid #7dd3fa; border-left: 4px solid #0ea5e9; box-shadow: 0 3px 10px rgba(14, 165, 233, 0.10); }
.post-map-label { padding: 8px 14px; font-size: 13px; font-weight: 600; color: #0369a1; background: #f0f9ff; border-bottom: 1px solid #7dd3fa; }
.post-map-iframe { width: 100%; height: 380px; border: none; display: block; }

/* ------------------------------------------------------------
   【detail.html】本文内のYouTube埋め込み（[youtube:URL]タグから生成、
   サムネイルをタップすると再生が始まる「ファサード」形式）
   ------------------------------------------------------------ */
.post-youtube-wrapper { margin: 24px 0; border-radius: 10px; overflow: hidden; border: 1px solid #7dd3fa; box-shadow: 0 3px 10px rgba(14, 165, 233, 0.10); position: relative; width: 100%; aspect-ratio: 16 / 9; background: #000; }
.post-youtube-facade { position: absolute; inset: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.post-youtube-thumb { width: 100%; height: 100%; object-fit: cover; display: block; transition: filter 0.2s ease; }
.post-youtube-facade:hover .post-youtube-thumb { filter: brightness(0.85); }
.post-youtube-play-btn { position: absolute; background: none; border: none; cursor: pointer; padding: 0; transition: transform 0.15s ease; }
.post-youtube-facade:hover .post-youtube-play-btn { transform: scale(1.1); }
.yt-btn-bg { fill: #ff0000; fill-opacity: 0.9; transition: fill-opacity 0.15s ease; }
.post-youtube-facade:hover .yt-btn-bg { fill-opacity: 1; }
.yt-btn-icon { fill: #fff; }
.post-youtube-iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; display: block; }

/* ------------------------------------------------------------
   【detail.html】本文下の区切り線
   ------------------------------------------------------------ */
hr { border: 0; border-top: 1px solid #e0f2fe; margin: 0 0 24px; }

/* ------------------------------------------------------------
   【detail.html】「前の画面に戻る」「この記事を編集する」ボタン行
   ------------------------------------------------------------ */
.detail-actions { display: flex; justify-content: center; align-items: center; gap: 12px; padding: 4px 0 32px; flex-wrap: wrap; }

.detail-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 11px 24px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background-color 0.18s, border-color 0.18s, color 0.18s, box-shadow 0.18s, transform 0.13s;
    white-space: nowrap;
    min-height: 44px;
    line-height: 1;
}

.detail-btn-icon { width: 17px; height: 17px; flex-shrink: 0; }

/* 「前の画面に戻る」ボタン（白背景） */
.detail-btn-back {
    background-color: #ffffff;
    color: #4a7a96;
    border: 1px solid #7dd3fa;
    box-shadow: 0 1px 4px rgba(14, 165, 233, 0.08);
}

.detail-btn-back:hover {
    background-color: #f0f9ff;
    border-color: #38bdf8;
    color: #0c1f35;
    box-shadow: 0 3px 10px rgba(14, 165, 233, 0.14);
    transform: translateY(-1px);
}

.detail-btn-back:active { transform: translateY(0); box-shadow: none; background-color: #dbeafe; }

/* 「この記事を編集する」ボタン（セルリアン塗りつぶし・投稿者本人のみ表示） */
.detail-btn-edit {
    background-color: #0ea5e9;
    color: #ffffff;
    border: 1px solid #0ea5e9;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
}

.detail-btn-edit:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #ffffff;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.30);
    transform: translateY(-1px);
    text-decoration: none;
}

.detail-btn-edit:active { transform: translateY(0); box-shadow: none; background-color: #075985; }

/* ============================================================
   【detail.html】関連記事セクション（記事末尾、最大4件表示）
   ============================================================ */
.related-section { margin-top: 20px; padding-top: 8px; }

.related-heading {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 20px;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 32px 0 14px;
    text-align: left;
    letter-spacing: 0.02em;
}

.related-heading-icon { font-size: 16px; flex-shrink: 0; }

/* 「📂○○ / #タグ を表示中」のサブラベルバッジ */
.related-heading-sub {
    font-size: 13px;
    font-weight: 500;
    color: #0369a1;
    background: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 10px;
    padding: 2px 10px;
    margin-left: 4px;
    white-space: nowrap;
    letter-spacing: 0;
    line-height: 1.6;
    flex-shrink: 0;
}

.related-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }

/* 関連記事カード（一覧カードと同じ左アクセントラインデザイン、ホバーでゴールドに変化） */
.related-card {
    display: flex;
    align-items: center;
    gap: 18px;
    background: #fff;
    border: 1.5px solid #7dd3fa;
    border-left: 4px solid #0ea5e9;
    border-radius: 0 10px 10px 0;
    padding: 14px 18px 14px 14px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.18s, border-color 0.18s, background 0.18s, transform 0.15s;
    overflow: hidden;
}

.related-card:hover {
    border-left-color: #f59e0b;
    border-color: #fbbf24;
    background: #fffbeb;
    box-shadow: 0 6px 20px rgba(245, 158, 11, 0.15);
    transform: translateY(-1px);
    text-decoration: none;
    color: inherit;
}

.related-thumb {
    flex: 0 0 120px;
    width: 120px;
    height: 85px;
    border-radius: 6px;
    overflow: hidden;
    background: #dbeafe;
    border: 1px solid #7dd3fa;
    transition: border-color 0.18s;
}

.related-card:hover .related-thumb { border-color: #fbbf24; background: #fef3c7; }

.related-thumb img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; margin: 0 !important; border-radius: 0; }

.related-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }

.related-title {
    font-size: 15px;
    font-weight: 600;
    color: #0c1f35;
    line-height: 1.45;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
}

.related-card:hover .related-title { color: #0369a1; }
.related-date { font-size: 12px; color: #0369a1; margin: 0; font-weight: 500; }

/* ------------------------------------------------------------
   【detail.html】後方互換用の旧ボタンデザイン（現状未使用の予備クラス）
   ------------------------------------------------------------ */
.detail-ul { display: flex; justify-content: center; gap: 16px; padding: 0; margin: 0; list-style: none; flex-wrap: wrap; }
.detail-ul-li { background: none; border: none; padding: 0; }
.detail-ul-li-a { font-size: 14px; color: #0369a1; text-decoration: none; padding: 10px 22px; border: 1px solid #7dd3fa; border-radius: 20px; display: inline-block; transition: all 0.18s; background: none; cursor: pointer; font-family: inherit; }
.detail-ul-li-a:hover { border-color: #0ea5e9; color: #0c1f35; background: #dbeafe; text-decoration: none; }

/* ------------------------------------------------------------
   【detail.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .detail-container { padding: 16px 0 48px !important; width: 100% !important; overflow-x: hidden; }
    article { padding: 28px 16px; border-radius: 0 10px 10px 0; border-left: none; border-right: none; margin-bottom: 16px; }
    h1 { font-size: 20px; letter-spacing: -0.01em; line-height: 1.45; }
    .post-meta { font-size: 12px; gap: 6px; margin-bottom: 24px; padding-bottom: 16px; }
    .post-user-info { font-size: 13px; }
    .detail-article-body {
    font-weight: 500; font-size: 15px !important; line-height: 1.75 !important; word-break: break-all; }
    .detail-article-body p { margin-top: 9px !important; margin-bottom: 1.4em; font-size: 15px; }
    .detail-article-body pre, .detail-article-body code, .detail-article-body table { max-width: 100% !important; overflow-x: auto !important; display: block; word-break: normal; }
    .detail-article-body h2 { font-size: 18px; margin: 32px 0 12px; }
    .detail-article-body h3 { font-size: 16px; margin: 24px 0 0; padding-left: 8px; }
    .post-toc, .detail-article-body .toc { padding: 16px !important; border-radius: 0 6px 6px 0 !important; margin: 24px 0 !important; }
    .post-toc > ul > li, .post-toc .toc > ul > li, .detail-article-body .toc > ul > li { font-size: 14px !important; padding: 10px 0 !important; }
    .post-toc ul ul, .post-toc .toc ul ul, .detail-article-body .toc ul ul { padding-left: 16px !important; margin: 4px 0 0 !important; }
    .post-toc ul ul li, .post-toc .toc ul ul li, .detail-article-body .toc ul ul li { font-size: 13px !important; padding: 5px 0 !important; }
    .post-map-iframe { height: 260px; }
    .post-youtube-wrapper { border-radius: 6px; margin: 16px 0; }
    hr { margin: 0 16px 20px; }
    .detail-actions { flex-direction: column; gap: 10px; padding: 0 16px 28px; }
    .detail-btn { width: 100%; justify-content: center; padding: 13px 24px; font-size: 15px; border-radius: 8px; box-sizing: border-box; }
    .detail-ul { flex-direction: column; align-items: center; gap: 12px; padding: 0 16px 12px; box-sizing: border-box; }
    .detail-ul-li { width: 100%; }
    .detail-ul-li-a { font-size: 15px; padding: 13px 24px; display: block; text-align: center; width: 100%; box-sizing: border-box; min-height: 48px; }
    .post-figure { margin: 12px auto 6px; }
    .post-figcaption { font-size: 12px; }
    .related-section { margin-top: 28px; padding: 0 0 8px; }
    .related-heading { font-size: 16px; margin: 24px 0 12px; padding-bottom: 8px; }
    .related-heading-sub { margin-left: 0; font-size: 11px; }
    .related-list { gap: 8px; }
    .related-card { gap: 14px; padding: 12px 14px 12px 12px; border-radius: 0 8px 8px 0; }
    .related-thumb { flex: 0 0 100px; width: 100px; height: 70px; }
    .related-title { font-size: 14px; }
    .related-date { font-size: 12px; }
}
</file>

<file path="static/css/genre.css">
/* ============================================================
   static/css/genre.css - Coastal Dawn v2
   【対象ページ】 genre.html（ジャンル一覧ページ）
   ============================================================
   このファイルはジャンル一覧ページ専用のスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【genre.html】ページ見出し「ジャンル一覧」
   ------------------------------------------------------------ */
h1 {
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    margin: 36px 0 20px;
    color: #0c1f35;
    letter-spacing: -0.01em;
}

/* ------------------------------------------------------------
   【genre.html】カード全体（ジャンル一覧を囲む枠）
   ------------------------------------------------------------ */
.genre-container {
    max-width: 480px;
    margin: 0 auto 60px;
    background: #fff;
    border: 1.5px solid #7dd3fa;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.genre-list, .sub-genre-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

/* ------------------------------------------------------------
   【genre.html】「📁 全て表示」リンク（一覧最上部）
   ------------------------------------------------------------ */
.genre-item-all a {
    display: block;
    padding: 16px 24px;
    font-size: 15px !important;
    font-weight: 700;
    color: #0369a1;
    text-decoration: none;
    border-bottom: 1px solid #e0f2fe;
    transition: background 0.15s;
}

.genre-item-all a:hover {
    background: #dbeafe;
    color: #0c1f35;
    text-decoration: none;
}

/* ============================================================
   【genre.html】アコーディオン形式のカテゴリグループ
   （ライフスタイル／社会経済／技術学習／スポーツ／娯楽／仕事）
   ============================================================ */

/* グループ全体の外枠（<details>要素） */
.genre-group {
    border-bottom: 1px solid #e0f2fe;
}

.genre-group:last-child {
    border-bottom: none;
}

/* グループの見出し行（<summary>要素、クリックで開閉） */
.group-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 24px;
    font-size: 15px;
    font-weight: 600;
    color: #0c1f35;
    cursor: pointer;
    user-select: none;
    outline: none;
    list-style: none;
    transition: background 0.15s;
    min-height: 52px;
    box-sizing: border-box;
}

.group-title:hover {
    background: #f0f9ff;
}

.group-title::-webkit-details-marker {
    display: none;
}

/* 開閉状態を示す矢印アイコン（▶ → 開いたら90度回転） */
.group-title .arrow {
    font-size: 10px;
    color: #38bdf8;
    display: inline-block;
    transition: transform 0.22s ease, color 0.22s;
    flex-shrink: 0;
}

details[open] .group-title .arrow {
    transform: rotate(90deg);
    color: #0ea5e9;
}

details[open] .group-title {
    color: #0c1f35;
    background: #f0f9ff;
    border-bottom: 1px solid #e0f2fe;
}

/* ------------------------------------------------------------
   【genre.html】展開時に表示されるサブジャンルのリンク一覧
   ------------------------------------------------------------ */
.sub-genre-list {
    background: #f8fdff;
    padding: 4px 0;
}

.sub-genre-list li a {
    font-weight: 500;
    display: flex;
    align-items: center;
    padding: 12px 24px 12px 36px;
    font-size: 14px !important;
    color: #0369a1;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    min-height: 44px;
    box-sizing: border-box;
}

.sub-genre-list li a::before {
    content: "–";
    margin-right: 8px;
    color: #38bdf8;
    flex-shrink: 0;
}

.sub-genre-list li a:hover {
    background: #dbeafe;
    color: #0c1f35;
    text-decoration: none;
}

/* ------------------------------------------------------------
   【genre.html】カード下部の「一覧画面に戻る」フッターリンク
   ------------------------------------------------------------ */
.genre-footer {
    text-align: center;
    margin: 20px 0 48px;
}

.genre-footer a {
    font-size: 14px;
    color: #0369a1;
    text-decoration: none;
    padding: 10px 22px;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    display: inline-block;
    transition: all 0.18s;
    background: #ffffff;
}

.genre-footer a:hover {
    border-color: #0ea5e9;
    color: #0c1f35;
    background: #dbeafe;
}

/* ------------------------------------------------------------
   【genre.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    h1 { font-size: 18px; margin: 24px 0 16px; }
    .genre-container { margin: 0 16px 48px; border-radius: 10px; }
    .genre-item-all a { padding: 16px 18px; font-size: 14px !important; }
    .group-title { padding: 14px 18px; font-size: 14px; min-height: 50px; }
    .sub-genre-list li a {
    font-weight: 500; padding: 12px 18px 12px 30px; font-size: 14px !important; min-height: 48px; }
}
</file>

<file path="static/css/hashtag.css">
/* ============================================================
   static/css/hashtag.css - Coastal Dawn v2
   【対象ページ】 全ページ共通（base.htmlで読み込み）
   ハッシュタグ関連の表示・入力・絞り込みUIをまとめたファイル。
   ============================================================
   使用ページの内訳:
   - index.html / mypage.html   : 記事カードのハッシュタグバッジ、絞り込みバー
   - detail.html                : 記事詳細のハッシュタグバッジ
   - create.html / update.html  : ハッシュタグ入力欄・プレビュー
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【共通】ハッシュタグバッジ本体（記事カード・記事詳細で表示するタグ）
   ------------------------------------------------------------ */
.hashtag-badge {
    display: inline-block;
    padding: 2px 9px;
    font-size: 12px;
    font-weight: 600;
    color: #0369a1;
    background-color: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 7px;
    text-decoration: none;
    transition: background-color 0.15s, border-color 0.15s;
    white-space: nowrap;
}

.hashtag-badge:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}

/* 【index.html / mypage.html】記事カード内のタグ一覧の並び方 */
.post-hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 4px 0 8px;
}

/* 【detail.html】記事詳細メタ情報内のタグ一覧の並び方 */
.detail-hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
}

/* ============================================================
   【index.html】ハッシュタグ絞り込みバー（ジャンル選択中のみ表示）
   ============================================================ */
.hashtag-filter-bar {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 10px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 4px solid #0ea5e9;
    border-radius: 0 10px 10px 0;
    padding: 14px 18px;
    margin-bottom: 35px;
    box-shadow: 0 2px 10px rgba(14, 165, 233, 0.08);
}

.hashtag-filter-label {
    font-size: 13px;
    font-weight: 700;
    color: #0369a1;
    white-space: nowrap;
    padding-top: 2px;
    flex-shrink: 0;
}

.hashtag-filter-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
}

/* 絞り込みバー内の各タグボタン */
.hashtag-filter-badge {
    display: inline-block;
    padding: 4px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #0369a1;
    background-color: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
}

.hashtag-filter-badge:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}

/* 現在選択中のタグ（塗りつぶし強調） */
.hashtag-filter-badge.active {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
    color: #fff;
}

.hashtag-filter-badge.active:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #fff;
}

/* 「✕ タグ解除」ボタン */
.hashtag-filter-clear {
    display: inline-block;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 700;
    color: #c0392b;
    background-color: #fff;
    border: 1px solid #f5b7b1;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
}

.hashtag-filter-clear:hover {
    background-color: #fff0ee;
    border-color: #e74c3c;
    color: #a93226;
    text-decoration: none;
}

/* ============================================================
   【create.html / update.html】ハッシュタグ入力エリア
   ============================================================ */
.hashtag-input-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    padding: 8px 14px;
    background: #f0f9ff;
    margin-bottom: 10px;
    transition: border-color 0.18s, background 0.18s;
    box-sizing: border-box;
    width: 100%;
}

.hashtag-input-wrapper:focus-within {
    border-color: #0ea5e9;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* 入力欄先頭に固定表示される「#」記号 */
.hashtag-prefix {
    font-size: 16px;
    font-weight: 700;
    color: #0ea5e9;
    margin-right: 6px;
    user-select: none;
    flex-shrink: 0;
}

.hashtag-text-input {
    flex: 1;
    border: none !important;
    outline: none !important;
    background: transparent !important;
    font-size: 15px;
    color: #0c1f35;
    padding: 0 !important;
    margin: 0 !important;
    box-shadow: none !important;
    min-width: 0;
    font-family: inherit;
}

/* 入力内容からリアルタイム生成されるタグプレビューの並び */
.hashtag-preview-area {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-height: 28px;
    margin-bottom: 22px;
}

/* プレビュー用タグバッジ（ポップアニメーション付き） */
.hashtag-badge-preview {
    display: inline-block;
    padding: 3px 12px;
    font-size: 12px;
    font-weight: 600;
    color: #0369a1;
    background-color: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 20px;
    animation: badgePop 0.15s ease;
}

@keyframes badgePop {
    from { transform: scale(0.85); opacity: 0.6; }
    to   { transform: scale(1);    opacity: 1; }
}

/* ------------------------------------------------------------
   【共通】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .hashtag-filter-bar {
        flex-direction: column;
        gap: 8px;
        padding: 12px 14px;
        margin-bottom: 18px;
    }
    .hashtag-filter-list { gap: 6px; }
    .hashtag-filter-badge, .hashtag-filter-clear { font-size: 12px; padding: 5px 12px; }
    .post-hashtags, .detail-hashtags { gap: 5px; }
    .hashtag-badge { font-size: 11px; padding: 2px 8px; }
    .hashtag-input-wrapper { padding: 10px 12px; }
    .hashtag-text-input { font-size: 16px !important; }
}
</file>

<file path="static/css/index.css">
/* ============================================================
   static/css/index.css - Coastal Dawn v2（白ヘッダー・視認性改善版）
   【対象ページ】 index.html（トップページ・記事一覧）
   ============================================================
   このファイルはトップページの記事一覧・記事カード・
   ページ番号ページ送りのスタイルをまとめている。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */


/* ------------------------------------------------------------
   【index.html】メインレイアウト（記事一覧全体を囲む余白）
   ------------------------------------------------------------ */
.page-wrapper {
    max-width: 940px;
    margin: 0 auto;
    padding: 32px 28px 60px;
    margin-top: 15px;
}

/* ------------------------------------------------------------
   【index.html】ページ送り時にスクロールを戻す目印（非表示要素）
   ------------------------------------------------------------
   固定ヘッダー（position: fixed）の下に隠れないよう
   scroll-margin-top をヘッダーの高さ分だけ確保しておく。
   ------------------------------------------------------------ */
#index-articles-anchor {
    scroll-margin-top: 100px;
}

@media (max-width: 767px) {
    #index-articles-anchor {
        scroll-margin-top: 80px;
    }
}


/* ------------------------------------------------------------
   【index.html / mypage.html 共通】記事カードの「編集」リンクボタン
   ------------------------------------------------------------ */
.btn-edit {
    display: inline-block;
    padding: 3px 14px;
    font-size: 14px;
    font-weight: 500;
    color: #0369a1;
    border: 1.2px solid #7dd3fa;
    border-radius: 4px;
    margin-right: 7px;
    background: transparent;
    text-decoration: none;
}

a[role="button"]:hover {
    color: #0c1f35;
    border-color: #0ea5e9;
    background: #e0f2fe;
    text-decoration: none;
}


/* ------------------------------------------------------------
   【index.html】検索・絞り込み結果ラベル（「🔍「◯◯」の検索結果」）
   ------------------------------------------------------------ */
.filter-label {
    font-size: 19px;
    color: #0c1f35;
    font-weight: 600;
    margin-bottom: 10px;
    display: inline-block;
}


/* ------------------------------------------------------------
   【index.html】「📋 最新の記事」セクション見出し
   ------------------------------------------------------------ */
.posts-section-title {
    font-size: 1.4rem !important;
    font-weight: 700;
    color: #0c1f35;
    line-height: 1.4;
    letter-spacing: 0.01em;
}


/* ------------------------------------------------------------
   【index.html】自己紹介（hero）セクションの見出し
   （実際の詳細レイアウトは top_sections.css で定義）
   ------------------------------------------------------------ */
.hero-section-title {
    font-size: 1.4rem !important;
    font-weight: 700;
    color: #0c1f35;
    line-height: 1.4;
    letter-spacing: 0.01em;
}


/* ------------------------------------------------------------
   【index.html / mypage.html 共通】記事カードのジャンル・非公開バッジ
   ------------------------------------------------------------ */
.badge-genre {
    font-size: 13px;
    font-weight: 600;
    color: #0369a1;
    background: #dbeafe;
    border: 1px solid #38bdf8;
    border-radius: 12px;
    padding: 2px 10px;
    white-space: nowrap;
}

.badge-private {
    font-size: 12px;
    font-weight: 700;
    color: #c0392b;
    background: #fff0ee;
    border: 1.2px solid #f5b7b1;
    border-radius: 12px;
    padding: 2px 10px;
    white-space: nowrap;
}


/* ============================================================
   【index.html / mypage.html 共通】記事カード本体
   ============================================================
   左端に 4px のセルリアンアクセントライン。ホバー時にゴールド
   (#f59e0b) へ変化する。カードは角丸なし（左）＋角丸あり（右）で
   「ページから飛び出す」ような奥行きを演出するシグネチャー要素。
   ============================================================ */
.post-card {
    display: flex;
    gap: 36px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 16px 24px;
    margin-bottom: 20px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
    transition: transform 0.22s ease, box-shadow 0.22s ease,
                border-left-color 0.22s ease, border-color 0.22s ease,
                background-color 0.22s ease;
    position: relative;
    cursor: pointer;
}

.post-card:hover {
    transform: translateY(-3px);
    background: #fffbeb;
    border: 1.5px solid #fbbf24;
    border-left: 5px solid #f59e0b;
    box-shadow: 0 8px 28px rgba(245, 158, 11, 0.20),
                0 2px 8px rgba(14, 165, 233, 0.08);
}

/* カード左側のサムネイル画像枠 */
.post-thumbnail {
    flex: 0 0 260px;
    height: 158px;
    border-radius: 8px;
    overflow: hidden;
    background-color: #e0f2fe;
    border: 1.5px solid #7dd3fa;
    transition: border-color 0.22s ease;
}

.post-card:hover .post-thumbnail {
    border-color: #fbbf24;
    background-color: #fef3c7;
}

.thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
}

/* カード右側のコンテンツ（ジャンル・タイトル・日付・操作ボタン）レイアウト */
.post-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.post-header-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
    font-size: 0.95rem;
    flex-wrap: wrap;
}

/* ------------------------------------------------------------
   【index.html / mypage.html 共通】記事タイトルリンク
   ------------------------------------------------------------ */
.post-title {
    margin: 8px 0 8px 0;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.5;
    text-align: left !important;
}

.post-title a {
    color: #0c1f35;
    text-decoration: none;
    display: inline-block;
    transition: color 0.22s ease;
}

/* カード全域をタップ可能にする透明レイヤー */
.post-title a::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
}

.post-card:hover .post-title a {
    color: #0369a1;
    font-weight: 700;
}

/* ------------------------------------------------------------
   【index.html / mypage.html 共通】「編集」「削除」ボタン行（投稿者本人のみ表示）
   ------------------------------------------------------------ */
.post-actions {
    position: relative;
    z-index: 2;
    margin-top: 8px;
}

.btn-delete {
    background: transparent;
    border: 1.2px solid #f5b7b1;
    color: #c0392b;
    padding: 3px 14px;
    font-size: 14px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.18s;
}

.btn-delete:hover {
    background-color: #fff0ee;
    border-color: #e74c3c;
    color: #a93226;
}

/* ------------------------------------------------------------
   【index.html / mypage.html 共通】投稿日・更新日の表示
   ------------------------------------------------------------ */
.post-date {
    margin: 1px 0 0 0;
    font-size: 0.80rem;
    color: #0369a1;
    font-weight: 500;
    transition: color 0.22s ease;
}

.post-card:hover .post-date {
    color: #b45309;
}


/* ============================================================
   【index.html】ページ番号によるページ送り（1ページ5件表示）
   ============================================================
   「もっと見る／表示を減らす」ボタンを廃止し、
   ページ番号によるページ送り UI に置き換えたもの。
   ボタン群は load_more.css の配色トーンを踏襲しつつ、
   現在のページを塗りつぶし（.active）で強調する。
   ============================================================ */

/* ページ送りナビ全体（JS側で totalPages > 1 のときだけ flex 表示） */
.index-pagination {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 8px 0 40px;
    flex-wrap: wrap;
}

/* ページ番号・前へ／次へ の共通ボタンデザイン */
.page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    color: #0369a1;
    background-color: #ffffff;
    border: 1px solid #7dd3fa;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.08);
    transition: background-color 0.2s ease, border-color 0.2s ease,
                color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
}

.page-btn:hover:not(:disabled) {
    background-color: #dbeafe;
    border-color: #38bdf8;
    color: #0c1f35;
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.16);
    transform: translateY(-1px);
}

.page-btn:active:not(:disabled) {
    transform: translateY(0);
    box-shadow: none;
    background-color: #bae6fd;
}

/* 現在表示中のページ番号ボタン（塗りつぶし強調） */
.page-btn.active {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
}

.page-btn.active:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #ffffff;
}

/* 「‹」「›」前へ／次へ ボタン */
.page-btn-arrow {
    font-size: 16px;
    font-weight: 700;
}

/* 先頭・末尾ページで無効化された前へ／次へボタン */
.page-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
    transform: none;
}


/* ==========================================================================
   【index.html / mypage.html 共通】レスポンシブ（スマホ）
   ========================================================================== */

@media (max-width: 600px) {
    .page-wrapper {
        padding: 16px 14px 48px;
    }

    .post-card {
        flex-direction: column;
        gap: 12px;
        padding: 15px;
        margin-top: 5px;
        border-radius: 0 10px 10px 0;
    }

    .post-thumbnail {
        flex: none;
        width: 100%;
        height: 240px;
    }

    .post-content {
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    .post-header-meta {
        font-size: 0.85rem;
        margin-bottom: 4px;
    }

    .post-title {
        font-size: 1.1rem;
        line-height: 1.45;
        margin-bottom: 10px;
    }

    .post-date {
        order: 0;
        font-size: 0.75rem;
        margin-top: 3px;
        margin-bottom: 3px;
    }

    .post-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
        margin-bottom: 3px;
        width: 100%;
    }

    .btn-edit,
    .btn-delete {
        padding: 4px 17px;
        font-size: 13px;
        min-height: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .post-actions {
        order: 1;
    }

    .post-title a::after {
        inset: 0;
        z-index: 1;
    }

    .index-pagination {
        gap: 6px;
        margin: 8px 0 32px;
    }

    .page-btn {
        min-width: 36px;
        height: 36px;
        padding: 0 10px;
        font-size: 13px;
    }
}
</file>

<file path="static/css/load_more.css">
/* ============================================================
   static/css/load_more.css - Coastal Dawn v2
   【対象ページ】 mypage.html（マイページの投稿一覧）
   ============================================================
   以前は index.html でも使用していたが、index.html は
   ページ番号方式のページ送り（index.css の .index-pagination）に
   置き換えたため、現在この CSS を読み込んでいるのは
   mypage.html のみ。学習用サンプルとしてこのファイル自体は
   そのまま残してある。
   ============================================================ */

/* ------------------------------------------------------------
   【mypage.html】「もっと見る／表示を減らす」ボタンのラッパー
   ------------------------------------------------------------ */
.load-more-wrap {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 8px 0 40px;
    flex-wrap: wrap;
}

/* ------------------------------------------------------------
   【mypage.html】「もっと見る」「▲ 表示を減らす」ボタン共通デザイン
   ------------------------------------------------------------ */
.load-more-btn,
.load-less-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 40px;
    border-radius: 24px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    transition: background-color 0.2s ease, border-color 0.2s ease,
                color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
}

/* 「もっと見る」ボタン（白背景） */
.load-more-btn {
    background-color: #ffffff;
    color: #0369a1;
    border: 1px solid #7dd3fa;
    box-shadow: 0 2px 10px rgba(14, 165, 233, 0.10);
}

.load-more-btn:hover {
    background-color: #dbeafe;
    border-color: #38bdf8;
    color: #0c1f35;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.18);
    transform: translateY(-1px);
}

.load-more-btn:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #bae6fd;
}

/* 「▲ 表示を減らす」ボタン（控えめなグレー系） */
.load-less-btn {
    background-color: #ffffff;
    color: #4a7a96;
    border: 1px solid #bae6fd;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.06);
}

.load-less-btn:hover {
    background-color: #f0f9ff;
    border-color: #7dd3fa;
    color: #0c1f35;
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.12);
    transform: translateY(-1px);
}

.load-less-btn:active {
    transform: translateY(0);
    box-shadow: none;
    background-color: #e0f2fe;
}

/* ------------------------------------------------------------
   【mypage.html】「もっと見る」ボタン内の残り件数バッジ（「あと◯件」）
   ------------------------------------------------------------ */
.load-more-count {
    display: inline-block;
    background: #dbeafe;
    color: #0369a1;
    font-size: 12px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 10px;
    min-width: 28px;
    text-align: center;
    line-height: 1.6;
    transition: background-color 0.2s;
}

.load-more-btn:hover .load-more-count {
    background-color: #bae6fd;
}

/* ------------------------------------------------------------
   【mypage.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 600px) {
    .load-more-wrap { flex-direction: column; gap: 8px; }
    .load-more-btn, .load-less-btn {
        width: 100%;
        justify-content: center;
        padding: 14px 24px;
        font-size: 15px;
        border-radius: 20px;
    }
}
</file>

<file path="static/css/mypage.css">
/* ============================================================
   static/css/mypage.css - Coastal Dawn v2
   【対象ページ】 mypage.html（マイページ）
   ============================================================
   このファイルはマイページ専用のスタイルをまとめている
   （記事カード自体のデザインは index.css を共用）。
   機能・パーツ単位で見出しコメントを付け、どのUI要素の
   デザインかが一目でわかるように整理している。
   ============================================================ */

/* ------------------------------------------------------------
   【mypage.html】ページ全体のレイアウト
   ------------------------------------------------------------ */
.mypage-container {
    max-width: 940px;
    margin: 0 auto;
    padding: 38px 28px 60px;
    box-sizing: border-box;
}

/* ============================================================
   【mypage.html】プロフィールカード（ニックネーム・投稿数・変更フォーム）
   ============================================================ */
.profile-header {
    background: #fff;
    padding: 28px 28px 24px;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    margin-bottom: 30px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.profile-title {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 8px 0;
    color: #0c1f35;
    letter-spacing: -0.01em;
}

.profile-username {
    margin: 4px 0 0;
    color: #4a7a96;
    font-size: 13px;
}

.profile-post-count {
    font-weight: 500;
    margin: 10px 0 0;
    color: #2a4a5e;
    font-size: 14px;
}

.profile-post-count strong {
    color: #0369a1;
    font-weight: 700;
}

/* ------------------------------------------------------------
   【mypage.html】ニックネーム変更フォーム
   ------------------------------------------------------------ */
.nickname-form-wrapper {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid #e0f2fe;
}

.nickname-form-wrapper > p,
.nickname-form label {
    font-size: 13px;
    color: #4a7a96;
    margin: 0 0 8px;
    font-weight: 500;
}

.nickname-form {
    display: flex;
    gap: 8px;
    align-items: center;
}

.nickname-input {
    flex: 1;
    min-width: 0;
    padding: 8px 14px;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.18s, box-shadow 0.18s;
    background: #f0f9ff;
    color: #0c1f35;
    font-family: inherit;
}

.nickname-input:focus {
    border-color: #0ea5e9;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

.nickname-submit-btn {
    padding: 8px 18px;
    background-color: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    transition: background 0.18s;
    white-space: nowrap;
    flex-shrink: 0;
    font-family: inherit;
}

.nickname-submit-btn:hover {
    background-color: #0369a1;
}

/* ------------------------------------------------------------
   【mypage.html】セクション見出し（「📂 使用ジャンル」「📝 投稿一覧」）
   ------------------------------------------------------------ */
.section-title-genre,
.section-title-posts {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 36px 0 20px;
    letter-spacing: 0.02em;
}

/* ------------------------------------------------------------
   【mypage.html】使用ジャンルのタグ一覧
   ------------------------------------------------------------ */
.user-genre-list { margin-bottom: 8px; }

.genre-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.genre-tag-item {
    background: #dbeafe;
    border: 1px solid #38bdf8;
    padding: 4px 14px;
    border-radius: 15px;
    display: inline-block;
    transition: all 0.15s;
}

.genre-tag-item:hover {
    background: #bae6fd;
    border-color: #0ea5e9;
}

.genre-tag-link {
    text-decoration: none;
    color: #0369a1;
    font-size: 13px;
    font-weight: 600;
}

/* ------------------------------------------------------------
   【mypage.html】投稿が1件もない場合の案内メッセージ
   ------------------------------------------------------------ */
.empty-message {
    color: #4a7a96;
    text-align: center;
    margin-top: 48px;
    font-size: 15px;
    line-height: 2;
}

.empty-message a {
    color: #0369a1;
    text-decoration: underline;
}

/* ------------------------------------------------------------
   【mypage.html】レスポンシブ（スマホ）
   ------------------------------------------------------------ */
@media (max-width: 767px) {
    .mypage-container { padding: 15px 12px 48px; width: 100% !important; box-sizing: border-box; }
    .profile-header { padding: 20px 16px 18px; border-radius: 0 10px 10px 0; margin-bottom: 20px; }
    .profile-title { font-size: 17px; }
    .nickname-form { flex-direction: column; align-items: stretch; gap: 8px; }
    .nickname-input { font-size: 16px; width: 100% !important; box-sizing: border-box; }
    .nickname-submit-btn { text-align: center; margin-top: 4px; padding: 10px; font-size: 14px; width: 100%; min-height: 40px; }
    .section-title-genre, .section-title-posts { font-size: 15px; margin: 28px 0 16px; }
    .genre-tag-item { padding: 6px 14px; }
}
</file>

<file path="static/css/top_sections.css">
/* ============================================================
   static/css/top_sections.css - Coastal Dawn v2（白ヘッダー・視認性改善版）
   【対象ページ】 index.html（hero・stats・記事一覧見出し・検索エリア）
                 about.html / howto.html（静的情報ページ共通レイアウト）
   ============================================================
   複数ページで共用する「セクション単位」のパーツをまとめたファイル。
   どのページ・どの機能のデザインかをブロックごとに明記している。
   ============================================================ */


/* ------------------------------------------------------------
   【index.html】hero（自己紹介）セクションの見出し「📋 自己紹介」
   ------------------------------------------------------------ */
.hero-section-title {
    font-size: 16px;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 0 0 20px;
    text-align: left;
    letter-spacing: 0.02em;
    margin-top: 45px;
}


/* ------------------------------------------------------------
   【共通】セクション間の余白（hero / howto / stats 共通）
   ------------------------------------------------------------ */
.hero-section,
.howto-section,
.stats-section {
    margin-bottom: 40px;
}


/* ============================================================
   【index.html】hero（自己紹介）セクション本体（hero.htmlをinclude）
   ============================================================
   hero カードは記事カードと同じ左アクセントラインデザインに統一。
   背景は白、外枠は #bae6fd で視認性◎。
   ============================================================ */
.hero-section {
    display: flex;
    align-items: center;
    gap: 24px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 28px 32px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

/* 管理者アバター画像 */
.hero-avatar img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid #bae6fd;
    background: #e0f2fe;
    flex-shrink: 0;
    display: block;
}

.hero-body {
    flex: 1;
}

/* ブログ名見出し（「◯◯ のブログ」） */
.hero-name {
    font-size: 20px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0 0 10px;
    text-align: left;
    letter-spacing: -0.02em;
}

/* 自己紹介の一言テキスト */
.hero-bio {
    font-weight: 500;
    font-size: 15px;
    color: #2a4a5e;
    line-height: 1.75;
    margin: 0;
}

/* 「👤 自己紹介を読む」「📖 使い方を見る」リンクボタン */
.hero-links {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    flex-wrap: wrap;
}

.hero-link-btn {
    display: inline-block;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
    color: #0369a1;
    background: #e0f2fe;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.18s;
    white-space: nowrap;
}

.hero-link-btn:hover {
    background: #bae6fd;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}


/* ============================================================
   【現状未使用】howto セクション用スタイル
   ============================================================
   このブロックは元々 howto.html 内の「使い方リスト」表示用に
   作られたものだが、howto.html は現在
   about.html と同じ .info-page-container 系レイアウト
   （このファイル内の「about/howtoページ共通」セクション）
   に統一されているため、.howto-section 系クラスは
   現状どのテンプレートからも参照されていない。
   将来 howto 用の別レイアウトを作る際の下敷きとして残している。
   ============================================================ */
.howto-section {
    background: #f4fbff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 24px 28px;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.08);
}

.howto-title {
    font-size: 16px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0 0 16px;
    text-align: left;
}

.howto-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.howto-item {
    font-weight: 500;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 14px;
    color: #2a4a5e;
    line-height: 1.65;
}

.howto-icon {
    font-size: 20px;
    flex-shrink: 0;
    line-height: 1.4;
}

.howto-item strong {
    color: #0c1f35;
    font-weight: 700;
}


/* ============================================================
   【index.html】サイト統計セクション（stats.htmlをinclude、
   絞り込みなしのトップ表示時のみ表示）
   ============================================================
   stats カードの上部に 3px のセルリアンラインを追加（ヘッダーと連動）。
   数値は明朝体×#0369a1 で品格を出す。
   白背景カードを #f0f9ff の page 上に置くことで浮き上がり感が生まれる。
   ============================================================ */
.stats-section {
    display: flex;
    gap: 16px;
    height: 70%;
}

/* 「総投稿数」「ハッシュタグ数」「最終更新日」の各カード */
.stats-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-top: 4px solid #0ea5e9;
    border-radius: 0 0 12px 12px;
    padding: 16px 10px;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.12);
    text-align: center;
}

.stats-icon {
    font-size: 20px;
    line-height: 1;
}

.stats-number {
    font-size: 26px;
    font-weight: 700;
    color: #0369a1;
    line-height: 1.2;
    letter-spacing: -0.03em;
}

.stats-label {
    font-size: 12px;
    color: #4a7a96;
    font-weight: 600;
    letter-spacing: 0.03em;
}


/* ------------------------------------------------------------
   【index.html】「📋 最新の記事」一覧見出し
   ------------------------------------------------------------
   注意: 同名クラス .posts-section-title は index.css 側でも
   フォントサイズ等を再定義している（index.css の定義が優先される）。
   ここではスマホ以外の基本デザインを担当。
   ------------------------------------------------------------ */
.posts-section-title {
    font-size: 16px;
    font-weight: 700;
    color: #0c1f35;
    border-bottom: 2px solid #0ea5e9;
    padding-bottom: 10px;
    margin: 0 0 20px;
    text-align: left;
    letter-spacing: 0.02em;
    border-top: 100px;
}


/* ============================================================
   【about.html / howto.html 共通】静的情報ページのレイアウト
   ============================================================ */
.info-page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 36px 24px 60px;
    box-sizing: border-box;
}

/* ページ上部のアバター＋タイトル行 */
.info-page-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
}

.info-page-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 3px solid #bae6fd;
    background: #e0f2fe;
    flex-shrink: 0;
}

.info-page-title {
    font-size: 22px;
    font-weight: 700;
    color: #0c1f35;
    margin: 0;
    text-align: left;
    letter-spacing: -0.02em;
}

/* 本文を囲むカード */
.info-page-body {
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-left: 5px solid #0ea5e9;
    border-radius: 0 12px 12px 0;
    padding: 32px 36px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
    margin-bottom: 28px;
}

/* 本文内の各セクション（見出し＋段落のセット） */
.info-section {
    margin-bottom: 32px;
}

.info-section:last-child {
    margin-bottom: 0;
}

.info-section-title {
    font-size: 17px;
    font-weight: 700;
    color: #0c1f35;
    border-left: 4px solid #0ea5e9;
    padding-left: 12px;
    margin: 0 0 12px;
    text-align: left;
}

.info-section p {
    font-weight: 500;
    font-size: 15px;
    color: #2a4a5e;
    line-height: 1.8;
    margin: 0;
}

/* 「← トップに戻る」フッターボタン */
.info-page-footer {
    text-align: center;
}

.info-back-btn {
    display: inline-block;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    color: #0369a1;
    border: 1px solid #7dd3fa;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.18s;
}

.info-back-btn:hover {
    background: #e0f2fe;
    border-color: #0ea5e9;
    color: #0c1f35;
    text-decoration: none;
}


/* ============================================================
   【index.html】インページ検索エリア（search_area.htmlをinclude、常に表示）
   ジャンル選択＋キーワード入力を同時に指定できる検索フォーム
   ============================================================
   検索エリアは白カード。#f0f9ff の page 背景上でしっかり浮き上がる。
   ============================================================ */
.index-search-area {
    background: #ffffff;
    border: 1.5px solid #7dd3fa;
    border-radius: 12px;
    padding: 20px 24px 22px;
    margin-bottom: 30px;
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);
}

.index-search-title {
    font-size: 16px;
    font-weight: 700;
    color: #0369a1;
    margin: 0 0 18px;
    letter-spacing: 0.03em;
}

.index-search-form {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    flex-wrap: wrap;
}

.index-search-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.index-search-genre {
    flex: 0 0 180px;
}

.index-search-keyword {
    flex: 1 1 180px;
    min-width: 160px;
}

.index-search-action {
    flex: 0 0 auto;
}

/* 各入力欄のラベル（「ジャンル」「キーワード」） */
.index-search-label {
    font-size: 12px;
    font-weight: 700;
    color: #4a7a96;
    letter-spacing: 0.02em;
    white-space: nowrap;
}

/* 検索ボタン列でラベルと縦位置を揃えるための空白スペーサー（PCのみ） */
.index-search-label-spacer {
    display: block;
    height: 18px;
    pointer-events: none;
}

/* ------------------------------------------------------------
   【index.html】検索エリア内「ジャンル」セレクトボックス
   ------------------------------------------------------------ */
.index-search-select-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

.index-search-select {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    padding: 10px 36px 10px 14px;
    font-size: 14px;
    color: #0c1f35;
    background: #f0f9ff;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    outline: none;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.18s, background 0.18s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.index-search-select:focus {
    border-color: #0ea5e9;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

/* セレクトボックスのカスタム矢印アイコン */
.index-search-select-arrow {
    position: absolute;
    right: 10px;
    width: 16px;
    height: 16px;
    color: #4a7a96;
    pointer-events: none;
    flex-shrink: 0;
    transition: color 0.18s;
}

.index-search-select-wrap:focus-within .index-search-select-arrow {
    color: #0ea5e9;
}

/* ------------------------------------------------------------
   【index.html】検索エリア内「キーワード」テキスト入力欄
   ------------------------------------------------------------ */
.index-search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

/* 入力欄左側の虫眼鏡アイコン */
.index-search-input-icon {
    position: absolute;
    left: 12px;
    width: 16px;
    height: 16px;
    color: #7dd3fa;
    pointer-events: none;
    flex-shrink: 0;
    transition: color 0.18s;
}

.index-search-input-wrap:focus-within .index-search-input-icon {
    color: #0ea5e9;
}

.index-search-input {
    width: 100%;
    padding: 10px 36px 10px 36px;
    font-size: 14px;
    color: #0c1f35;
    background: #f0f9ff;
    border: 1px solid #7dd3fa;
    border-radius: 8px;
    outline: none;
    font-family: inherit;
    box-sizing: border-box;
    transition: border-color 0.18s, background 0.18s;
}

.index-search-input:focus {
    border-color: #0ea5e9;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
}

.index-search-input::placeholder {
    color: #7ab8d8;
}

/* 入力内容をクリアする「✕」ボタン（JSで表示切替） */
.index-search-clear {
    position: absolute;
    right: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: none;
    border: none;
    border-radius: 50%;
    color: #7ab8d8;
    font-size: 13px;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.15s, background 0.15s;
}

.index-search-clear:hover {
    color: #c0392b;
    background: #fff0ee;
}

/* ------------------------------------------------------------
   【index.html】検索エリア内「検索する」ボタン・「絞り込みを解除」リンク
   ------------------------------------------------------------ */
.index-search-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 22px;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
    background: #0ea5e9;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: background-color 0.18s, transform 0.13s;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
    min-height: 42px;
}

.index-search-btn:hover {
    background: #0369a1;
    transform: translateY(-1px);
}

.index-search-btn:active {
    transform: translateY(0);
    background: #075985;
}

.index-search-reset {
    display: inline-block;
    margin-top: 6px;
    font-size: 12px;
    font-weight: 600;
    color: #c0392b;
    text-decoration: none;
    padding: 4px 10px;
    border: 1px solid #f5b7b1;
    border-radius: 20px;
    background: #ffffff;
    transition: all 0.15s;
    white-space: nowrap;
}

.index-search-reset:hover {
    background: #fff0ee;
    border-color: #e74c3c;
    color: #a93226;
    text-decoration: none;
}


/* ==========================================================================
   【共通】レスポンシブ（スマホ）
   ========================================================================== */

@media (max-width: 600px) {
    /* --- hero（自己紹介）セクション --- */
    .hero-section {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        padding: 20px 16px;
    }

    .hero-avatar img {
        width: 64px;
        height: 64px;
    }

    .hero-name {
        font-size: 17px;
    }

    .hero-bio {
    font-weight: 500;
        font-size: 14px;
    }

    .hero-links {
        flex-direction: column;
        gap: 17px;
    }

    .hero-link-btn {
        text-align: center;
    }

    /* --- howto セクション（現状未使用） --- */
    .howto-section {
        padding: 18px 16px;
    }

    .howto-title {
        font-size: 15px;
    }

    .howto-item {
    font-weight: 500;
        font-size: 13px;
        gap: 10px;
    }

    .howto-icon {
        font-size: 18px;
    }

    /* --- stats（統計）セクション --- */
    .stats-section {
        gap: 10px;
    }

    .stats-card {
        padding: 14px 8px;
    }

    .stats-icon {
        font-size: 18px;
    }

    .stats-number {
        font-size: 20px;
    }

    .stats-label {
        font-size: 11px;
    }

    /* --- about/howto 静的ページ共通レイアウト --- */
    .info-page-container {
        padding: 20px 0 48px;
    }

    .info-page-header {
        padding: 0 16px;
        gap: 14px;
        margin-bottom: 20px;
    }

    .info-page-avatar {
        width: 56px;
        height: 56px;
    }

    .info-page-title {
        font-size: 18px;
    }

    .info-page-body {
        padding: 24px 16px;
        border-radius: 0 10px 10px 0;
    }

    .info-section-title {
        font-size: 15px;
    }

    .info-section p {
    font-weight: 500;
        font-size: 14px;
    }

    /* --- インページ検索エリア --- */
    .index-search-area {
        padding: 16px 14px 18px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .index-search-title {
        font-size: 15px;
        margin-bottom: 12px;
    }

    .index-search-form {
        flex-direction: column;
        gap: 10px;
        align-items: stretch;
    }

    .index-search-genre,
    .index-search-keyword,
    .index-search-action {
        flex: none;
        width: 100%;
    }

    .index-search-select,
    .index-search-input {
        font-size: 15px;
        padding-top: 12px;
        padding-bottom: 12px;
    }

    .index-search-btn {
        width: 100%;
        justify-content: center;
        padding: 13px 24px;
        font-size: 14px;
        min-height: 48px;
        border-radius: 8px;
        margin-top: 7px;
        margin-bottom: 5px;
    }

    .index-search-label-spacer {
        display: none;
    }

    .index-search-reset {
        text-align: center;
        width: 100%;
        box-sizing: border-box;
        padding: 8px;
        margin-top: 5px;
    }
}
</file>

<file path="templates/about.html">
{% extends "base.html" %}
{% block content %}

<link rel="stylesheet" href="{{ url_for('static', filename='css/top_sections.css') }}">

<div class="info-page-container">
    <div class="info-page-header">
        <img src="https://api.dicebear.com/7.x/identicon/svg?seed={{ admin_user.nickname if admin_user and admin_user.nickname else 'admin' }}"
             alt="管理者アバター" class="info-page-avatar">
        <h1 class="info-page-title">
            {{ admin_user.nickname if admin_user and admin_user.nickname else '管理者' }} について
        </h1>
    </div>

    <div class="info-page-body">
        <section class="info-section">
            <h2 class="info-section-title">👤 自己紹介</h2>
            <p>
                はじめまして!「MIT Blog」管理者の MIT です。<br>
                普段は旅行や野球観戦、ゲーム、映画・作品鑑賞など、多趣味に楽しんでいます。<br>
                最近は特にAIを活用したWebアプリ開発に挑戦中です。
            </p>
        </section>

        <section class="info-section">
            <h2 class="info-section-title">💡 興味・関心</h2>
            <p>
                今後、大学の研究で必要になるデータ分析やWebアプリ開発に関連する知識や技術習得のため、
                AIの活用法をはじめ、フロントエンドデザイン、セキュリティの強化、機械学習について学習中です。
            </p>
        </section>

        <section class="info-section">
            <h2 class="info-section-title">📝 このブログについて</h2>
            <p>
                このブログは、学習内容や趣味について発信しながら、アウトプットを習慣化し、文章力を高めることを目的に立ち上げました。
                開発記録や技術的な気づきだけでなく、旅行先の体験や作品の感想など、幅広く発信していく予定です。
            </p>
        </section>
    </div>

    <div class="info-page-footer">
        <a href="/" class="info-back-btn">← トップに戻る</a>
    </div>
</div>

{% endblock %}
