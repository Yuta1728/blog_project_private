   ============================================================ */
.main-header {
    background-color: #ffffff;
    border-bottom: 3px solid #0ea5e9;
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transform: translateY(0);
    visibility: visible;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0s,
                background-color 0.25s ease,
                border-color 0.25s ease;
}

/* 下スクロール時にヘッダーを画面外へスライドアウトさせる状態（JSが付与） */
.main-header.header-hidden {
    transform: translateY(-100%);
    visibility: hidden;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0.2s;
}

/* ヘッダー内側のレイアウト（ロゴ／ナビを横並びに配置） */
.header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    height: 85px;
    gap: 24px;
}

/* ------------------------------------------------------------
   【共通ヘッダー】ヘッダー右側の操作群
   ------------------------------------------------------------
   ナビ・テーマ切り替えボタン・ハンバーガーを1つの塊にまとめ、
   ロゴ（左）と右側操作群（右）を space-between で両端に配置する。
   ------------------------------------------------------------ */
.header-right {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 0 0 auto;
}

/* ------------------------------------------------------------
   【共通ヘッダー】ロゴ（「MIT Blog」）
   ------------------------------------------------------------
   ロゴは Noto Serif JP（明朝体）のインク色（#0c1f35）。
   白背景上でくっきりと読める十分なコントラストを確保。
   ------------------------------------------------------------ */
.header-logo {
    flex: 0 0 auto;
}

.header-logo a {
    color: #0c1f35 !important;
    text-decoration: none !important;
    font-size: 35px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    display: block;
}

.header-logo a:hover {
    color: #0369a1 !important;
    text-decoration: none !important;
}

/* ------------------------------------------------------------
   【共通ヘッダー】PC用ナビゲーション（新規投稿／ジャンル検索／自己紹介／マイページ／ログアウト）
   ------------------------------------------------------------
   白背景上のナビリンク。テキストを #0369a1（濃いセルリアン）に設定し
   白背景でも確実に視認できるコントラストを確保。
   ------------------------------------------------------------ */
.header-nav {
    flex: 0 0 auto;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.header-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.header-nav ul li {
    display: inline-block;
    line-height: 1;
}

.header-nav ul li a {
    color: #0369a1;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 20px;
    background-color: #e0f2fe;
    border: 1px solid #38bdf8;
    transition: all 0.18s ease;
    display: inline-block;
    white-space: nowrap;
}

.header-nav ul li a:hover {
    color: #0c1f35;
    border-color: #0ea5e9;
    background-color: #bae6fd;
    text-decoration: none;
}

/* 先頭の「新規投稿」だけセルリアン塗りつぶしで強調 */
.header-nav ul li:first-child a {
    background-color: #0ea5e9;
    color: #ffffff;
    border-color: #0ea5e9;
    font-weight: 700;
}

.header-nav ul li:first-child a:hover {
    background-color: #0369a1;
    border-color: #0369a1;
    color: #ffffff;
}


/* ------------------------------------------------------------
   【共通ヘッダー】ダークモード切り替えボタン（🌙 / ☀️）
   ------------------------------------------------------------
   PC・スマホ共通で常時表示。クリックで data-theme を切り替え、
   選択内容は localStorage に保存される（JS は base.html 側）。
   ------------------------------------------------------------ */
.theme-toggle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border-radius: 50%;
    border: 1.5px solid #38bdf8;
    background-color: #e0f2fe;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    flex-shrink: 0;
    transition: background-color 0.18s ease, border-color 0.18s ease, transform 0.13s ease;
}

.theme-toggle-btn:hover {
    background-color: #bae6fd;
    border-color: #0ea5e9;
    transform: translateY(-1px);
}

.theme-toggle-btn:active {
    transform: translateY(0);
    background-color: #7dd3fa;
}

.theme-toggle-icon {
    display: block;
    pointer-events: none;
}


/* ------------------------------------------------------------
   【共通ヘッダー】ハンバーガーボタン（スマホ・PC非表示のメニュー開閉ボタン）
   ------------------------------------------------------------
   白ヘッダー上のハンバーガーラインはセルリアン系の濃い色で視認性を確保。
   ------------------------------------------------------------ */
.hamburger-btn {
    display: none;
    background: none;
    border: 1.5px solid #bae6fd;
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
}

.hamburger-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #0369a1;
    border-radius: 2px;
    transition: all 0.25s ease;
}


/* ============================================================
   【共通ヘッダー】スマホ用ドロワーメニュー（ハンバーガーで開閉）
   ============================================================ */

/* 背景を暗く覆うオーバーレイ */
.mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(12, 31, 53, 0.45);
    z-index: 999;
}

.mobile-nav-overlay.open {
    display: block;
}

/* 右からスライドインするドロワー本体 */
.mobile-nav-drawer {
    position: fixed;
    top: 0;
    right: -290px;
    width: 270px;
    height: 100dvh;
    background: #ffffff;
    box-shadow: -4px 0 20px rgba(14, 165, 233, 0.15);
    z-index: 1000;
    transition: right 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
}

.mobile-nav-drawer.open {
    right: 0;
}

/* ドロワー上部（ロゴ＋閉じるボタン） */
.mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 3px solid #0ea5e9;
    background: #ffffff;
}

.mobile-nav-header-logo {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #0c1f35;
}

.mobile-nav-close {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #5a8ba8;
    padding: 4px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    transition: background 0.15s;
}

.mobile-nav-close:hover,
.mobile-nav-close:active {
    background: #e0f2fe;
}

/* ドロワー内のメニュー項目 */
.mobile-nav-drawer ul {
    list-style: none;
    margin: 12px 0 0;
    padding: 0 12px;
}

.mobile-nav-drawer ul li {
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 6px;
}

.mobile-nav-drawer ul li a {
    display: block;
    padding: 14px 16px;
    color: #0369a1;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    transition: background 0.15s;
    border-radius: 8px;
    min-height: 48px;
    border-left: 3px solid transparent;
}

.mobile-nav-drawer ul li a:hover,
.mobile-nav-drawer ul li a:active {
    background: #e0f2fe;
    border-left-color: #0ea5e9;
}

/* 先頭の「新規投稿」だけ強調表示 */
.mobile-nav-drawer ul li:first-child a {
    background-color: #0ea5e9;
    color: #fff;
    margin-bottom: 12px;
    text-align: center;
    border-left-color: transparent;
    font-weight: 700;
}

.mobile-nav-drawer ul li:first-child a:hover,
.mobile-nav-drawer ul li:first-child a:active {
    background-color: #0369a1;
}

/* 【共通】floatクリア用ユーティリティ */
.clear { clear: both; }


/* ==========================================================================
   【共通ヘッダー】レスポンシブ（スマホ）
   ========================================================================== */

@media (max-width: 767px) {

    /* ========================================================================
       【スマホのフォントが細く見える問題への対応】
       ------------------------------------------------------------------------
       body に指定している -webkit-font-smoothing: antialiased は、
       WebKit 系ブラウザ（iPhone の Safari / Chrome など）で文字の線を
       グレースケール・アンチエイリアスで「細く」描画する。
       一方 Windows の Chrome / Edge はこの指定を無視し、ClearType で
       しっかりした太さで描画するため、
       「Windows では普通なのにスマホだけ痩せて見える」差が生まれていた。

       文字の太さ（font-weight）は Windows もスマホも同じ値なので、
       スマホ側でこの痩せる描画（antialiased）を解除するだけで、
       Windows とほぼ同じ見た目の太さになる。

       - -webkit-font-smoothing: auto  … WebKit 系の痩せ描画を解除
       - -moz-osx-font-smoothing: auto … macOS 版 Firefox 用の同等指定
       ※ これらのプロパティは継承されるため html, body に指定すれば
         ページ内すべての文字（他CSSファイルで装飾された要素も含む）に効く。
       ======================================================================== */
    html,
    body {
        -webkit-font-smoothing: auto;
        -moz-osx-font-smoothing: auto;
    }

    .header-container {
        padding: 0 15px;
        height: 63px;
        gap: 12px;
    }

    /* 固定ヘッダーの高さがスマホでは63pxになるため、
       本文の押し下げ量もそれに合わせて上書きする。 */
    body {
        padding-top: 63px;
    }

    .header-logo a {
        font-size: 26px;
    }

    .header-nav {
        display: none;
    }

    /* スマホではナビが消える分、右側の間隔を詰める */
    .header-right {
        gap: 10px;
    }

    /* スマホでもテーマ切り替えボタンは常時表示（少しだけ小さく） */
    .theme-toggle-btn {
        width: 38px;
        height: 38px;
        font-size: 17px;
    }

    .hamburger-btn {
        display: flex;
    }

    .flash-messages {
        margin: 12px 16px;
    }

    .flash-messages li {
        font-size: 13px;
    }

    h2 {
        font-size: 20px;
        margin: 16px 0;
    }
}
